---
import Eyebrow from "../primitives/Eyebrow.astro";
---

<header class="lookbook-header">
  <Eyebrow>Editorial Lookbook</Eyebrow>

  <h2>
    <span class="title-intro">Scenes From</span>
    <span class="title-statement">A Couture Story</span>
  </h2>

  <p>
    A quiet edit of silhouettes, details and moments designed to feel less like
    browsing and more like entering the world of Rangbastra.
  </p>
</header>

<style>
  .lookbook-header {
    display: grid;
    gap: var(--space-5);
    max-width: var(--measure-md);
  }

  h2 {
    display: grid;
    gap: var(--space-2);
    max-width: min(100%, 48rem);
    color: var(--text-primary);
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    text-wrap: balance;
  }

  .title-intro {
    color: var(--text-primary);
    font-size: var(--section-heading-intro);
    letter-spacing: var(--tracking-heading);
    line-height: 1.18;
    white-space: nowrap;
  }

  .title-statement {
    background: var(--gradient-brand-text);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    font-size: var(--section-heading-statement);
    letter-spacing: var(--tracking-heading);
    line-height: 1.12;
    padding-bottom: .08em;
    white-space: nowrap;
  }

  p {
    max-width: var(--measure-md);
    color: var(--text-secondary);
    font-size: var(--body-md);
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  @media (max-width: 767px) {
    .lookbook-header {
      gap: var(--space-4);
    }

    .title-intro {
      font-size: var(--section-heading-intro-mobile);
    }

    .title-statement {
      font-size: var(--section-heading-statement-mobile);
    }
  }
</style>
