---
import { signatureDetails } from "../../data/lookbookExperience";
import LookbookExperienceHeader from "./LookbookExperienceHeader.astro";
---

<section class="signature-details" aria-labelledby="signature-details-heading">
  <LookbookExperienceHeader
    id="signature-details-heading"
    eyebrow="Signature Details"
    intro="Close Enough"
    statement="To Feel The Craft"
    copy="Embroidery, fabric, mirror work and finishing details are framed as intimate textures rather than decorative proof."
  />

  <div class="detail-rail" aria-label="Signature detail photography">
    {
      signatureDetails.map((detail) => (
        <article
          class:list={["detail-card", `detail-card--${detail.frame}`]}
          style={`--detail-image: url("${detail.image}")`}
        >
          <img src={detail.image} alt={`${detail.title} close-up`} loading="lazy" decoding="async" />
          <div>
            <span>{detail.collection}</span>
            <h3>{detail.title}</h3>
            <p>{detail.caption}</p>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .signature-details {
    display: grid;
    gap: clamp(var(--space-7), 6vw, var(--space-10));
  }

  .detail-rail {
    display: grid;
    grid-auto-columns: minmax(17rem, 24rem);
    grid-auto-flow: column;
    gap: var(--space-4);
    overflow-x: auto;
    padding-block-end: var(--space-3);
    scroll-snap-type: x proximity;
    scrollbar-width: thin;
  }

  .detail-card {
    position: relative;
    display: grid;
    align-items: end;
    overflow: hidden;
    min-height: 31rem;
    border: 1px solid rgba(255, 255, 255, .1);
    background: var(--detail-image) center / cover no-repeat;
    scroll-snap-align: start;
    isolation: isolate;
  }

  .detail-card--landscape {
    grid-column: span 2;
    min-width: min(34rem, 86vw);
  }

  .detail-card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, transparent 34%, rgba(0, 0, 0, .82));
    pointer-events: none;
  }

  .detail-card img {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .detail-card div {
    position: relative;
    z-index: 2;
    display: grid;
    gap: var(--space-2);
    padding: var(--space-5);
  }

  .detail-card span {
    color: var(--text-muted);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-caption);
    text-transform: uppercase;
  }

  h3 {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 2.6vw, 2.8rem);
    font-weight: var(--weight-light);
    line-height: 1.06;
  }

  p {
    color: var(--text-secondary);
    font-size: var(--body-sm);
    line-height: var(--leading-body);
  }

  @media (max-width: 560px) {
    .detail-rail {
      grid-auto-columns: minmax(15.5rem, 82vw);
    }

    .detail-card {
      min-height: 27rem;
    }
  }
</style>
