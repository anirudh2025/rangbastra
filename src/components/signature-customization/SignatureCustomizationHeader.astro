---
import Eyebrow from "../primitives/Eyebrow.astro";
---

<header class="signature-header">
  <Eyebrow>The Rangbastra Difference</Eyebrow>

  <h2>
    <span class="title-intro">Couture Isn't Chosen</span>
    <span class="title-statement title-highlight">It Is Recognized</span>
  </h2>

  <p>
    We do not begin with inventory. We begin with the woman, the moment and the
    memory the garment must hold.
  </p>
</header>

<style>
  .signature-header {
    display: grid;
    gap: var(--editorial-header-gap);
    max-width: min(100%, 62rem);
  }

  h2 {
    display: grid;
    gap: var(--editorial-title-gap);
    max-width: min(100%, 54rem);
    color: var(--text-primary);
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    text-wrap: balance;
  }

  .title-intro {
    color: var(--text-primary);
    font-size: var(--section-heading-intro);
    letter-spacing: var(--tracking-heading);
    line-height: 1.18;
    white-space: nowrap;
  }

  .title-statement {
    background: var(--gradient-primary);
    background-size: 220% 100%;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    font-size: var(--section-heading-statement);
    letter-spacing: var(--tracking-heading);
    line-height: 1.12;
    padding-bottom: 0.08em;
    white-space: nowrap;
    animation: signature-cocoa-drift 12s ease-in-out infinite alternate;
  }

  p {
    max-width: min(100%, 62ch);
    color: var(--text-secondary);
    font-size: var(--body-lg);
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  @keyframes signature-cocoa-drift {
    to {
      background-position: 100% 50%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .title-statement {
      animation: none;
    }
  }

  @media (max-width: 767px) {
    .signature-header {
      gap: var(--space-4);
    }

    .title-intro {
      font-size: var(--section-heading-intro-mobile);
    }

    .title-statement {
      font-size: var(--section-heading-statement-mobile);
    }

    p {
      font-size: var(--body-md);
    }
  }
</style>
