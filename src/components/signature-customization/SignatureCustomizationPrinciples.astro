---
import { signaturePrinciples } from "../../data/signatureCustomization";
import SignatureCustomizationPrinciple from "./SignatureCustomizationPrinciple.astro";
---

<div class="principles" aria-label="Rangbastra couture principles">
  {
    signaturePrinciples.map((principle) => (
      <SignatureCustomizationPrinciple
        index={principle.id}
        title={principle.title}
        statement={principle.statement}
        icon={principle.icon}
      />
    ))
  }
</div>

<style>
  .principles {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: clamp(var(--space-4), 2vw, var(--space-6));
    row-gap: clamp(var(--space-4), 2vw, var(--space-6));
    column-gap: clamp(var(--space-4), 2vw, var(--space-6));
    align-items: stretch;
  }

  .principles :global(.principle:nth-child(1)) {
    grid-column: 1 / span 5;
  }

  .principles :global(.principle:nth-child(2)) {
    grid-column: 6 / span 7;
    margin-top: var(--space-6);
  }

  .principles :global(.principle:nth-child(3)) {
    grid-column: 2 / span 6;
    margin-top: calc(var(--space-6) * -1);
  }

  .principles :global(.principle:nth-child(4)) {
    grid-column: 8 / span 5;
    margin-top: var(--space-6);
  }

  @media (max-width: 1023px) {
    .principles {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-5);
    }

    .principles :global(.principle:nth-child(1)),
    .principles :global(.principle:nth-child(2)),
    .principles :global(.principle:nth-child(3)),
    .principles :global(.principle:nth-child(4)) {
      grid-column: auto;
      margin-top: 0;
    }
  }

  @media (max-width: 767px) {
    .principles {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
</style>
