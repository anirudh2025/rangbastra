---
import Button from "../primitives/Button.astro";
import Label from "../primitives/Label.astro";
import Eyebrow from "../primitives/Eyebrow.astro";
import { customCoutureImages } from "../../data/customCouture";
---

<section class="custom-hero" aria-labelledby="custom-couture-heading">
  <figure class="hero-image">
    <img
      src={customCoutureImages.hero}
      alt="Rangbastra custom couture created for a private celebration"
      width="1200"
      height="1500"
      loading="eager"
      decoding="async"
    />
  </figure>

  <div class="hero-copy">
    <Eyebrow>Custom Couture</Eyebrow>

    <h1 id="custom-couture-heading">
      <span class="title-intro">Your Story,</span>
      <span class="title-statement">Made Couture</span>
    </h1>

    <p>
      Enter a slower, more personal way of creating bridal and occasion wear,
      where every silhouette begins with the woman who will wear it.
    </p>

    <div class="hero-actions" aria-label="Custom couture actions">
      <Button href="/design-your-outfit" class="custom-hero-primary">
        <Label icon="sparkle">Begin Your Custom Journey</Label>
      </Button>

      <Button href="#couture-journey" class="custom-hero-secondary">
        <Label icon="customCouture">View Couture Experiences</Label>
      </Button>
    </div>
  </div>
</section>

<style>
  .custom-hero {
    display: grid;
    grid-template-columns: minmax(0, .9fr) minmax(22rem, .7fr);
    gap: clamp(var(--space-7), 7vw, var(--space-12));
    align-items: center;
    min-height: min(54rem, calc(100svh - var(--navbar-height)));
    padding-top: clamp(var(--space-11), 12vw, var(--space-13));
  }

  .hero-image {
    position: relative;
    overflow: hidden;
    min-height: clamp(34rem, 58vw, 48rem);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    background: var(--surface-raised);
    box-shadow: var(--shadow-premium), var(--shadow-inset);
  }

  .hero-image::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, .04), rgba(0, 0, 0, .56)),
      var(--gradient-glass);
    opacity: .72;
  }

  img {
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
  }

  .hero-copy {
    display: grid;
    gap: clamp(var(--space-4), 3vw, var(--space-6));
    max-width: 39rem;
  }

  h1 {
    display: grid;
    gap: var(--space-2);
    color: var(--text-primary);
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    letter-spacing: var(--tracking-heading);
    line-height: var(--leading-heading);
    text-wrap: balance;
  }

  .title-intro {
    color: var(--text-primary);
    font-size: clamp(2.35rem, 4vw, 5rem);
    line-height: 1.08;
  }

  .title-statement {
    background: var(--gradient-brand-text);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    font-size: clamp(3.15rem, 6.7vw, 7.85rem);
    font-weight: var(--weight-medium);
    line-height: .94;
    padding-bottom: .08em;
  }

  p {
    max-width: var(--measure-sm);
    color: var(--text-secondary);
    font-size: clamp(var(--body-md), 1.4vw, var(--body-lg));
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-top: var(--space-2);
  }

  :global(.custom-hero-primary),
  :global(.custom-hero-secondary) {
    min-height: var(--button-height);
    box-shadow: var(--glow-soft), var(--shadow-inset);
  }

  :global(.custom-hero-primary) {
    background: var(--gradient-primary);
  }

  :global(.custom-hero-primary:hover),
  :global(.custom-hero-primary:focus-visible) {
    background: var(--button-primary-gradient-hover);
    box-shadow: var(--glow-medium), var(--button-shadow-hover), var(--shadow-inset-strong);
  }

  :global(.custom-hero-secondary) {
    border: 1px solid var(--border-default);
    background: rgba(255, 255, 255, .025);
    color: var(--text-secondary);
  }

  :global(.custom-hero-secondary:hover),
  :global(.custom-hero-secondary:focus-visible) {
    border-color: var(--border-strong);
    background: rgba(255, 255, 255, .045);
    color: var(--text-primary);
  }

  @media (max-width: 1023px) {
    .custom-hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-copy {
      max-width: 48rem;
    }
  }

  @media (max-width: 640px) {
    .custom-hero {
      gap: var(--space-7);
      padding-top: clamp(var(--space-10), 28vw, var(--space-12));
    }

    .hero-image {
      min-height: clamp(20rem, 82vw, 28rem);
      border-radius: var(--radius-lg);
    }

    .title-intro {
      font-size: clamp(2.15rem, 10vw, 3.1rem);
    }

    .title-statement {
      font-size: clamp(3rem, 17vw, 4.7rem);
    }

    .hero-actions,
    :global(.custom-hero-primary),
    :global(.custom-hero-secondary) {
      width: 100%;
    }
  }
</style>
