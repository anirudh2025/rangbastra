---
import Icon from "../primitives/Icon.astro";
import DesignYourOutfitHeader from "./DesignYourOutfitHeader.astro";
import { availabilityPromises } from "../../data/designYourOutfit";
---

<section class="promise-section" aria-labelledby="promise-heading">
  <DesignYourOutfitHeader
    eyebrow="Availability Promise"
    intro="Handled Privately"
    statement="Answered With Care"
    copy="Every message is treated as the beginning of a personal couture relationship."
  />

  <div class="promise-grid">
    {
      availabilityPromises.map((promise) => (
        <article class="promise-card">
          <Icon name={promise.icon} size={24} class="promise-icon" />
          <h3>{promise.title}</h3>
          <p>{promise.text}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .promise-section {
    display: grid;
    gap: clamp(var(--space-7), 7vw, var(--space-10));
  }

  .promise-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .promise-card {
    display: grid;
    gap: var(--space-3);
    min-height: 13.5rem;
    padding: clamp(var(--space-5), 3vw, var(--space-6));
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at 12% 0%, rgba(181, 147, 130, .08), transparent 48%),
      rgba(255, 255, 255, .018);
    box-shadow: var(--shadow-inset);
  }

  .promise-card :global(.promise-icon) {
    color: var(--sand-200);
    opacity: .78;
  }

  h3 {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 2.6vw, 2.6rem);
    font-weight: var(--weight-light);
    line-height: var(--leading-title);
    text-wrap: balance;
  }

  p {
    color: var(--text-secondary);
    font-size: var(--body-sm);
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  @media (max-width: 900px) {
    .promise-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .promise-grid {
      grid-template-columns: 1fr;
    }

    .promise-card {
      min-height: auto;
    }
  }
</style>
