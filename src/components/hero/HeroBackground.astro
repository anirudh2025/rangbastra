<div class="hero-background">

    <div class="ambient ambient-left"></div>

    <div class="ambient ambient-right"></div>

    <div class="spotlight"></div>

    <div class="noise"></div>

    <div class="vignette"></div>

</div>

<style>

.hero-background{

    position:absolute;

    inset:0;

    overflow:hidden;

    z-index:-3;

    pointer-events:none;

    background:#050505;

}

/* ==========================================
   LEFT AMBIENT LIGHT
========================================== */

.ambient{

    position:absolute;

    border-radius:50%;

    filter:blur(140px);

    opacity:.22;

}

.ambient-left{

    width:760px;

    height:760px;

    left:-260px;

    top:-180px;

    background:

        radial-gradient(

            circle,

            rgba(106,78,66,.45),

            rgba(106,78,66,.18),

            transparent 72%

        );

}

/* ==========================================
   RIGHT AMBIENT LIGHT
========================================== */

.ambient-right{

    width:900px;

    height:900px;

    right:-340px;

    bottom:-320px;

    background:

        radial-gradient(

            circle,

            rgba(125,96,82,.28),

            rgba(125,96,82,.10),

            transparent 74%

        );

}

/* ==========================================
   HERO SPOTLIGHT
========================================== */

.spotlight{

    position:absolute;

    inset:0;

    background:

        radial-gradient(

            circle at 58% 42%,

            rgba(255,255,255,.025),

            transparent 52%

        );

    mix-blend-mode:screen;

}

/* ==========================================
   FILM GRAIN
========================================== */

.noise{

    position:absolute;

    inset:0;

    opacity:.018;

    background-image:

        radial-gradient(circle,#ffffff 1px,transparent 1px);

    background-size:12px 12px;

}

/* ==========================================
   CINEMATIC VIGNETTE
========================================== */

.vignette{

    position:absolute;

    inset:0;

    background:

        radial-gradient(

            ellipse at center,

            transparent 42%,

            rgba(0,0,0,.16) 72%,

            rgba(0,0,0,.46) 100%

        );

}

@media(max-width:1024px){

.ambient-left{

    width:480px;

    height:480px;

    left:-180px;

    top:-120px;

}

.ambient-right{

    width:520px;

    height:520px;

    right:-220px;

    bottom:-180px;

}

.noise{

    opacity:.012;

}

}

</style>