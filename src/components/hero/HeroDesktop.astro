---
import HeroContent from "./HeroContent.astro";
---

<section
    class="hero-desktop"
    aria-labelledby="hero-heading"
>

    <div class="hero-artwork">


    <img
        class="hero-image"
        src="https://res.cloudinary.com/dfxlm7z58/image/upload/v1782614896/Hero_Desktop_klovjb.webp"
        alt="Luxury Couture by Rangbastra"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        draggable="false"
        width="4096"
        height="2731"
    />

</div>

    <div class="hero-overlay">

        <div class="hero-shell">

            <div class="hero-grid">

                <HeroContent />

            </div>

        </div>

    </div>

</section>

<style>
.hero-desktop{

    /* ==========================
       Layout Tokens
    ========================== */

    --hero-shell-width:min(100% - 12.5rem,1520px);

    --hero-content-width:clamp(40rem,48vw,52rem);

    --hero-content-offset:clamp(14rem,19vh,19rem);

    --hero-left:clamp(.5rem,1vw,1.25rem);

    position:relative;

    width:100%;

    overflow:hidden;

    isolation:isolate;

}

/* ========================================= */
/* Artwork */

.hero-artwork{

    display:block;

    width:100%;

    line-height:0;

}

.hero-image{

    display:block;

    width:100%;

    height:auto;

    user-select:none;

    pointer-events:none;

    -webkit-user-drag:none;

}

/* ========================================= */
/* Overlay */

.hero-overlay{

    position:absolute;

    inset:0;

    z-index:5;

}

/* ========================================= */

.hero-shell{

    width:var(--hero-shell-width);

    height:100%;

    margin-inline:auto;

}

/* ========================================= */

.hero-grid{

    display:grid;

    grid-template-columns:var(--hero-content-width);

    align-content:start;

    height:100%;

    padding-top:var(--hero-content-offset);

}

/* ========================================= */

.hero-grid > *{

    margin-left:var(--hero-left);

}

/* ========================================================= */
/* 1536+ */

@media (min-width:1536px){

.hero-desktop{

    --hero-content-width:52rem;

    --hero-content-offset:clamp(20rem,24vh,30rem);

}

}

/* ========================================================= */
/* Laptop */

@media (max-width:1440px){

.hero-desktop{

    --hero-shell-width:min(100% - 10rem,1320px);

    --hero-content-offset:clamp(19rem,23vh,29.5rem);

}

}

/* ========================================================= */
/* 1366 */

@media (max-width:1366px){

.hero-desktop{

    --hero-shell-width:min(100% - 8rem,1240px);
  
    --hero-content-offset:clamp(19rem,24vh,29rem);

}

}

/* ========================================================= */
/* Short Screens (IMPORTANT) */

@media (max-height:900px){dfbdvbdfg

.hero-desktop{

    --hero-content-offset:clamp(15.5rem,23vh,28rem);

}

}

/* ========================================================= */

@media (max-height:820px){

.hero-desktop{

    --hero-content-offset:clamp(13.5rem,18vh,18.15rem);

}

}

/* ========================================================= */

@media (max-height:760px){

.hero-desktop{

    --hero-content-offset:12.5rem;

}

}

/* ========================================================= */
/* Tablet */

@media (max-width:1024px){

.hero-desktop{

    display:none;

}

}
</style>
