---
import HeroActions from "./HeroActions.astro";
---

<div class="hero-content">

    <span class="hero-eyebrow">

        Luxury Custom Couture / Anand, Gujarat

    </span>

    <h1
        id="hero-heading"
        class="hero-title"
    >

        <span class="title-line">

            Where Every Thread

        </span>

        <span class="title-line title-highlight">

            Becomes Your Signature.

        </span>

    </h1>

    <p class="hero-description">

        Handcrafted couture designed exclusively for you.
        From bridal masterpieces to occasion wear,
        every creation begins with your story.

    </p>

    <HeroActions />

</div>

<style>

.hero-content{

    --hero-content-measure:48rem;

    position:relative;

    z-index:5;

    display:flex;

    flex-direction:column;

    align-items:flex-start;

    justify-content:flex-start;

    width:min(100%,var(--hero-content-measure));

    gap:clamp(1rem,1.35vw,1.65rem);

}

/* ====================================================== */
/* EYEBROW */

.hero-eyebrow{

    display:inline-flex;

    align-items:center;

    gap:1rem;

    max-width:100%;

    color:var(--cocoa-500);

    font-size:clamp(.72rem,.58vw,.86rem);

    font-weight:600;

    letter-spacing:.16em;

    line-height:1.2;

    text-transform:uppercase;

    white-space:nowrap;

}

.hero-eyebrow::before,
.hero-eyebrow::after{

    content:"";

    width:clamp(26px,2.2vw,52px);

    height:1px;

}

.hero-eyebrow::before{

    background:linear-gradient(
        90deg,
        transparent,
        var(--cocoa-500)
    );

}

.hero-eyebrow::after{

    background:linear-gradient(
        90deg,
        var(--cocoa-500),
        transparent
    );

}

/* ====================================================== */
/* TITLE */

.hero-title{

    margin:0;

    max-width:20ch;

    overflow:visible;

    color:var(--text-primary);

    font-family:var(--font-display);

    font-size:clamp(3.05rem,4.55vw,6.15rem);

    font-weight:500;

    letter-spacing:-2.4;

    line-height:1.15;

    text-wrap:balance;

}

.title-line{

    display:block;

    white-space:nowrap;

}

.title-highlight{

    background:var(--gradient-brand-text);

    -webkit-background-clip:text;

    background-clip:text;

    -webkit-text-fill-color:transparent;

    color:transparent;

}

/* ====================================================== */
/* DESCRIPTION */

.hero-description{

    max-width:34rem;

    margin-block:.35rem .55rem;

    color:var(--text-secondary);

    font-size:clamp(.98rem,.9vw,1.12rem);

    line-height:1.68;

    text-wrap:pretty;

}

/* ====================================================== */

@media (max-width:1600px){

.hero-title{

    font-size:clamp(2.95rem,4.35vw,5.6rem);

}

}

/* ====================================================== */

@media (max-width:1366px){

.hero-content{

    --hero-content-measure:46rem;

    gap:1.15rem;

}

.hero-title{

    max-width:20ch;

    font-size:clamp(2.75rem,4vw,4.85rem);

}

.hero-description{

    max-width:32rem;

    font-size:1rem;

}

}

/* ====================================================== */
/* Short screens */

@media (max-height:850px){

.hero-content{

    gap:1rem;

}

.hero-title{

    font-size:clamp(2.65rem,4.35vw,5.1rem);

}

.hero-description{

    max-width:35rem;

    font-size:.96rem;

    line-height:1.6;

}

}

/* ====================================================== */

@media (max-width:1024px){

.hero-content{

    --hero-content-measure:100%;

    width:100%;

    gap:.95rem;

}

.hero-eyebrow{

    gap:.55rem;

    font-size:.62rem;

    letter-spacing:.13em;

}

.hero-eyebrow::before{

    width:22px;

}

.hero-eyebrow::after{

    width:18px;

}

.hero-title{

    max-width:100%;

    font-size:clamp(2.05rem,7.45vw,3.75rem);

    line-height:1.12;

}

.hero-description{

    max-width:34rem;

    margin-block:.15rem .35rem;

    font-size:.95rem;

    line-height:1.62;

}

}

/* ====================================================== */

@media (max-width:640px){

.hero-content{

    align-items:center;

    gap:.85rem;

    text-align:center;

}

.hero-eyebrow{

    justify-content:center;

    font-size:.56rem;

    letter-spacing:.11em;

}

.hero-eyebrow::before,
.hero-eyebrow::after{

    display:none;

}

.hero-title{

    font-size:clamp(1.95rem,8.2vw,2.85rem);

    line-height:1.14;

}

.hero-description{

    max-width:28rem;

    font-size:.9rem;

    line-height:1.58;

}

}

@media (max-width:380px){

.hero-title{

    font-size:clamp(1.82rem,7.9vw,2.2rem);

}

.hero-description{

    font-size:.84rem;

}

}

</style>
