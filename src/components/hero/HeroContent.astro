---
import HeroActions from "./HeroActions.astro";
---

<div class="hero-content">

    <span class="hero-eyebrow">

        Luxury Custom Couture • Anand, Gujarat

    </span>

    <h1
        id="hero-heading"
        class="hero-title"
    >

        Where Every Thread

        <span class="title-highlight">

            Becomes Your Signature.

        </span>

    </h1>

    <p class="hero-description">

        Handcrafted couture designed exclusively for you.
        From bridal masterpieces to occasion wear,
        every creation begins with your story.

    </p>

    <HeroActions />

</div>

<style>

.hero-content{

    display:flex;

    flex-direction:column;

    align-items:flex-start;

    justify-content:flex-start;

    width:min(100%,44rem);

    gap:clamp(1.4rem,1.8vw,2.4rem);

    position:relative;

    z-index:5;

}

/* ====================================================== */
/* EYEBROW */

.hero-eyebrow{

    display:inline-flex;

    align-items:center;

    gap:1rem;

    font-size:clamp(.72rem,.55vw,.9rem);

    font-weight:600;

    letter-spacing:.18em;

    text-transform:uppercase;

    color:var(--accent-light);

    opacity:.98;

    white-space:nowrap;

}

.hero-eyebrow::before{

    content:"";

    width:clamp(34px,2.5vw,56px);

    height:1px;

    background:linear-gradient(

        90deg,

        transparent,

        var(--accent-light)

    );

}

.hero-eyebrow::after{

    content:"";

    width:clamp(26px,2vw,44px);

    height:1px;

    background:linear-gradient(

        90deg,

        var(--accent-light),

        transparent

    );

}

/* ====================================================== */
/* TITLE */

.hero-title{

    margin:0;

    max-width:18.5ch;

    font-family:var(--font-display);

    font-weight:600;

    font-size:clamp(3rem,4.8vw,6.3rem);

    line-height:1.15;

    letter-spacing:-.045em;

    color:var(--text-primary);

    text-wrap:balance;

}

.title-highlight{

    display:inline-block;

    background:linear-gradient(

        135deg,

        var(--ivory-50),

        var(--sand-300),

        var(--cocoa-500)

    );

    -webkit-background-clip:text;

    background-clip:text;

    -webkit-text-fill-color:transparent;

    color:transparent;

}

/* ====================================================== */
/* DESCRIPTION */

.hero-description{

    margin-top:1rem;

    margin-bottom:1.5rem;

    max-width:36rem;

    font-size:clamp(1rem,.95vw,1.18rem);

    line-height:1.75;

    color:var(--text-secondary);

    text-wrap:pretty;

}

/* ====================================================== */

@media (max-width:1600px){

.hero-title{

    font-size:clamp(2.8rem,4.6vw,5.6rem);

}

}

/* ====================================================== */

@media (max-width:1366px){

.hero-content{

    gap:1.35rem;

}

.hero-title{

    max-width:11ch;

    font-size:clamp(2.6rem,4.2vw,5rem);

}

.hero-description{

    max-width:28rem;

    font-size:1rem;

}

}

/* ====================================================== */
/* IMPORTANT */
/* This fixes laptops with low HEIGHT */

@media (max-height:850px){

.hero-content{

    gap:1.15rem;

}

.hero-title{

    font-size:clamp(2.5rem,5vw,5.6rem);

}

.hero-description{

    font-size:.98rem;

    line-height:1.75;

    max-width:35rem;

}

}

/* ====================================================== */

@media (max-width:1024px){

.hero-content{

    width:100%;

    gap:1.4rem;

}

.hero-eyebrow{

    font-size:.55rem;

    letter-spacing:.18em;

}

.hero-eyebrow::before{

    width:28px;

}

.hero-eyebrow::after{

    width:22px;

}

.hero-title{

    max-width:188ch;

    font-size:clamp(2.4rem,8vw,3.8rem);

    line-height:1.15;

    letter-spacing:-.03em;

}

.hero-description{

    max-width:100%;

    font-size:.95rem;

    line-height:1.7;

}

}

</style>