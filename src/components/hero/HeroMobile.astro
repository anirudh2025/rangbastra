---
import HeroContent from "./HeroContent.astro";

const mobileHero =
"https://res.cloudinary.com/dfxlm7z58/image/upload/v1782619685/Hero_Mobile_yt2m8f.webp";
---

<section
    class="hero-mobile"
    aria-labelledby="hero-heading"
>

    <picture class="hero-artwork">

        <img
            class="hero-image"
            src={mobileHero}
            alt="Luxury Couture by Rangbastra"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            draggable="false"
            width="1080"
            height="1920"
        />

    </picture>

    <div class="hero-overlay">

        <div class="hero-shell">

            <HeroContent />

        </div>

    </div>

</section>

<style>

.hero-mobile{

    display:none;

}

@media (max-width:1024px){

.hero-mobile{

    position:relative;

    display:block;

    overflow:hidden;

    isolation:isolate;

}

.hero-artwork{

    display:block;

    width:100%;

    line-height:0;

}

.hero-image{

    display:block;

    width:100%;

    height:auto;

    user-select:none;

    pointer-events:none;

    -webkit-user-drag:none;

}

.hero-overlay{

    position:absolute;

    inset:0;

    z-index:5;

}

.hero-shell{

    width:min(100% - 2rem,44rem);

    margin-inline:auto;

    padding-top:clamp(15.5rem,14vh,16.25rem);

}

}

@media (max-width:768px){

.hero-shell{

    width:min(100% - 2rem,32rem);

    padding-top:clamp(9.25rem,13vh,12.5rem);

}

}

@media (max-width:640px){

.hero-shell{

    width:min(100% - 1.5rem,28rem);

    padding-top:clamp(9.75rem,15vh,12rem);

}

}

@media (max-width:380px){

.hero-shell{

    width:min(100% - 1.25rem,24rem);

    padding-top:8.75rem;

}

}

/* Mobile overrides: keep the signature headline balanced without forced word breaks. */
:global(.hero-shell .title-line),
:global(.hero-shell .title-highlight) {
    display:block;
    max-width:100%;
    white-space:normal;
    overflow-wrap:normal;
    word-break:normal;
    text-wrap:balance;
}

@media (max-width:640px){
    :global(.hero-shell .title-line){
        font-size:clamp(1.2rem,5vw,2rem);
        line-height:1.12;
    }

    :global(.hero-shell .title-highlight){
        font-size:clamp(1.85rem,7.6vw,2.45rem);
    }
}

@media (max-width:380px){
    :global(.hero-shell .title-line),
    :global(.hero-shell .title-highlight){
        font-size:clamp(1.55rem,7.25vw,1.95rem);
    }
}
</style>
