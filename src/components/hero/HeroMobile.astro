---
import HeroContent from "./HeroContent.astro";

const mobileHero =
"https://res.cloudinary.com/dfxlm7z58/image/upload/v1782619685/Hero_Mobile_yt2m8f.webp";
---

<section
    class="hero-mobile"
    aria-labelledby="hero-heading"
>

    <picture class="hero-artwork">

        <img
            class="hero-image"
            src={mobileHero}
            alt="Luxury Couture by Rangbastra"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            draggable="false"
            width="1080"
            height="1920"
        />

    </picture>

    <div class="hero-overlay">

        <div class="hero-shell">

            <HeroContent />

        </div>

    </div>

</section>

<style>

.hero-mobile{

    display:none;

}

@media (max-width:1024px){

.hero-mobile{

    position:relative;

    display:block;

    overflow:hidden;

    isolation:isolate;

}

.hero-artwork{

    display:block;

    width:100%;

    line-height:0;

}

.hero-image{

    display:block;

    width:100%;

    height:auto;

    user-select:none;

    pointer-events:none;

    -webkit-user-drag:none;

}

.hero-overlay{

    position:absolute;

    inset:0;

    z-index:5;

}

.hero-shell{

    width:min(100% - 2rem,44rem);

    margin-inline:auto;

    padding-top:clamp(16.25rem,14vh,10.5rem);

}

}

@media (max-width:768px){

.hero-shell{

    width:min(100% - 2rem,32rem);

    padding-top:clamp(12.5rem,13vh,9.25rem);

}

}

@media (max-width:640px){

.hero-shell{

    width:min(100% - 1.5rem,28rem);

    padding-top:clamp(11.25rem,15vh,15.25rem);

}

}

@media (max-width:380px){

.hero-shell{

    width:min(100% - 1.25rem,24rem);

    padding-top:9.85rem;

}

}

/* Mobile overrides: allow signature title to wrap and scale down so it doesn't overflow */
.hero-shell .title-line,
.hero-shell .title-highlight {
        white-space: normal;
        display: block;
        overflow-wrap: anywhere;
        word-break: break-word;
        hyphens: auto;
        max-width: 100%;
}

@media (max-width:640px){
    .hero-shell .title-line{
        font-size: clamp(.6rem,5vw,1.2rem);
        line-height: 1.12;
    }

    .hero-shell .title-highlight{
        font-size: clamp(.6rem,4.5vw,1.4rem);
    }
}

@media (max-width:380px){
    .hero-shell .title-line,
    .hero-shell .title-highlight{
        font-size: clamp(1.4rem,7.5vw,1.9rem);
    }
}
</style>
