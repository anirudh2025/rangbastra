---
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";
---

<div class="hero-actions">

    <Button
        href="/design-your-outfit"
        class="hero-primary"
    >

        Design Your Outfit

    </Button>

    <a
        href="/collections"
        class="hero-secondary"
    >

        <span class="hero-secondary-icon">

            <Icon name="sparkle" size={16} />

        </span>

        <span>

            Explore Collections

        </span>

    </a>

</div>

<style>

:global(.hero-primary){

    position:relative;

    isolation:isolate;

}

:global(.hero-primary:hover),
:global(.hero-primary:focus-visible){

    background:var(--button-primary-background-hover);

}

.hero-actions{

    display:flex;

    align-items:center;

    gap:clamp(.8rem,1.05vw,1.5rem);

    flex-wrap:wrap;

}

.hero-secondary{

    display:inline-flex;

    align-items:center;

    gap:.65rem;

    color:var(--text-secondary);

    font-size:1rem;

    font-weight:600;

    text-decoration:none;

    transition:
        color .35s var(--ease-luxury);

}

.hero-secondary:hover{

    color:var(--text-primary);

}

.hero-secondary-icon{

    display:flex;

    align-items:center;

    justify-content:center;

    width:1rem;

    height:1rem;

    opacity:0;

    transform:
        translateX(-8px)
        scale(.75)
        rotate(-18deg);

    transition:
        opacity .35s var(--ease-luxury),
        transform .45s var(--ease-luxury);

}

.hero-secondary:hover .hero-secondary-icon{

    opacity:1;

    transform:
        translateX(0)
        scale(1)
        rotate(0deg);

}

.hero-secondary-icon :global(svg){

    width:100%;

    height:100%;

}

@media (max-width:640px){

.hero-actions{

    flex-direction:column;

    justify-content:center;

    width:100%;

    gap:var(--space-3);

}

:global(.hero-primary){

    min-height:46px;

    padding-inline:1.35rem;

}

.hero-secondary{

    font-size:.9rem;

}

}

@media (max-width:380px){

.hero-actions{

    flex-direction:column;

    align-items:center;

}

:global(.hero-primary){

    width:min(100%,17rem);

}

}

</style>
