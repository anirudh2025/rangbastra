---
import Button from "../primitives/Button.astro";
import Sparkles from "../icons/journey/Sparkles.astro";
---

<div class="hero-actions">

    <Button
    href="/consultation"
    class="hero-primary"
>

    Book Consultation

</Button>

    <a
        href="/collections"
        class="hero-secondary"
    >

        <span class="hero-secondary-icon">

            <Sparkles />

        </span>

        <span>

            Explore Collections

        </span>

    </a>

</div>

<style>


.hero-primary{

    position:relative;

    isolation:isolate;

}

/* ====================================== */

.hero-primary::after{

    content:"";

    position:absolute;

    inset:-8px;

    border:1px solid rgba(148,115,100,.55);

    border-radius:calc(var(--button-radius) + 8px);

    opacity:0;

    transform:scale(.96);

    transition:

        opacity .35s var(--ease-luxury),

        transform .35s var(--ease-luxury);

}

/* ====================================== */

.hero-primary:hover::after{

    opacity:1;

    transform:scale(1);

}

.hero-actions{

    display:flex;

    align-items:center;

    gap:clamp(1rem,1.2vw,1.75rem);

    flex-wrap:wrap;

}

/* ====================================== */

.hero-secondary{

    display:inline-flex;

    align-items:center;

    gap:.65rem;

    text-decoration:none;

    color:var(--text-secondary);

    font-size:1rem;

    font-weight:600;

    transition:

        color .35s var(--ease-luxury);

}

/* ====================================== */

.hero-secondary:hover{

    color:var(--text-primary);

}

/* ====================================== */

.hero-secondary-icon{

    display:flex;

    align-items:center;

    justify-content:center;

    width:1rem;

    height:1rem;

    opacity:0;

    transform:

        translateX(-8px)

        scale(.75)

        rotate(-18deg);

    transition:

        opacity .35s var(--ease-luxury),

        transform .45s var(--ease-luxury);

}

.hero-secondary:hover .hero-secondary-icon{

    opacity:1;

    transform:

        translateX(0)

        scale(1)

        rotate(0deg);

}

/* ====================================== */

.hero-secondary-icon :global(svg){

    width:100%;

    height:100%;

}

</style>