---
import Eyebrow from "../primitives/Eyebrow.astro";
---

<header class="craftsmanship-header">
  <Eyebrow>Craftsmanship</Eyebrow>

  <h2>
    <span class="title-intro">Made With The</span>
    <span class="title-statement title-highlight">Patience Of Couture</span>
  </h2>

  <p>
    Rangbastra pieces are shaped through material intelligence, hand-finished
    detail and a fitting process designed around the individual.
  </p>
</header>

<style>
  .craftsmanship-header {
    display: grid;
    gap:var(--editorial-header-gap);
    max-width: var(--measure-md);
  }

  h2 {
    display: grid;
    gap:var(--editorial-title-gap);
    max-width: min(100%, 54rem);
    color: var(--text-primary);
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    text-wrap: balance;
  }

  .title-intro {
    color: var(--text-primary);
    font-size: var(--section-heading-intro);
    letter-spacing: var(--tracking-heading);
    line-height: 1.18;
    white-space: nowrap;
  }

  .title-statement {
    background: var(--gradient-brand-text);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    font-size: clamp(2.65rem,5.2vw,5.8rem);
    letter-spacing: var(--tracking-heading);
    line-height: 1.12;
    padding-bottom: .08em;
    white-space: nowrap;
  }

  p {
    max-width: var(--measure-md);
    color: var(--text-secondary);
    font-size: var(--body-md);
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  @media (max-width: 767px) {
    .craftsmanship-header {
      gap: var(--space-4);
    }

    .title-intro {
      font-size: var(--section-heading-intro-mobile);
    }

    .title-statement {
      font-size: var(--section-heading-statement-mobile);
    }
  }
</style>
