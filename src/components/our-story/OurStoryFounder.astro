---
import OurStoryHeader from "./OurStoryHeader.astro";
import Icon from "../primitives/Icon.astro";
import { ourStoryImages } from "../../data/ourStory";
---

<section class="founder-section" id="founder" aria-labelledby="founder-heading">
  <figure style={`--story-image: url("${ourStoryImages.founder}")`}>
    <img
      src={ourStoryImages.founder}
      alt="Founder-led Rangbastra craft and design attention"
      width="900"
      height="1200"
      loading="eager"
      decoding="async"
    />
  </figure>

  <div class="founder-copy">
    <OurStoryHeader
      eyebrow="Meet The Founder"
      intro="Bhagirathi Patel"
      statement="Designs By Listening"
      copy="For Bhagirathi, clothing is never separate from the person wearing it. The bride, the family memory, the ritual, the comfort and the feeling all matter before a design becomes final."
    />

    <div class="founder-note">
      <Icon name="signature" size={28} class="founder-icon" />
      <p>
        More than a decade of dedication has made her process quieter, not
        louder. She still works personally with brides because customization is
        not an added service at Rangbastra. It is the foundation.
      </p>
    </div>
  </div>
</section>

<style>
  .founder-section {
    display: grid;
    grid-template-columns: minmax(20rem, .48fr) minmax(0, .72fr);
    gap: clamp(var(--space-7), 7vw, var(--space-11));
    align-items: center;
  }

  figure {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    background:
      var(--story-image) center / cover no-repeat,
      var(--surface-raised);
    box-shadow: var(--shadow-premium), var(--shadow-inset);
  }

  figure::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: var(--gradient-glass);
    opacity: .6;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .founder-copy {
    display: grid;
    gap: clamp(var(--space-6), 5vw, var(--space-8));
  }

  .founder-note {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--space-4);
    max-width: 48rem;
    padding: clamp(var(--space-5), 4vw, var(--space-7));
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, .016);
    box-shadow: var(--shadow-inset);
  }

  .founder-note :global(.founder-icon) {
    color: var(--sand-200);
    opacity: .78;
    transform: translateY(.2rem);
  }

  p {
    color: var(--text-secondary);
    font-size: clamp(var(--body-md), 1.5vw, var(--body-lg));
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  @media (max-width: 900px) {
    .founder-section {
      grid-template-columns: 1fr;
    }

    figure {
      max-width: 34rem;
    }
  }

  @media (max-width: 560px) {
    .founder-note {
      grid-template-columns: 1fr;
    }

    figure {
      border-radius: var(--radius-lg);
    }
  }
</style>
