---
interface Props{
    size?: number;
    color?: string;
    class?: string;
    strokeWidth?: number;
}

const{
    size = 28,
    color = "currentColor",
    class: className = "",
    strokeWidth = 1.8
} = Astro.props;
---

<svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    width={size}
    height={size}
    fill="none"
    stroke={color}
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
>

    <rect
        x="3"
        y="3"
        width="18"
        height="18"
        rx="5"
    />

    <circle
        cx="12"
        cy="12"
        r="4"
    />

    <circle
        cx="17.5"
        cy="6.5"
        r=".5"
        fill={color}
        stroke="none"
    />

</svg>