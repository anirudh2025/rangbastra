---
interface Props{
    size?: number;
    color?: string;
    class?: string;
    strokeWidth?: number;
}

const{
    size = 28,
    color = "currentColor",
    class: className = "",
    strokeWidth = 1.8
} = Astro.props;
---

<svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    width={size}
    height={size}
    fill="none"
    stroke={color}
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
>

    <rect
        x="3"
        y="5"
        width="18"
        height="16"
        rx="3"
    />

    <path d="M8 3V7" />

    <path d="M16 3V7" />

    <path d="M3 10H21" />

    <path d="M8 14H8.01" />

    <path d="M12 14H12.01" />

    <path d="M16 14H16.01" />

    <path d="M8 18H8.01" />

    <path d="M12 18H12.01" />

</svg>