---
interface Props{
  size?: number;
  color?: string;
  class?: string;
  strokeWidth?: number;
}

const{
  size = 28,
  color = "currentColor",
  class: className = "",
  strokeWidth = 1.8
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <path d="M4.5 20.5h15"/>
  <path d="M6 20.5V9.8L12 4l6 5.8v10.7"/>
  <path d="M9 20.5v-7h6v7"/>
  <path d="M8 10.2h8"/>
  <path d="M12 4v3.8"/>
</svg>
