---
interface Props{
  size?: number;
  color?: string;
  class?: string;
  strokeWidth?: number;
}

const{
  size = 28,
  color = "currentColor",
  class: className = "",
  strokeWidth = 1.8
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>

  <rect
    x="8"
    y="3"
    width="8"
    height="18"
    rx="2"
  />

  <path d="M8 8h8"/>

  <path d="M12 8v10"/>

  <path d="M12 21c2-1 3-2.2 3-3.6 0-1.4-.9-2.4-3-3.4-2.1 1-3 2-3 3.4 0 1.4 1 2.6 3 3.6"/>

</svg>