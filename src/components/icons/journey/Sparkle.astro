---
interface Props{
  size?: number;
  color?: string;
  class?: string;
  strokeWidth?: number;
}

const{
  size = 28,
  color = "currentColor",
  class: className = "",
  strokeWidth = 1.8
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>

  <path d="M12 2l1.5 4.5L18 8l-4.5 1.5L12 14l-1.5-4.5L6 8l4.5-1.5L12 2z"/>

  <path d="M18.5 15l.8 2.2 2.2.8-2.2.8-.8 2.2-.8-2.2-2.2-.8 2.2-.8.8-2.2z"/>

  <path d="M5 15l.6 1.6 1.6.6-1.6.6-.6 1.6-.6-1.6-1.6-.6 1.6-.6L5 15z"/>

</svg>

<style>
  svg{filter:drop-shadow(0 0 5px rgba(181,147,130,.24));animation:rangbastra-sparkle-breathe 4.6s var(--ease-luxury) infinite;transform-origin:center;}
  @keyframes rangbastra-sparkle-breathe{0%,100%{opacity:.76;transform:scale(.97)}50%{opacity:1;transform:scale(1.02)}}
  @media(prefers-reduced-motion:reduce){svg{animation:none;opacity:.9;transform:none}}
</style>
