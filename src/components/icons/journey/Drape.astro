---
interface Props{
  size?: number;
  color?: string;
  class?: string;
  strokeWidth?: number;
}

const{
  size = 28,
  color = "currentColor",
  class: className = "",
  strokeWidth = 1.8
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <path d="M5 4.5c3 1.3 5.4 1.3 7 0 1.7-1.3 4-1.3 7 0"/>
  <path d="M5 4.5v15"/>
  <path d="M19 4.5v15"/>
  <path d="M5 19.5c3-1.5 5.4-1.5 7 0 1.7 1.5 4 1.5 7 0"/>
  <path d="M8.2 6.5v11"/>
  <path d="M12 5.4v13.2"/>
  <path d="M15.8 6.5v11"/>
</svg>
