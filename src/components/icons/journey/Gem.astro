---
interface Props{
  size?: number;
  color?: string;
  class?: string;
  strokeWidth?: number;
}

const{
  size = 28,
  color = "currentColor",
  class: className = "",
  strokeWidth = 1.8
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <path d="M6.5 4.5h11L21 9l-9 10.5L3 9l3.5-4.5z"/>
  <path d="M3 9h18"/>
  <path d="M8.2 9 12 19.5 15.8 9"/>
  <path d="M8.2 9 10 4.5"/>
  <path d="M15.8 9 14 4.5"/>
</svg>
