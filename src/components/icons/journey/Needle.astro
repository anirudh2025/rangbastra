---
interface Props{
  size?: number;
  color?: string;
  class?: string;
  strokeWidth?: number;
}

const{
  size = 28,
  color = "currentColor",
  class: className = "",
  strokeWidth = 1.8
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>

  <path d="M19 5L7 17"/>

  <path d="M16.8 2.8a2.2 2.2 0 1 1 3.1 3.1"/>

  <path d="M7 17l-3 5"/>

  <circle cx="18.4" cy="5.6" r=".7" fill={color} stroke="none"/>

</svg>