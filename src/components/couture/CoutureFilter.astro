---
import type { CoutureCategory } from "../../data/couture";
interface Props { categories: Array<"All" | CoutureCategory> }
const { categories } = Astro.props;
const normalize=(value:string)=>value.toLowerCase().replace(/\s+/g,"-");
---
<div class="collection-selector" data-collection-selector>
  <span class="collection-selector__label">Collection</span>
  <button class="collection-selector__trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
    <span>Viewing: <strong data-filter-label>All Products</strong></span>
    <svg viewBox="0 0 16 16" aria-hidden="true"><path d="m4 6 4 4 4-4"/></svg>
  </button>
  <div class="collection-selector__menu" role="listbox" aria-label="Choose a collection" hidden>
    {categories.map((category,index)=><button type="button" role="option" data-category={normalize(category)} aria-selected={index===0}>{category==="All"?"All Products":category}</button>)}
  </div>
  <button class="collection-selector__reset" type="button" data-filter-reset hidden>Clear · All Products</button>
</div>
<script>
  document.querySelectorAll<HTMLElement>("[data-collection-selector]").forEach(selector=>{
    const trigger=selector.querySelector<HTMLButtonElement>(".collection-selector__trigger")!,menu=selector.querySelector<HTMLElement>("[role=listbox]")!,label=selector.querySelector<HTMLElement>("[data-filter-label]")!,reset=selector.querySelector<HTMLButtonElement>("[data-filter-reset]")!,options=[...menu.querySelectorAll<HTMLButtonElement>("[role=option]")],catalog=selector.closest<HTMLElement>(".product-catalog")!,cards=[...catalog.querySelectorAll<HTMLElement>(".product-card")];
    const valid=new Set(options.map(option=>option.dataset.category!));
    const apply=(requested:string,push=true)=>{const category=valid.has(requested)?requested:"all";options.forEach(option=>option.setAttribute("aria-selected",String(option.dataset.category===category)));const active=options.find(option=>option.dataset.category===category)!;label.textContent=active.textContent?.trim()||"All Products";reset.hidden=category==="all";let count=0;cards.forEach(card=>{const show=category==="all"||card.dataset.categoryId===category;card.hidden=!show;if(show)count++});catalog.querySelector<HTMLElement>("[data-result-count]")!.textContent=`${count} couture ${count===1?"story":"stories"}`;catalog.querySelector<HTMLElement>("[data-empty-state]")!.hidden=count>0;if(push){const url=new URL(location.href);category==="all"?url.searchParams.delete("category"):url.searchParams.set("category",category);history.pushState({category},"",url)}};
    const open=()=>{menu.hidden=false;trigger.setAttribute("aria-expanded","true");options.find(option=>option.getAttribute("aria-selected")==="true")?.focus()};const close=()=>{menu.hidden=true;trigger.setAttribute("aria-expanded","false")};
    trigger.addEventListener("click",()=>menu.hidden?open():close());options.forEach(option=>option.addEventListener("click",()=>{apply(option.dataset.category!);close();trigger.focus()}));reset.addEventListener("click",()=>apply("all"));menu.addEventListener("keydown",event=>{const current=options.indexOf(document.activeElement as HTMLButtonElement);if(event.key==="Escape"){close();trigger.focus()}else if(event.key==="ArrowDown"||event.key==="ArrowUp"){event.preventDefault();options[(current+(event.key==="ArrowDown"?1:-1)+options.length)%options.length]?.focus()}});document.addEventListener("pointerdown",event=>{if(!selector.contains(event.target as Node))close()});addEventListener("popstate",()=>apply(new URLSearchParams(location.search).get("category")?.toLowerCase()||"all",false));apply(new URLSearchParams(location.search).get("category")?.toLowerCase()||"all",false);
  });
</script>
<style>
  .collection-selector{position:relative;z-index:var(--z-form-control);display:grid;width:min(100%,25rem);gap:var(--space-2)}.collection-selector__label{color:var(--text-muted);font-size:var(--caption);font-weight:var(--weight-semibold);letter-spacing:var(--tracking-label);text-transform:uppercase}.collection-selector__trigger{display:flex;align-items:center;justify-content:space-between;min-height:3.5rem;padding:0 var(--space-4);border:1px solid var(--cocoa-border);border-radius:var(--radius-md);background:rgba(5,5,5,.98);color:var(--text-secondary)}.collection-selector__trigger strong{color:var(--ivory-100)}.collection-selector__trigger svg{width:18px;fill:none;stroke:rgb(var(--cocoa-rgb));stroke-width:1.5;transition:transform var(--motion-fast)}.collection-selector__trigger[aria-expanded=true] svg{transform:rotate(180deg)}.collection-selector__menu{position:absolute;top:calc(100% - 1.6rem);inset-inline:0;z-index:var(--z-dropdown);padding:var(--space-2);border:1px solid var(--cocoa-border);border-radius:var(--radius-md);background:rgba(3,3,3,.98);box-shadow:0 24px 60px rgba(0,0,0,.65)}.collection-selector__menu button{display:block;width:100%;min-height:44px;padding:0 var(--space-3);border-radius:var(--radius-md);color:var(--text-secondary);text-align:left}.collection-selector__menu button:hover,.collection-selector__menu button:focus-visible{background:rgba(var(--cocoa-rgb),.18);color:var(--ivory-100)}.collection-selector__menu [aria-selected=true]{color:var(--cocoa-300)}.collection-selector__reset{justify-self:start;color:var(--cocoa-300);font-size:var(--caption)}.collection-selector__trigger:focus-visible,.collection-selector__reset:focus-visible{outline:2px solid var(--focus-ring);outline-offset:3px}
</style>
