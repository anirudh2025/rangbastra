---
import Button from "../primitives/Button.astro";
import Eyebrow from "../primitives/Eyebrow.astro";
import Icon from "../primitives/Icon.astro";
import WishlistButton from "../wishlist/WishlistButton.astro";
import type { CouturePiece } from "../../data/couture";
import { getWhatsAppHref } from "../../data/contact";
import CoutureProductGallery from "./CoutureProductGallery.astro";

interface Props {
  product: CouturePiece;
}

const { product } = Astro.props;
const inquiryHref = `/products/${product.slug}/customize`;
const whatsappHref = getWhatsAppHref(
  `Hello Rangbastra, I am interested in ${product.name} and would like to know more about customization.`,
);
const priceValue = product.priceLabel
  .replace(/^From\s+/i, "");
const hasRating =
  typeof product.rating === "number" && product.rating > 0 && product.rating <= 5 &&
  typeof product.reviewCount === "number" && product.reviewCount > 0;
---

<section class="product-detail-hero" aria-labelledby="product-title">
  <div class="hero-media">
    <WishlistButton slug={product.slug} name={product.name} />

    <CoutureProductGallery product={product} />

  </div>

  <div class="hero-summary" data-product-summary>
    <Eyebrow>{product.collection}</Eyebrow>

    <div class="hero-title-group">
      <h1 id="product-title">
        <span>{product.name}</span>
        <Icon name="sparkle" size={22} class="title-sparkle" />
      </h1>
    </div>

    <p class="hero-description">{product.shortDescription}</p>

    <div class="product-rating" aria-label={hasRating ? `${product.rating} out of 5 stars from ${product.reviewCount} reviews` : "Not yet rated"}>
        <span class="product-rating__stars" aria-hidden="true">
          {Array.from({ length: 5 }, (_, index) => (
            <svg viewBox="0 0 24 24" width="15" height="15"><path d="m12 3.8 2.45 4.96 5.48.8-3.97 3.86.94 5.46L12 16.3l-4.9 2.58.94-5.46-3.97-3.86 5.48-.8L12 3.8Z" fill={hasRating && index < Math.round(product.rating!) ? "currentColor" : "none"} stroke="currentColor" stroke-width="1.4" /></svg>
          ))}
        </span>
        {hasRating ? <><span>{product.rating?.toFixed(1)}</span><span class="product-rating__count">{product.reviewCount} reviews</span></> : <span class="product-rating__count">Not yet rated</span>}
      </div>

    <dl class="summary-list" aria-label={`${product.name} summary`}>
      <div class="price-note">
        <dt>Starting From</dt>
        <dd>{priceValue}</dd>
      </div>

      {
        product.makingTime && (
          <div>
            <dt>Making Time</dt>
            <dd>{product.makingTime}</dd>
          </div>
        )
      }

      <div>
        <dt>Palette</dt>
        <dd>{product.shade ?? product.colorFamily}</dd>
      </div>
    </dl>

    <div class="hero-actions" aria-label={`${product.name} actions`}>
      <Button href={inquiryHref} variant="brand-mesh">Start This Story</Button>
      <WishlistButton slug={product.slug} name={product.name} variant="inline" />
      <Button href={whatsappHref} target="_blank" variant="whatsapp">Ask On WhatsApp</Button>
      <a href="/collections" class="secondary-link">Return to Collections</a>
    </div>
  </div>
</section>

<style>
  .product-detail-hero {
    display: grid;
    grid-template-columns: minmax(340px, 40%) minmax(0, 1fr);
    column-gap: clamp(var(--space-6), 4vw, var(--space-10));
    align-items: start;
    min-height: min(48rem, calc(100svh - var(--navbar-height)));
    padding-top: calc(var(--navbar-height) + var(--navbar-fixed-gutter) + var(--product-page-top-gap) + env(safe-area-inset-top));
  }

  .hero-media {
    position: relative;
    min-width: 0;
  }

  .hero-summary {
    position: relative;
    display: grid;
    gap: clamp(var(--space-4), 3vw, var(--space-6));
    align-content: start;
    align-self: start;
    max-width: none;
  }

  .hero-title-group {
    display: grid;
    gap: var(--space-2);
  }

  .hero-title-group p,
  dt {
    color: var(--text-muted);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-caption);
    text-transform: uppercase;
  }

  h1 {
    display: inline-flex;
    align-items: center;
    gap: clamp(var(--space-2), 1vw, var(--space-3));
    color: var(--text-primary);
    font-family: var(--font-signature);
    font-size: clamp(3.35rem, 6.3vw, 7rem);
    font-weight: var(--weight-regular);
    letter-spacing: var(--tracking-heading);
    line-height: 1;
    overflow-wrap: anywhere;
    text-wrap: balance;
    text-shadow:0 0 7px var(--cocoa-glow-soft);
  }

  h1 :global(.title-sparkle) {
    flex: 0 0 auto;
    color:rgb(var(--cocoa-rgb));
    opacity: .78;
    transform: translateY(.08em);
  }

  .hero-description {
    max-width: 42rem;
    color: var(--text-secondary);
    font-size: clamp(var(--body-md), 1.55vw, var(--body-lg));
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  .product-rating { display: inline-flex; width: fit-content; align-items: center; gap: var(--space-2); color:rgb(var(--cocoa-rgb)); font-size: var(--body-sm); }
  .product-rating__stars { display: inline-flex; gap: .15rem; }
  .product-rating__count { color: var(--text-muted); }

  .summary-list {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) repeat(2, minmax(0, .9fr));
    gap: var(--space-4);
  }

  .summary-list div {
    display: grid;
    gap: var(--space-2);
    min-width: 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--border-subtle);
  }

  .summary-list .price-note {
    padding: var(--space-4);
    border:1px solid var(--cocoa-border-soft);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, .045), rgba(255, 255, 255, .012)),
      rgba(255, 255, 255, .02);
    box-shadow: none;
  }

  .price-note dt {
    color:rgb(var(--cocoa-rgb));
  }

  dd {
    color: var(--text-primary);
    font-size: var(--body-sm);
    line-height: var(--leading-body);
  }

  .price-note dd {
    width: fit-content;
    background:none;
    background-clip: text;
    -webkit-background-clip: text;
    color:var(--ivory-100);
    -webkit-text-fill-color:currentColor;
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 2.2vw, 2.35rem);
    font-weight: var(--weight-light);
    letter-spacing: var(--tracking-title);
    line-height: var(--leading-title);
    text-shadow:0 0 8px var(--cocoa-glow);
    border-bottom:1px solid var(--cocoa-border);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
  }
  .hero-actions .secondary-link{flex-basis:100%;width:fit-content;}

  .hero-actions :global(.button),
  .hero-actions :global(.wishlist-toggle) { box-shadow: none; }
  .hero-actions :global(.button:hover) { box-shadow: 0 10px 28px rgba(0, 0, 0, .14); transform: translate3d(0, -1px, 0); }
  .hero-actions :global(.button:focus-visible) { outline:1px solid var(--cocoa-border-strong);outline-offset:4px;box-shadow:none; }

  .secondary-link {
    position: relative;
    color: var(--text-secondary);
    font-size: var(--label-md);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    transition: color var(--motion-button) var(--ease-luxury);
  }

  .secondary-link::after { content:"";position:absolute;left:0;right:0;bottom:-.3rem;height:1px;background:rgb(var(--cocoa-rgb));transform:scaleX(0);transform-origin:left;transition:transform var(--duration-medium) var(--ease-premium); }
  .secondary-link:hover::after,.secondary-link:focus-visible::after { transform:scaleX(1); }

  .secondary-link:hover,
  .secondary-link:focus-visible {
    color: var(--text-primary);
  }

  .secondary-link:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: var(--space-2);
    border-radius: var(--radius-sm);
  }

  @media (max-width: 900px) {
    .product-detail-hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-summary {
      max-width: 44rem;
    }
  }

  @media (max-width: 640px) {
    .product-detail-hero {
      gap: var(--space-7);
      padding-top: calc(var(--navbar-height) + var(--navbar-fixed-gutter) + var(--product-page-top-gap) + env(safe-area-inset-top));
    }

    h1 {
      font-size: clamp(3.25rem, 16vw, 5rem);
    }

    .summary-list {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .hero-actions :global(.button),
    .secondary-link {
      width: 100%;
      justify-content: center;
      text-align: center;
    }
  }
</style>
