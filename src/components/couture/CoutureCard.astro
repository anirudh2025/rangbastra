---
import Label from "../primitives/Label.astro";
import Eyebrow from "../primitives/Eyebrow.astro";
import Icon from "../primitives/Icon.astro";
import WishlistButton from "../wishlist/WishlistButton.astro";
import type { CouturePiece } from "../../data/couture";
import {
  getCloudinaryImageUrl,
  getProductCoverImage,
  isConfirmedFourByFive,
} from "../../lib/couture";

interface Props {
  product: CouturePiece;
  index: number;
  animateEntrance?: boolean;
}

const { product, index, animateEntrance = false } = Astro.props;
const loading = index < 4 ? "eager" : "lazy";
const cover = getProductCoverImage(product);
const confirmedFourByFive = isConfirmedFourByFive(cover);
---

<article
  class:list={[
    "product-card",
    product.featured && "product-card--featured",
    animateEntrance && "product-card--staged",
  ]}
  data-category={product.category}
  data-category-id={product.collectionIds[0]}
  data-featured-stage={animateEntrance ? index + 1 : undefined}
  style={`--product-card-delay: ${Math.min(index, 8) * 150}ms;--product-shade:${product.shadeHex ?? product.color.hex ?? "#4B3731"}`}
>
  <WishlistButton slug={product.slug} name={product.name} />

  <a
    href={`/products/${product.slug}`}
    class="product-link"
    data-track="product_opened"
    data-product={product.slug}
    data-category={product.category}
  >
    <figure
      class="product-media"
      data-image-fit={confirmedFourByFive ? "cover" : "contain"}
    >
      <img
        src={getCloudinaryImageUrl(cover.src, 900)}
        alt={cover.alt}
        width={cover.width ?? 900}
        height={cover.height ?? 1125}
        loading={loading}
        decoding="async"
      />
    </figure>

    <div class="product-copy">
      <div class="product-kicker"><Eyebrow>{product.category}</Eyebrow></div>

      <h2>
        <span>{product.name}</span>
        <Icon name="sparkle" size={16} class="card-title-sparkle" />
      </h2>

      <p class="product-description">{product.shortDescription}</p>

      <div class="product-meta">
        <div class="product-price" aria-label={product.startingPrice ? `Starting at ${product.priceLabel}` : product.priceLabel}>
          {product.startingPrice && <span>Starting at</span>}
          <strong>{product.priceLabel}</strong>
        </div>
        <div class="product-palette" aria-label={`${product.name} colour palette`}>
          {product.paletteOptions.slice(0, 3).map((shade, shadeIndex) => (
            <span class="palette-choice" role="img" aria-label={`${shade.name}${shadeIndex === 0 ? ", selected" : ""}`}>
              <i class:list={[shadeIndex === 0 && "is-selected"]} style={`--swatch:${shade.value}`} aria-hidden="true"></i>
            </span>
          ))}
          <span class="palette-name">{product.colorFamily}</span>
        </div>
      </div>

      <ul class="craft-tags" aria-label={`${product.name} craft details`}>
        {product.craftTags.slice(0, 3).map((tag) => <li>{tag}</li>)}
      </ul>

      <span class="product-action">
        <Label icon="journal" iconPosition="right" iconSize={14}
          >Explore Piece</Label
        >
      </span>
    </div>
  </a>
</article>

<style>
  .product-card {
    --product-card-radius: var(--radius-xl);
    --product-card-image-ratio: 4 / 5;

    position: relative;

    opacity: 1;
    transform: none;
  }
  .product-card--staged {
    opacity: 0;
    transform: translateY(130px);
    transition:
      opacity 900ms cubic-bezier(0.22, 1, 0.36, 1) var(--product-card-delay),
      transform 1050ms cubic-bezier(0.22, 1, 0.36, 1) var(--product-card-delay);
  }
  .product-card--staged.is-settled {
    opacity: 1;
    transform: none;
  }

  .product-link {
    display: grid;
    gap: var(--space-5);
    height: 100%;
    color: inherit;
    text-decoration: none;
  }

  .product-media {
    position: relative;
    overflow: hidden;
    aspect-ratio: var(--product-card-image-ratio);
    border: 1px solid var(--border-default);
    border-radius: var(--product-card-radius);
    background: var(--surface-raised);
    box-shadow: var(--shadow-premium), var(--shadow-inset);
    transition:
      transform var(--motion-medium) var(--ease-luxury),
      border-color var(--motion-medium) var(--ease-luxury),
      box-shadow var(--motion-medium) var(--ease-luxury);
  }

  .product-media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }
  .product-media[data-image-fit="cover"] img {
    object-fit: cover;
  }

  .product-media::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, transparent 46%, rgba(0, 0, 0, 0.7)),
      var(--gradient-glass);
    opacity: 0.72;
    transition: opacity var(--motion-medium) var(--ease-luxury);
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1);
    transition: transform var(--motion-image) var(--ease-luxury);
  }

  .product-copy {
    display: grid;
    gap: var(--space-3);
    padding-inline: var(--space-1);
  }

  .product-kicker,
  .product-meta,
  .craft-tags {
    color: var(--text-muted);
    font-size: var(--caption);
    line-height: var(--leading-caption);
  }

  .product-kicker {
    display: flex;
  }
  .product-kicker :global(.eyebrow) {
    border: 1px solid rgba(var(--cocoa-rgb), 0.38);
    border-radius: var(--radius-2xs);
    background: rgba(var(--cocoa-rgb), 0.12);
    color: var(--text-secondary);
    box-shadow: none;
  }

  h2 {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    max-width: 13ch;
    color: var(--text-primary);
    font-family: var(--font-signature);
    font-size: clamp(1.85rem, 2.35vw, 2.85rem);
    font-weight: var(--weight-regular);
    font-synthesis: none;
    letter-spacing: 0;
    line-height: 1.28;
    padding-block: 0.08em 0.16em;
    text-wrap: balance;
    transition: color var(--motion-medium) var(--ease-luxury);
  }

  h2 :global(.card-title-sparkle) {
    flex: 0 0 auto;
    color: rgb(var(--cocoa-rgb));
    opacity: 0.72;
    transform: translateY(0.08em);
  }

  p {
    max-width: var(--measure-xs);
    color: var(--text-secondary);
    font-size: var(--body-sm);
    line-height: var(--leading-body);
    text-wrap: pretty;
  }
  .product-description {
    display: -webkit-box;
    min-height: calc(2 * var(--leading-body) * 1em);
    overflow: hidden;
    opacity: 1;
    transform: none;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }
  .product-card--staged .product-description {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 620ms var(--ease-luxury) calc(var(--product-card-delay) + 420ms),
      transform 720ms var(--ease-luxury) calc(var(--product-card-delay) + 420ms);
  }
  .product-card--staged.is-settled .product-description {
    opacity: 1;
    transform: none;
  }

  .product-meta {
    display: grid;
    gap: var(--space-4);
    padding-top: var(--space-1);
  }
  .product-price {
    display: grid;
    width: fit-content;
    gap: var(--space-1);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-variant-numeric: tabular-nums;
    line-height: 1.25;
  }
  .product-price span { color: var(--text-muted); font-size: var(--caption); font-weight: var(--weight-semibold); letter-spacing: var(--tracking-label); text-transform: uppercase; }
  .product-price strong { color: var(--text-primary); font-size: clamp(1.15rem, 1.6vw, 1.42rem); font-weight: 700; }
  .product-palette {
    display: inline-flex;
    width: fit-content;
    min-height: 44px;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-secondary);
  }
  .palette-choice { display: inline-grid; place-items: center; width: 2rem; height: 2rem; }
  .palette-choice i {
    display: block;
    width: 1.35rem;
    height: 1.35rem;
    border: 1px solid rgba(var(--cocoa-rgb), 0.42);
    border-radius: 50%;
    background: var(--swatch);
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.28);
  }
  .palette-choice i.is-selected {
    outline: 2px solid rgb(var(--cocoa-rgb));
    outline-offset: 3px;
  }
  .palette-name { margin-inline-start: var(--space-1); font-size: var(--caption); }

  .craft-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding: 0;
    list-style: none;
  }

  .craft-tags li {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--cocoa-border-soft);
    border-radius: var(--radius-2xs);
    padding: 0.35rem 0.65rem;
    background: rgba(var(--cocoa-rgb), 0.08);
    -webkit-backdrop-filter: var(--navbar-glass-filter);
    backdrop-filter: var(--navbar-glass-filter);
    text-align: center;
  }

  .product-action {
    display: inline-flex;
    width: fit-content;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    margin-top: var(--space-2);
    padding-inline: var(--space-4);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.02);
    color: var(--ivory-100);
    font-size: var(--label-md);
    font-weight: var(--weight-semibold);
    opacity: 0.9;
    transition:
      background var(--motion-medium) var(--ease-luxury),
      border-color var(--motion-medium) var(--ease-luxury),
      color var(--motion-medium) var(--ease-luxury),
      opacity var(--motion-medium) var(--ease-luxury),
      transform var(--motion-medium) var(--ease-luxury);
  }

  .product-link:hover .product-media,
  .product-link:focus-visible .product-media {
    transform: translate3d(0, var(--motion-card-lift), 0);
    border-color: var(--border-strong);
    box-shadow:
      var(--shadow-premium), var(--glow-soft), var(--shadow-inset-strong);
  }

  .product-link:hover .product-media::after,
  .product-link:focus-visible .product-media::after {
    opacity: 0.5;
  }

  .product-link:hover .product-media[data-image-fit="cover"] img,
  .product-link:focus-visible .product-media[data-image-fit="cover"] img {
    transform: scale(var(--motion-image-scale-subtle));
  }

  .product-link:hover h2,
  .product-link:focus-visible h2 {
    color: var(--ivory-50);
  }

  .product-link:hover .product-action,
  .product-link:focus-visible .product-action {
    border-color: var(--border-strong);
    background: rgba(255, 255, 255, 0.045);
    color: var(--ivory-100);
    opacity: 1;
    transform: translate3d(var(--motion-distance-xs), 0, 0);
  }

  .product-link:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: var(--space-3);
    border-radius: var(--product-card-radius);
  }

  @keyframes product-card-reveal {
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 767px) {
    .product-card {
      --product-card-radius: var(--radius-lg);
    }

    .product-link {
      gap: var(--space-4);
    }

    .product-copy {
      gap: var(--space-2);
    }

    h2 {
      font-size: clamp(1.45rem, 8vw, 2.15rem);
    }

    p {
      font-size: 0.86rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .product-description {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .product-link:hover .product-media,
    .product-link:focus-visible .product-media,
    .product-link:hover img,
    .product-link:focus-visible img,
    .product-link:hover .product-action,
    .product-link:focus-visible .product-action {
      transform: none;
    }
  }
</style>
