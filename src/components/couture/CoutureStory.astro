---
import Label from "../primitives/Label.astro";
import type { CouturePiece } from "../../data/couture";

interface Props {
  product: CouturePiece;
}

const { product } = Astro.props;
---

<section class="product-story" aria-labelledby="product-story-heading">
  <div>
    <Label icon="needle" iconSize={14}>Couture Story</Label>
    <h2 id="product-story-heading">A Quiet Couture <span>Chapter</span></h2>
  </div>

  <div class="story-copy">
    <p>{product.story}</p>

    {
      product.usp && (
        <p>
          <strong>Signature note:</strong> {product.usp}
        </p>
      )
    }
  </div>
</section>

<style>
  .product-story {
    display: grid;
    gap: clamp(var(--space-5), 4vw, var(--space-7));
    align-items: start;
    max-width: 64rem;
  }

  h2 {
    max-width: 18ch;
    margin-top: var(--space-4);
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 5vw, 5.7rem);
    font-weight: var(--weight-light);
    letter-spacing: var(--tracking-heading);
    line-height: var(--leading-heading);
    text-wrap: balance;
  }

  .product-story h2 span {
    background: var(--gradient-brand-text);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    font: inherit;
    letter-spacing: inherit;
    line-height: inherit;
    text-transform: none;
    -webkit-text-fill-color: transparent;
  }

  .story-copy {
    display: grid;
    gap: var(--space-5);
    max-width: 62rem;
    color: var(--text-secondary);
    font-size: clamp(var(--body-md), 1.6vw, var(--body-lg));
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  strong {
    color: var(--text-primary);
    font-weight: var(--weight-semibold);
  }
</style>
