---
import Icon from "../primitives/Icon.astro";

interface Props {
  step: number;
  title: string;
  description: string;
  icon: string;
  image: string;
  revealSide?: "left" | "right";
}

const {
  step,
  title,
  description,
  icon,
  image,
  revealSide = "right",
} = Astro.props;
---

<article class:list={["journey-card", `journey-card--reveal-${revealSide}`]}>
  <span class="milestone" aria-hidden="true"></span>

  <div class="image-panel" aria-hidden="true">
    <img
      src={image}
      alt=""
      width="900"
      height="1200"
      loading="lazy"
      decoding="async"
    />
  </div>

  <div class="card-surface">
    <span class="step">{String(step).padStart(2, "0")}</span>

    <div class="icon-wrapper" aria-hidden="true">
      <Icon
        name={icon}
        size={34}
        color="currentColor"
        class="journey-icon"
      />
    </div>

    <div class="content">
      <h3>{title}</h3>

      <span class="divider" aria-hidden="true"></span>

      <p>{description}</p>
    </div>
  </div>
</article>

<style>
  .journey-card {
    --journey-card-padding: clamp(var(--space-5), 3vw, var(--space-8));
    --journey-card-min-height: clamp(22rem, 33vw, 29rem);
    --journey-step-size: clamp(4rem, 7vw, 7rem);
    --journey-image-offset: 90%;

    position: relative;
    isolation: isolate;
  }

  .milestone {
    position: absolute;
    top: var(--space-8);
    z-index: var(--z-content);
    width: var(--space-3);
    height: var(--space-3);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-circle);
    background: var(--surface-canvas);
    box-shadow: 0 0 0 var(--space-2) var(--accent-soft), var(--glow-soft);
  }

  :global(.timeline-item--left) .milestone {
    right: calc(clamp(var(--space-7), 6vw, var(--space-12)) * -1);
    transform: translateX(50%);
  }

  :global(.timeline-item--right) .milestone {
    left: calc(clamp(var(--space-7), 6vw, var(--space-12)) * -1);
    transform: translateX(-50%);
  }

  .card-surface {
    position: relative;
    z-index: 2;
    display: flex;
    min-height: var(--journey-card-min-height);
    overflow: hidden;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-7);
    padding: var(--journey-card-padding);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-2xl);
    background: var(--gradient-glass), var(--gradient-obsidian);
    box-shadow: var(--elevation-2), var(--shadow-inset);
    transition:
      transform var(--motion-medium) var(--ease-luxury),
      border-color var(--motion-medium) var(--ease-luxury),
      box-shadow var(--motion-medium) var(--ease-luxury),
      background-color var(--motion-medium) var(--ease-luxury);
  }

  .card-surface::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: var(--gradient-ambient-cocoa);
    opacity: .42;
    transition: opacity var(--motion-medium) var(--ease-luxury);
  }

  .journey-card:hover .card-surface,
  .journey-card:focus-within .card-surface {
    transform: translateY(var(--hover-lift-soft));
    border-color: var(--border-strong);
    box-shadow: var(--shadow-premium), var(--glow-medium), var(--shadow-inset-strong);
  }

  .journey-card:hover .card-surface::before,
  .journey-card:focus-within .card-surface::before {
    opacity: .58;
  }

  .image-panel {
    position: absolute;
    top: 50%;
    z-index: 1;
    width: min(96%, 42rem);
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-2xl);
    background: var(--surface-raised);
    box-shadow: var(--shadow-floating);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity var(--motion-luxury) var(--ease-luxury),
      transform var(--motion-luxury) var(--ease-luxury),
      filter var(--motion-luxury) var(--ease-luxury);
  }

  .journey-card--reveal-right .image-panel {
    right: 0;
    transform: translate(8%, -50%) scale(.98);
  }

  .journey-card--reveal-left .image-panel {
    left: 0;
    transform: translate(-8%, -50%) scale(.98);
  }

  .journey-card:hover .image-panel,
  .journey-card:focus-within .image-panel {
    opacity: .92;
    filter: saturate(.9);
  }

  .journey-card--reveal-right:hover .image-panel,
  .journey-card--reveal-right:focus-within .image-panel {
    transform: translate(var(--journey-image-offset), -50%) scale(1);
  }

  .journey-card--reveal-left:hover .image-panel,
  .journey-card--reveal-left:focus-within .image-panel {
    transform: translate(calc(var(--journey-image-offset) * -1), -50%) scale(1);
  }

  .image-panel::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--gradient-overlay);
  }

  .image-panel img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.02);
    transition: transform var(--motion-luxury) var(--ease-luxury);
  }

  .journey-card:hover .image-panel img,
  .journey-card:focus-within .image-panel img {
    transform: scale(1);
  }

  .step {
    position: absolute;
    top: var(--space-5);
    right: var(--space-6);
    color: var(--cocoa-400);
    font-family: var(--font-display);
    font-size: var(--journey-step-size);
    font-weight: var(--weight-light);
    line-height: 1;
    transition:
      color var(--motion-medium) var(--ease-luxury),
      text-shadow var(--motion-medium) var(--ease-luxury);
  }

  .journey-card:hover .step,
  .journey-card:focus-within .step {
    color: var(--sand-300);
    text-shadow: var(--glow-cocoa-neon);
  }

  .icon-wrapper {
    display: grid;
    width: clamp(var(--space-8), 5vw, var(--space-10));
    height: clamp(var(--space-8), 5vw, var(--space-10));
    place-items: center;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-circle);
    background: var(--surface-glass);
    color: var(--sand-300);
    box-shadow: var(--shadow-inset);
    transition:
      transform var(--motion-medium) var(--ease-luxury),
      border-color var(--motion-medium) var(--ease-luxury),
      color var(--motion-medium) var(--ease-luxury),
      box-shadow var(--motion-medium) var(--ease-luxury);
  }

  .journey-card:hover .icon-wrapper,
  .journey-card:focus-within .icon-wrapper {
    transform: scale(var(--scale-hover));
    border-color: var(--border-strong);
    color: var(--ivory-100);
    box-shadow: var(--glow-soft), var(--shadow-inset-strong);
  }

  .content {
    display: grid;
    gap: var(--space-4);
    max-width: var(--measure-xs);
  }

  h3 {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 2.4vw, 2.6rem);
    font-weight: var(--weight-light);
    line-height: var(--leading-heading);
    letter-spacing: var(--tracking-title);
    text-wrap: balance;
    transition: color var(--motion-medium) var(--ease-luxury);
  }

  .journey-card:hover h3,
  .journey-card:focus-within h3 {
    color: var(--ivory-50);
  }

  .divider {
    width: var(--space-9);
    height: 1px;
    background: linear-gradient(90deg, var(--cocoa-400), transparent);
    transform-origin: left;
    transition: transform var(--motion-medium) var(--ease-luxury);
  }

  .journey-card:hover .divider,
  .journey-card:focus-within .divider {
    transform: scaleX(1.45);
  }

  p {
    max-width: var(--measure-xs);
    color: var(--text-secondary);
    font-size: var(--body-sm);
    line-height: var(--leading-body);
    text-wrap: pretty;
    transition: color var(--motion-medium) var(--ease-luxury);
  }

  .journey-card:hover p,
  .journey-card:focus-within p {
    color: var(--text-primary);
  }

  @media (max-width: 1023px) {
    .journey-card {
      --journey-card-min-height: clamp(20rem, 56vw, 27rem);
      --journey-mobile-image-height: min(16rem, 56vw);

      padding-bottom: calc(var(--journey-mobile-image-height) + var(--space-3));
    }

    .milestone {
      left: calc((var(--space-6) + var(--space-2)) * -1);
      right: auto;
      transform: none;
    }

    :global(.timeline-item--left) .milestone,
    :global(.timeline-item--right) .milestone {
      left: calc((var(--space-6) + var(--space-2)) * -1);
      right: auto;
      transform: none;
    }

    .image-panel {
      top: auto;
      right: var(--space-5);
      bottom: 0;
      left: var(--space-5);
      width: auto;
      height: var(--journey-mobile-image-height);
      aspect-ratio: 16 / 10;
      transform: translateY(calc((var(--journey-mobile-image-height) + var(--space-3)) * -1)) scale(.98);
    }

    .journey-card--reveal-left .image-panel,
    .journey-card--reveal-right .image-panel {
      transform: translateY(calc((var(--journey-mobile-image-height) + var(--space-3)) * -1)) scale(.98);
    }

    .journey-card:hover .image-panel,
    .journey-card:focus-within .image-panel,
    .journey-card--reveal-left:hover .image-panel,
    .journey-card--reveal-left:focus-within .image-panel,
    .journey-card--reveal-right:hover .image-panel,
    .journey-card--reveal-right:focus-within .image-panel {
      transform: translateY(0) scale(1);
    }
  }

  @media (max-width: 767px) {
    .journey-card {
      --journey-card-padding: var(--space-5);
      --journey-card-min-height: 22rem;
      --journey-mobile-image-height: min(13rem, 56vw);
    }

    .card-surface {
      gap: var(--space-6);
      border-radius: var(--radius-xl);
    }

    .step {
      top: var(--space-4);
      right: var(--space-5);
    }

    .image-panel {
      right: var(--space-4);
      left: var(--space-4);
      border-radius: var(--radius-xl);
    }
  }
</style>
