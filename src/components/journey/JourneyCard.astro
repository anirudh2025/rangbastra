---
import Icon from "../primitives/Icon.astro";

interface Props {
  step: number;
  title: string;
  description: string;
  icon: string;
  image: string;
  revealSide?: "left" | "right";
}

const {
  step,
  title,
  description,
  icon,
  image,
  revealSide = "right",
} = Astro.props;

// Create a responsive srcset for Cloudinary-hosted images (if possible)
const makeSrcset = (url?: string): string | null => {
  if (!url || !url.includes("/upload/")) return null;
  const widths = [480, 800, 1200, 1600];
  return widths
    .map((w) => url.replace("/upload/", `/upload/w_${w}/`) + ` ${w}w`)
    .join(", ");
};

const srcset = makeSrcset(image);
const sizesAttr = "(max-width: 767px) 90vw, (max-width: 1023px) 60vw, 42rem";
---

<article class:list={["journey-card", `journey-card--reveal-${revealSide}`]}>
  <span class="milestone" aria-hidden="true"></span>

  <div class="image-panel" aria-hidden="true">
    <img
      src={image}
      alt=""
      width="1600"
      height="1000"
      loading="lazy"
      decoding="async"
      srcset={srcset}
      sizes={srcset ? sizesAttr : undefined}
    />
  </div>

  <div class="card-surface">
    <span class="step">{String(step).padStart(2, "0")}</span>

    <div class="icon-wrapper" aria-hidden="true">
      <Icon
        name={icon}
        size={34}
        color="currentColor"
        class="journey-icon"
      />
    </div>

    <div class="content">
      <h3>{title}</h3>

      <span class="divider" aria-hidden="true"></span>

      <p>{description}</p>
    </div>
  </div>
</article>

<style>
  .journey-card {
    --journey-card-padding: clamp(var(--space-5), 3vw, var(--space-8));
    --journey-card-min-height: clamp(22rem, 33vw, 29rem);
    --journey-step-size: clamp(4rem, 7vw, 7rem);

    --journey-line-gap: var(--space-7);
    --journey-image-width: min(38rem, 42vw);
    --journey-dot-size: var(--space-3);

    position: relative;
    isolation: isolate;
  }

  .milestone {
    position: absolute;
    top: var(--space-8);
    z-index: 5;
    width: var(--journey-dot-size);
    height: var(--journey-dot-size);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-circle);
    background: var(--obsidian-1000);
    box-shadow:
      0 0 0 var(--space-2) rgba(181, 147, 130, .10),
      0 0 22px rgba(181, 147, 130, .22);
    opacity: .9;
  }

  :global(.timeline-item--left) .milestone {
    right: calc((var(--journey-line-gap) * -1) - (var(--journey-dot-size) / 2));
    transform: none;
  }

  :global(.timeline-item--right) .milestone {
    left: calc((var(--journey-line-gap) * -1) - (var(--journey-dot-size) / 2));
    transform: none;
  }

  .card-surface {
    position: relative;
    z-index: 3;
    display: flex;
    min-height: var(--journey-card-min-height);
    overflow: hidden;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-6);
    padding: var(--journey-card-padding);
    padding-bottom: clamp(var(--space-5), 2.4vw, var(--space-7));
    border: 1px solid var(--border-default);
    border-radius: var(--radius-2xl);
    background:
      var(--gradient-obsidian),
      var(--gradient-obsidian);
    box-shadow: var(--shadow-none);
    transition:
      transform var(--motion-medium) var(--ease-luxury),
      border-color var(--motion-medium) var(--ease-luxury),
      box-shadow var(--motion-medium) var(--ease-luxury);
  }

  .card-surface::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(circle at 18% 12%, rgba(181, 147, 130, .13), transparent 38%),
      radial-gradient(circle at 88% 86%, rgba(106, 78, 66, .18), transparent 46%);
    opacity: .5;
    transition: opacity var(--motion-medium) var(--ease-luxury);
  }

  .journey-card:hover .card-surface,
  .journey-card:focus-within .card-surface {
    transform: translate3d(0, var(--motion-card-lift), 0);
    border-color: var(--border-strong);
    box-shadow:
      0 22px 54px rgba(0, 0, 0, .34),
      0 0 28px rgba(181, 147, 130, .10),
      inset 0 1px 0 rgba(255, 255, 255, .05);
  }

  .journey-card:hover .card-surface::before,
  .journey-card:focus-within .card-surface::before {
    opacity: .58;
  }

  .image-panel {
    position: absolute;
    top: 0;
    z-index: 1;
    width: var(--journey-image-width);
    height: 100%;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-2xl);
    background: var(--surface-raised);
    box-shadow: 0 24px 60px rgba(0, 0, 0, .3);
    opacity: 0;
    pointer-events: none;
    will-change: transform, opacity;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    contain: paint;
    transition:
      opacity var(--motion-image) var(--ease-luxury),
      transform var(--motion-image) var(--ease-luxury);
  }

  .journey-card--reveal-right .image-panel {
    left: calc(100% + (var(--journey-line-gap) * 2));
    transform: translate3d(-14%, 0, 0) scale(.98);
  }

  .journey-card--reveal-left .image-panel {
    right: calc(100% + (var(--journey-line-gap) * 2));
    transform: translate3d(14%, 0, 0) scale(.98);
  }

  .journey-card:hover .image-panel,
  .journey-card:focus-within .image-panel {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  .image-panel::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,.08), rgba(0,0,0,.34));
  }

  .image-panel img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.03);
    transition: transform var(--motion-image) var(--ease-luxury);
  }

  .journey-card:hover .image-panel img,
  .journey-card:focus-within .image-panel img {
    transform: scale(1.06);
  }

  .step {
    position: absolute;
    top: var(--space-5);
    right: var(--space-6);
    color: var(--cocoa-400);
    font-family: var(--font-display);
    font-size: var(--journey-step-size);
    font-weight: var(--weight-light);
    line-height: 1;
    transition:
      color var(--motion-medium) var(--ease-luxury),
      text-shadow var(--motion-medium) var(--ease-luxury);
  }

  .journey-card:hover .step,
  .journey-card:focus-within .step {
    color: var(--sand-300);
    text-shadow:
      0 0 8px rgba(181, 147, 130, .42),
      0 0 22px rgba(181, 147, 130, .22),
      0 0 42px rgba(181, 147, 130, .12);
  }

  .icon-wrapper {
    display: grid;
    width: clamp(var(--space-8), 5vw, var(--space-10));
    height: clamp(var(--space-8), 5vw, var(--space-10));
    place-items: center;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-circle);
    background: var(--surface-glass);
    color: var(--sand-300);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, .05);
    transition:
      transform var(--motion-medium) var(--ease-luxury),
      border-color var(--motion-medium) var(--ease-luxury),
      color var(--motion-medium) var(--ease-luxury),
      box-shadow var(--motion-medium) var(--ease-luxury);
  }

  .journey-card:hover .icon-wrapper,
  .journey-card:focus-within .icon-wrapper {
    transform: scale(var(--motion-icon-scale));
    border-color: var(--border-strong);
    color: var(--ivory-100);
    box-shadow:
      0 0 16px rgba(181, 147, 130, .16),
      inset 0 1px 0 rgba(255, 255, 255, .08);
  }

  .content {
    display: grid;
    gap: var(--space-4);
    max-width: var(--measure-xs);
  }

  h3 {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 2.4vw, 2.6rem);
    font-weight: var(--weight-light);
    line-height: var(--leading-heading);
    letter-spacing: var(--tracking-title);
    text-wrap: balance;
    transition: color var(--motion-medium) var(--ease-luxury);
  }

  .journey-card:hover h3,
  .journey-card:focus-within h3 {
    color: var(--ivory-50);
  }

  .divider {
    width: var(--space-9);
    height: 1px;
    background: linear-gradient(90deg, var(--cocoa-400), transparent);
    transform-origin: left;
    transition: transform var(--motion-medium) var(--ease-luxury);
  }

  .journey-card:hover .divider,
  .journey-card:focus-within .divider {
    transform: scaleX(1.28);
  }

  p {
    max-width: var(--measure-xs);
    color: var(--text-secondary);
    font-size: var(--body-sm);
    line-height: var(--leading-body);
    text-wrap: pretty;
    transition: color var(--motion-medium) var(--ease-luxury);
  }

  .journey-card:hover p,
  .journey-card:focus-within p {
    color: var(--text-primary);
  }

  @media (max-width: 1023px) {
    .journey-card {
      --journey-card-min-height: clamp(20rem, 56vw, 27rem);
      --journey-mobile-image-height: min(16rem, 56vw);

      padding-bottom: calc(var(--journey-mobile-image-height) + var(--space-3));
    }

    .milestone,
    :global(.timeline-item--left) .milestone,
    :global(.timeline-item--right) .milestone {
      left: calc((var(--space-6) + var(--space-2)) * -1);
      right: auto;
      transform: none;
    }

    .image-panel {
      top: auto;
      right: var(--space-5);
      bottom: 0;
      left: var(--space-5);
      width: auto;
      height: var(--journey-mobile-image-height);
      aspect-ratio: 16 / 10;
      opacity: .82;
      transform: translate3d(0, 0, 0) scale(1);
    }

    .journey-card--reveal-left .image-panel,
    .journey-card--reveal-right .image-panel,
    .journey-card:hover .image-panel,
    .journey-card:focus-within .image-panel {
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  @media (max-width: 767px) {
    .journey-card {
      --journey-card-padding: var(--space-5);
      --journey-card-min-height: 22rem;
      --journey-mobile-image-height: min(13rem, 56vw);
    }

    .card-surface {
      gap: var(--space-5);
      border-radius: var(--radius-xl);
      padding-bottom: var(--space-5);
    }

    .step {
      top: var(--space-4);
      right: var(--space-5);
    }

    .image-panel {
      right: var(--space-4);
      left: var(--space-4);
      border-radius: var(--radius-xl);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .journey-card:hover .card-surface,
    .journey-card:focus-within .card-surface,
    .journey-card:hover .image-panel,
    .journey-card:focus-within .image-panel,
    .journey-card:hover .image-panel img,
    .journey-card:focus-within .image-panel img,
    .journey-card:hover .icon-wrapper,
    .journey-card:focus-within .icon-wrapper,
    .journey-card:hover .divider,
    .journey-card:focus-within .divider {
      transform: none;
    }
  }
</style>
