---
import { journey } from "../../data/journey";
import JourneyCard from "./JourneyCard.astro";
---

<div class="timeline" data-scroll-timeline>
  {
    journey.map((item, index) => (
      <div
        class:list={[
          "timeline-item",
          index % 2 === 0 ? "timeline-item--left" : "timeline-item--right",
        ]}
      >
        <JourneyCard
          step={item.id}
          title={item.title}
          description={item.description}
          icon={item.icon}
          image={item.image}
          revealSide={index % 2 === 0 ? "right" : "left"}
        />
      </div>
    ))
  }
</div>

<script>
  import { initTimelineProgress } from "../../lib/animations/timelineProgress";
  initTimelineProgress();
  document.addEventListener("astro:page-load", initTimelineProgress);
</script>

<style>
  .timeline {
    --timeline-gutter: clamp(var(--space-7), 6vw, var(--space-12));
    position: relative;
    display: grid;
    gap: clamp(var(--space-8), 7vw, var(--space-12));
  }

  .timeline::before {
    content: "";
    position: absolute;
    inset-block: var(--space-6);
    left: 50%;
    width: 1px;
    background: rgba(var(--cocoa-rgb), 0.26);
    box-shadow: none;
    transform: translateX(-50%);
  }

  .timeline::after {
    content: "";
    position: absolute;
    inset-block: var(--space-6);
    left: 50%;
    width: 1.5px;
    background: rgb(var(--cocoa-rgb));
    box-shadow: 0 0 4px var(--cocoa-glow-soft);
    transform: translate3d(-50%, 0, 0) scaleY(var(--timeline-progress, 0));
    transform-origin: top;
    pointer-events: none;
    will-change: transform;
  }

  .timeline-item {
    position: relative;
    width: 50%;
  }

  .timeline-item--left {
    justify-self: start;
    padding-right: var(--timeline-gutter);
  }

  .timeline-item--right {
    justify-self: end;
    padding-left: var(--timeline-gutter);
  }

  @media (max-width: 1023px) {
    .timeline {
      gap: var(--space-8);
    }

    .timeline::before {
      left: var(--space-2);
      transform: none;
    }
    .timeline::after {
      left: var(--space-2);
      transform: scaleY(var(--timeline-progress, 0));
    }

    .timeline-item,
    .timeline-item--left,
    .timeline-item--right {
      width: 100%;
      justify-self: stretch;
      padding-inline: 0 0;
      padding-left: var(--space-6);
    }
  }

  @media (max-width: 767px) {
    .timeline {
      gap: var(--space-7);
    }
  }
</style>
