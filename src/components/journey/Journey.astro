---
import Section from "../primitives/Section.astro";
import Container from "../primitives/Container.astro";

import JourneyHeader from "./JourneyHeader.astro";
import JourneyTimeline from "./JourneyTimeline.astro";
---

<Section class="journey-section">
  <Container class="journey-container">
    <JourneyHeader />

    <JourneyTimeline />
  </Container>
</Section>

<style>
  :global(.journey-section) {
    --section-padding-block: clamp(var(--space-10), 10vw, var(--space-14));

    overflow: hidden;
    background:transparent;
  }

  :global(.journey-container) {
    --container-default: var(--container-wide);
    --container-padding-inline: clamp(var(--space-5), 5vw, var(--space-10));

    position: relative;
    z-index: var(--z-content);
    display: flex;
    flex-direction: column;
    gap: clamp(var(--space-8), 7vw, var(--space-12));
  }

  @media (max-width: 767px) {
    :global(.journey-section) {
      --section-padding-block: clamp(var(--space-9), 18vw, var(--space-12));
    }

    :global(.journey-container) {
      --container-padding-inline: clamp(var(--space-4), 6vw, var(--space-6));
      gap: var(--space-8);
    }
  }
</style>
