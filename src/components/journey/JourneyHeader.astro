---
import Eyebrow from "../primitives/Eyebrow.astro";
---

<header class="journey-header">
  <Eyebrow>The Experience</Eyebrow>

  <h2 class="title">
    <span class="title-intro">Your Journey To</span>
    <span class="title-statement">Timeless Couture</span>
  </h2>

  <p class="description">
    From the first conversation to the final fitting, every creation is
    thoughtfully designed, meticulously handcrafted and tailored exclusively for
    your celebration.
  </p>
</header>

<style>
  .journey-header {
    display: grid;
    justify-items: center;
    gap: var(--space-4);
    max-width: var(--measure-md);
    margin-inline: auto;
    text-align: center;
  }

  .title {
    display: grid;
    gap: var(--space-2);
    max-width: min(100%, 44rem);
    color: var(--text-primary);
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    justify-self: center;
    text-align: center;
    text-wrap: balance;
  }

  .title-intro {
    color: var(--text-primary);
    font-size: var(--section-heading-intro);
    letter-spacing: var(--tracking-heading);
    line-height: 1.18;
    white-space: nowrap;
  }

  .title-statement {
    background: var(--gradient-primary);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    font-size: var(--section-heading-statement);
    letter-spacing: -3.8px;
    line-height: 1.12;
    padding-bottom: .08em;
    white-space: nowrap;
  }

  .description {
    max-width: var(--measure-md);
    color: var(--text-secondary);
    font-size: var(--body-md);
    line-height: var(--leading-body);
    text-align: center;
    text-wrap: pretty;
  }

  @media (max-width: 767px) {
    .journey-header {
      justify-items: start;
      gap: var(--space-3);
      text-align: left;
    }

    .title-intro {
      font-size: var(--section-heading-intro-mobile);
    }

    .title-statement {
      font-size: var(--section-heading-statement-mobile);
    }
  }
</style>
