---
import type { NavigationItem } from "../../data/navigation";
import { contact, getWhatsAppHref } from "../../data/contact";
import Icon from "../primitives/Icon.astro";
import SoundControl from "./SoundControl.astro";
interface Props {
  items: NavigationItem[];
}
const { items } = Astro.props;
---

<div
  class="mobile-nav"
  id="mobile-navigation"
  data-mobile-nav
  aria-hidden="true"
>
  <div class="mobile-nav__content">
    <ul class="mobile-nav__list">
      {
        items.map((item) => (
          <li class="mobile-nav__item">
            <details class="mobile-nav__group">
              <summary>
                {item.label}
                <svg viewBox="0 0 16 16" aria-hidden="true">
                  <path d="m4 6 4 4 4-4" />
                </svg>
              </summary>
              <div>
                {item.children?.map((child) => (
                  <a href={child.href} class="nav-link">
                    <span aria-hidden="true">
                      <Icon name={child.icon} size={17} />
                    </span>
                    <span>{child.label}</span>
                  </a>
                ))}
              </div>
            </details>
          </li>
        ))
      }
      <li class="mobile-nav__item mobile-nav__utilities">
        <a href="/search" class="nav-link">Search</a><a
          href="/wishlist"
          class="nav-link">Inspirations</a
        ><span class="mobile-auth-skeleton" data-auth-pending>Restoring account…</span
        ><div class="mobile-auth-signed-out" data-auth-signed-out hidden><a href="/account/login" class="nav-link" data-auth-login>Sign In</a><a href="/account/signup" class="nav-link" data-auth-signup>Create Account</a></div
        ><div class="mobile-profile" data-auth-signed-in hidden><div><span class="mobile-profile__avatar" data-auth-avatar aria-hidden="true"><Icon name="account" size={18}/></span><strong data-auth-name>Account</strong></div><a href="/account#profile" class="nav-link">My Profile</a><a href="/account#saved" class="nav-link">Saved Inspirations</a><a href="/account#requests" class="nav-link">Couture Requests</a><a href="/account#appointments" class="nav-link">Appointments</a><a href="/account#settings" class="nav-link">Account Settings</a><button type="button" class="nav-link" data-auth-logout>Log Out</button></div
        ><SoundControl id="mobile-sound-controls" compact />
      </li>
    </ul>
    <div class="mobile-nav__footer">
      <div class="mobile-nav__divider" aria-hidden="true"></div>
      <p class="mobile-nav__statement">
        Every masterpiece begins with a conversation.
      </p>
      <nav class="mobile-nav__social" aria-label="Social Links">
        <a href={contact.instagramUrl} target="_blank" rel="noopener noreferrer"
          >Instagram</a
        ><a
          href={getWhatsAppHref("homepage")}
          target="_blank"
          rel="noopener noreferrer">WhatsApp</a>
      </nav>
    </div>
  </div>
</div>

<style>
  .mobile-auth-signed-out,.mobile-profile{display:grid;gap:.25rem}.mobile-auth-skeleton{min-height:44px;padding:.75rem;color:var(--text-muted)}.mobile-profile>div{display:flex;align-items:center;gap:.75rem;padding:.75rem;color:var(--text-primary)}.mobile-profile__avatar{display:grid;width:2.25rem;height:2.25rem;overflow:hidden;place-items:center;border:1px solid var(--cocoa-border);border-radius:50%}.mobile-profile__avatar img{width:100%;height:100%;object-fit:cover}.mobile-profile button{width:100%;border:0;background:transparent;text-align:left}[hidden]{display:none!important}
</style>
