---
import Logo from "./Logo.astro";
import DesktopNav from "./DesktopNav.astro";
import MobileNav from "./MobileNav.astro";
import CTAButton from "./CTAButton.astro";
import MobileMenuButton from "./MobileMenuButton.astro";
import UtilityNav from "./UtilityNav.astro";

import { navigation as navigationItems } from "../../data/navigation";
---

<header class="navbar" data-navbar data-menu-open="false">
  <nav class="navbar__inner" aria-label="Primary Navigation">
    <div class="navbar__header">
      <a href="/" class="navbar__brand" aria-label="Rangbastra Home">
        <Logo alt="" />
      </a>

      <DesktopNav items={navigationItems} />

      <div class="navbar__actions">
        <UtilityNav />

        <CTAButton />

        <MobileMenuButton />
      </div>
    </div>

    <MobileNav items={navigationItems} />
  </nav>
  <dialog class="logout-dialog" data-logout-dialog aria-labelledby="logout-title" aria-describedby="logout-copy">
    <div><h2 id="logout-title">Leaving your private couture space?</h2><p id="logout-copy">Your inspirations and requests will remain safely saved for your return.</p><div><button type="button" data-logout-cancel>Stay Here</button><button type="button" data-logout-confirm>Log Out</button></div></div>
  </dialog>
</header>

<script>
  import { initializeNavbar } from "../../lib/navigation/navbar";
  import { initAccountNavigation } from "../../lib/auth/accountNavigation";

  initializeNavbar();
  initAccountNavigation();
  document.addEventListener("astro:page-load", initAccountNavigation);
</script>

<style>
  .logout-dialog{max-width:min(32rem,calc(100% - 2rem));padding:0;border:1px solid var(--cocoa-border);border-radius:var(--radius-lg);background:#050403;color:var(--text-secondary)}.logout-dialog::backdrop{background:rgba(0,0,0,.82);backdrop-filter:blur(7px)}.logout-dialog>div{display:grid;gap:var(--space-4);padding:clamp(var(--space-5),5vw,var(--space-8))}.logout-dialog h2{color:var(--text-primary);font-family:var(--font-display);font-size:clamp(2rem,5vw,3.2rem);font-weight:var(--weight-light);line-height:1}.logout-dialog p{line-height:var(--leading-body)}.logout-dialog div div{display:flex;justify-content:flex-end;gap:var(--space-3)}.logout-dialog button{min-height:44px;padding-inline:var(--space-4);border:1px solid var(--cocoa-border);border-radius:var(--radius-md);background:transparent;color:var(--text-primary)}.logout-dialog button[data-logout-confirm]{background:rgba(var(--cocoa-rgb),.2)}.logout-dialog button:focus-visible{outline:2px solid var(--focus-ring);outline-offset:3px}
</style>
