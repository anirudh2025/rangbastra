---
import Button from "../primitives/Button.astro";
import Eyebrow from "../primitives/Eyebrow.astro";
const steps = [
  ["occasion", "Occasion", ["Wedding", "Reception", "Engagement", "Festive celebration", "Other"]],
  ["silhouette", "Desired silhouette", ["Lehenga", "Anarkali", "Gown", "Sari direction", "Still exploring"]],
  ["palette", "Preferred palette", ["Deep ceremonial", "Soft romantic", "Earth and cocoa", "Jewel tones", "Open to guidance"]],
  ["timeline", "Timeline", ["Under 8 weeks", "8–12 weeks", "3–6 months", "More than 6 months"]],
  ["budget", "Budget range", ["₹20,000–₹50,000", "₹50,000–₹1,00,000", "₹1,00,000–₹2,00,000", "₹2,00,000+", "Discuss privately"]],
  ["measurements", "Measurement readiness", ["Measurements ready", "Need guidance", "Prefer studio measurement"]],
  ["consultation", "Consultation method", ["WhatsApp", "Video", "Anand studio", "Help me choose"]],
] as const;
---
<section class="discovery" id="couture-discovery" aria-labelledby="discovery-heading" data-couture-discovery>
  <div class="discovery__intro"><Eyebrow>Shape Your Brief</Eyebrow><h2 id="discovery-heading">Discover what your couture journey needs</h2><p>This guided edit helps you clarify the essentials. The detailed design request comes next.</p></div>
  <form>
    <div class="progress"><span data-progress-text>Step 1 of {steps.length + 1}</span><i aria-hidden="true"><b data-progress-bar></b></i></div>
    {steps.map(([name, title, options], index) => <fieldset data-step={index} hidden={index !== 0}><legend>{title}</legend><div class="choices">{options.map(option => <label><input type="radio" name={name} value={option} required /><span>{option}</span></label>)}</div></fieldset>)}
    <fieldset data-step={steps.length} hidden><legend>Inspiration</legend><p class="field-help">Add reference images now, or continue without them. Files stay in this browser draft and are not uploaded.</p><label class="upload"><span>Choose inspiration images</span><input type="file" name="inspiration" accept="image/jpeg,image/png,image/webp" multiple /></label><output data-file-output>No files selected</output></fieldset>
    <div class="controls"><button type="button" data-back hidden>Back</button><button type="button" data-next>Continue</button></div>
    <section class="summary" data-summary hidden aria-live="polite"><Eyebrow>Your Starting Point</Eyebrow><dl data-summary-list></dl><p>Your draft can be saved privately in this browser. Signed-in account syncing is intentionally deferred until it can use the existing authenticated server flow safely.</p><div class="summary__actions"><button type="button" data-save>Save browser draft</button><Button href="/design-your-outfit">Continue to Detailed Request</Button></div><output data-save-status></output></section>
  </form>
</section>
<script>
  document.querySelectorAll<HTMLElement>("[data-couture-discovery]").forEach(root=>{const form=root.querySelector("form")!;const fields=[...root.querySelectorAll<HTMLFieldSetElement>("[data-step]")];const next=root.querySelector<HTMLButtonElement>("[data-next]")!;const back=root.querySelector<HTMLButtonElement>("[data-back]")!;const summary=root.querySelector<HTMLElement>("[data-summary]")!;let step=0;const draw=()=>{fields.forEach((field,index)=>field.hidden=index!==step);back.hidden=step===0;root.querySelector<HTMLElement>("[data-progress-text]")!.textContent=`Step ${Math.min(step+1,fields.length)} of ${fields.length}`;root.querySelector<HTMLElement>("[data-progress-bar]")!.style.width=`${((step+1)/fields.length)*100}%`;next.textContent=step===fields.length-1?"Review brief":"Continue"};const values=()=>Object.fromEntries(new FormData(form).entries());const review=()=>{fields.forEach(field=>field.hidden=true);root.querySelector<HTMLElement>(".controls")!.hidden=true;summary.hidden=false;root.querySelector<HTMLElement>("[data-summary-list]")!.innerHTML=Object.entries(values()).filter(([key])=>key!=="inspiration").map(([key,value])=>`<div><dt>${key}</dt><dd>${String(value)}</dd></div>`).join("")};next.addEventListener("click",()=>{const selected=fields[step]?.querySelector<HTMLInputElement>("input[type=radio]:checked");if(step<fields.length-1&&!selected){fields[step]?.querySelector<HTMLInputElement>("input[type=radio]")?.focus();fields[step]?.setAttribute("data-invalid","");return}if(step===fields.length-1){review();return}step++;draw()});back.addEventListener("click",()=>{step=Math.max(0,step-1);draw()});root.querySelector<HTMLInputElement>("input[type=file]")?.addEventListener("change",event=>{const input=event.currentTarget as HTMLInputElement;root.querySelector<HTMLOutputElement>("[data-file-output]")!.textContent=input.files?.length?`${input.files.length} file(s) selected`:"No files selected"});root.querySelector("[data-save]")?.addEventListener("click",()=>{localStorage.setItem("rangbastra-couture-discovery",JSON.stringify(values()));root.querySelector<HTMLOutputElement>("[data-save-status]")!.textContent="Draft saved in this browser."});draw()});
</script>
<style>
  .discovery{display:grid;grid-template-columns:minmax(0,.38fr) minmax(0,.62fr);gap:clamp(var(--space-6),8vw,var(--space-11));align-items:start}.discovery__intro,.discovery form,.summary{display:grid;gap:var(--space-5)}h2{max-width:12ch;color:var(--text-primary);font-family:var(--font-display);font-size:clamp(2.7rem,5vw,5.8rem);font-weight:var(--weight-light);line-height:1}.discovery p,.field-help{max-width:var(--measure-xs);color:var(--text-secondary);line-height:var(--leading-body)}form{padding:clamp(var(--space-5),5vw,var(--space-8));border:1px solid var(--cocoa-border-soft);border-radius:var(--radius-lg);background:#030303}.progress{display:grid;gap:var(--space-2);color:var(--text-muted);font-size:var(--caption);letter-spacing:var(--tracking-label);text-transform:uppercase}.progress i{height:2px;background:rgba(var(--cocoa-rgb),.18)}.progress b{display:block;height:100%;background:rgb(var(--cocoa-rgb));transition:width var(--motion-medium) var(--ease-luxury)}fieldset{border:0;padding:0}legend{margin-bottom:var(--space-5);color:var(--text-primary);font-family:var(--font-display);font-size:clamp(2rem,4vw,3.5rem)}.choices{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:var(--space-3)}.choices input{position:absolute;opacity:0}.choices span,.upload{display:flex;min-height:52px;align-items:center;padding:var(--space-3) var(--space-4);border:1px solid var(--cocoa-border-soft);border-radius:var(--radius-2xs);color:var(--text-secondary);cursor:pointer}.choices input:checked+span{border-color:rgb(var(--cocoa-rgb));background:rgba(var(--cocoa-rgb),.15);color:var(--text-primary)}.choices input:focus-visible+span{outline:2px solid var(--focus-ring);outline-offset:3px}.upload{width:fit-content}.upload input{max-width:15rem;margin-left:var(--space-3)}.controls,.summary__actions{display:flex;flex-wrap:wrap;gap:var(--space-3)}button{min-height:44px;padding-inline:var(--space-4);border:1px solid var(--cocoa-border);border-radius:var(--radius-md);color:var(--text-primary)}[data-next],[data-save]{background:rgba(var(--cocoa-rgb),.18)}dl{display:grid;gap:var(--space-2)}dl div{display:grid;grid-template-columns:10rem 1fr;gap:var(--space-3);padding-block:var(--space-2);border-bottom:1px solid var(--border-default)}dt{color:var(--text-muted);text-transform:capitalize}dd{color:var(--text-primary)}@media(max-width:800px){.discovery{grid-template-columns:1fr}.choices{grid-template-columns:1fr}dl div{grid-template-columns:1fr}}@media(prefers-reduced-motion:reduce){.progress b{transition:none}}
</style>
