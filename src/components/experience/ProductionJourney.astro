---
import Eyebrow from "../primitives/Eyebrow.astro"; import { productionStages } from "../../data/experiencePages";
---
<section class="production" data-production-journey><header><Eyebrow>Customization Process</Eyebrow><h1>A transparent journey from discovery to delivery</h1><p>Explore each atelier stage. This explains the process only—it does not represent a live customer order status.</p></header><div class="journey"><div class="stage-tabs" role="tablist" aria-label="Couture production stages">{productionStages.map((stage,index)=><button type="button" role="tab" id={`stage-tab-${index}`} aria-controls={`stage-panel-${index}`} aria-selected={index===0} tabindex={index===0?0:-1}><span>{String(index+1).padStart(2,"0")}</span>{stage.title}</button>)}</div><div class="stage-panels">{productionStages.map((stage,index)=><section role="tabpanel" id={`stage-panel-${index}`} aria-labelledby={`stage-tab-${index}`} hidden={index!==0}><span>{String(index+1).padStart(2,"0")} / {String(productionStages.length).padStart(2,"0")}</span><h2>{stage.title}</h2><p>{stage.text}</p></section>)}</div></div></section>
<script>
  document.querySelectorAll<HTMLElement>("[data-production-journey]").forEach(root=>{const tabs=[...root.querySelectorAll<HTMLButtonElement>("[role=tab]")];const panels=[...root.querySelectorAll<HTMLElement>("[role=tabpanel]")];const activate=(index:number)=>{tabs.forEach((tab,i)=>{tab.setAttribute("aria-selected",String(i===index));tab.tabIndex=i===index?0:-1});panels.forEach((panel,i)=>panel.hidden=i!==index)};tabs.forEach((tab,index)=>{tab.addEventListener("click",()=>activate(index));tab.addEventListener("keydown",event=>{if(!["ArrowRight","ArrowLeft","ArrowDown","ArrowUp"].includes(event.key))return;event.preventDefault();const next=(index+(["ArrowRight","ArrowDown"].includes(event.key)?1:-1)+tabs.length)%tabs.length;activate(next);tabs[next]?.focus()})})});
</script>
<style>
  .production{display:grid;gap:clamp(var(--space-8),8vw,var(--space-12));padding-top:clamp(var(--space-12),14vw,var(--space-14))}header{display:grid;max-width:62rem;gap:var(--space-5)}h1,h2{color:var(--text-primary);font-family:var(--font-display);font-weight:var(--weight-light);line-height:1}h1{font-size:clamp(3.2rem,7vw,7.7rem)}h2{font-size:clamp(3rem,7vw,7rem)}p{max-width:var(--measure-sm);color:var(--text-secondary);line-height:var(--leading-body)}.journey{display:grid;grid-template-columns:minmax(17rem,.36fr) minmax(0,.64fr);gap:clamp(var(--space-5),7vw,var(--space-10))}.stage-tabs{display:grid}.stage-tabs button{display:grid;grid-template-columns:3rem 1fr;min-height:58px;align-items:center;border-bottom:1px solid var(--border-default);color:var(--text-muted);text-align:left}.stage-tabs button[aria-selected=true]{border-color:rgb(var(--cocoa-rgb));color:var(--text-primary)}.stage-tabs button:focus-visible{outline:2px solid var(--focus-ring);outline-offset:2px}.stage-panels{min-height:28rem;padding:clamp(var(--space-6),7vw,var(--space-10));border:1px solid var(--cocoa-border-soft);border-radius:var(--radius-lg);background:radial-gradient(circle at 80% 15%,rgba(var(--cocoa-rgb),.15),transparent 42%),#030303}.stage-panels section{display:grid;gap:var(--space-5)}.stage-panels span{color:var(--text-muted);letter-spacing:var(--tracking-label)}@media(max-width:760px){.journey{grid-template-columns:1fr}.stage-tabs{display:flex;overflow-x:auto;scroll-snap-type:x mandatory}.stage-tabs button{min-width:12rem;scroll-snap-align:start}.stage-panels{min-height:22rem}}
</style>
