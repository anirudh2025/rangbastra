---
import Eyebrow from "../primitives/Eyebrow.astro"; import { confirmedMilestones, futureMissions } from "../../data/experiencePages";
---
<section class="milestones" aria-labelledby="milestone-heading" data-milestone-timeline><header><Eyebrow>Rangbastra Journey</Eyebrow><h1 id="milestone-heading">What has been built, and what comes next</h1><p>This timeline intentionally includes only confirmed information. No customer, country, sales or audience claims are inferred.</p></header><div class="timeline-layout"><ol class="timeline">{confirmedMilestones.map(item=><li><span>{item.date}</span><article>{item.media&&<figure><img src={item.media} alt="" loading="lazy" decoding="async"/></figure>}<h2>{item.title}</h2><p>{item.text}</p><small>Source: {item.source}</small></article></li>)}</ol><aside><Eyebrow>Upcoming Mission</Eyebrow><h2>A record designed to grow honestly</h2><ul>{futureMissions.map(item=><li>{item}</li>)}</ul></aside></div></section>
<script>
  document.querySelectorAll<HTMLElement>("[data-milestone-timeline]").forEach(root=>{if(matchMedia("(prefers-reduced-motion: reduce)").matches){root.style.setProperty("--timeline-progress","100%");return}let queued=false;const update=()=>{const timeline=root.querySelector<HTMLElement>(".timeline");if(!timeline)return;const rect=timeline.getBoundingClientRect();const distance=Math.max(1,rect.height+innerHeight*.55);const progress=Math.max(0,Math.min(1,(innerHeight*.72-rect.top)/distance));root.style.setProperty("--timeline-progress",`${progress*100}%`);queued=false};addEventListener("scroll",()=>{if(!queued){queued=true;requestAnimationFrame(update)}},{passive:true});update()});
</script>
<style>
  .milestones{--timeline-progress:0%;display:grid;gap:clamp(var(--space-8),9vw,var(--space-12));padding-top:clamp(var(--space-12),14vw,var(--space-14))}header{display:grid;max-width:62rem;gap:var(--space-5)}h1,h2{color:var(--text-primary);font-family:var(--font-display);font-weight:var(--weight-light);line-height:1}h1{font-size:clamp(3.2rem,7vw,7.8rem)}h2{font-size:clamp(2.4rem,4vw,4.8rem)}p,li,small{color:var(--text-secondary);line-height:var(--leading-body)}.timeline-layout{display:grid;grid-template-columns:minmax(0,.62fr) minmax(18rem,.38fr);gap:clamp(var(--space-6),8vw,var(--space-11));align-items:start}.timeline{position:relative;display:grid;gap:var(--space-8);padding:0 0 0 var(--space-7);list-style:none}.timeline::before,.timeline::after{content:"";position:absolute;top:0;bottom:0;left:.45rem;width:2px;background:rgba(var(--cocoa-rgb),.18)}.timeline::after{bottom:auto;height:var(--timeline-progress);background:rgb(var(--cocoa-rgb));transition:height 120ms linear}.timeline li{position:relative;display:grid;grid-template-columns:5rem 1fr;gap:var(--space-5)}.timeline li::before{content:"";position:absolute;left:calc(var(--space-7) * -1 - .05rem);top:.4rem;width:1rem;height:1rem;border:2px solid rgb(var(--cocoa-rgb));border-radius:50%;background:#000}.timeline article,aside{display:grid;gap:var(--space-4);padding:clamp(var(--space-5),5vw,var(--space-7));border:1px solid var(--cocoa-border-soft);border-radius:var(--radius-lg);background:#030303}.timeline figure{overflow:hidden;aspect-ratio:16/9}.timeline img{width:100%;height:100%;object-fit:cover}aside{position:sticky;top:calc(var(--navbar-height) + var(--space-5))}ul{display:grid;gap:var(--space-4);padding-left:1.2rem}@media(max-width:800px){.timeline-layout{grid-template-columns:1fr}.timeline li{grid-template-columns:1fr}aside{position:static}}@media(prefers-reduced-motion:reduce){.timeline::after{transition:none}}
</style>
