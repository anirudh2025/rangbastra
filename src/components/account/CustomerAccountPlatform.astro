---
import Button from "../primitives/Button.astro";
import { getPublishedCouturePieces } from "../../lib/couture";

const catalogue = getPublishedCouturePieces().map(({ id, slug, name, category, featuredImage }) => ({
  id, slug, name, category, featuredImage,
}));

const sections = [
  ["overview", "Overview"], ["profile", "My Profile"], ["saved", "Saved Inspirations"],
  ["requests", "Couture Requests"], ["appointments", "Appointments"],
  ["notifications", "Notifications"], ["activity", "Reviews & activity"],
  ["preferences", "Preferences"], ["privacy", "Privacy & security"],
] as const;
---

<section class="client-room" data-account-platform aria-labelledby="client-room-title">
  <header class="client-room__header">
    <p class="client-room__eyebrow">Rangbastra Private Client Room</p>
    <h1 id="client-room-title">Your couture, considered.</h1>
    <p data-account-greeting>Loading your private account…</p>
  </header>

  <div class="client-room__layout">
    <nav class="client-room__nav" aria-label="Account sections">
      {sections.map(([id, label], index) => (
        <button type="button" data-account-tab={id} aria-controls={`account-${id}`} aria-current={index === 0 ? "page" : undefined}>{label}</button>
      ))}
      <button type="button" class="client-room__signout" data-account-signout>Sign Out</button>
    </nav>

    <main class="client-room__content" aria-live="polite">
      <div class="client-room__notice" data-account-status role="status">Securely checking your account…</div>

      <section id="account-overview" data-account-panel="overview" tabindex="-1">
        <div class="panel-heading"><p>Overview</p><h2>Your private couture space</h2></div>
        <div class="stat-grid">
          <article><strong data-overview-saved>—</strong><span>saved inspirations</span></article>
          <article><strong data-overview-requests>—</strong><span>couture requests</span></article>
          <article><strong data-overview-appointments>—</strong><span>appointments</span></article>
          <article><strong data-overview-unread>—</strong><span>unread updates</span></article>
        </div>
        <div class="next-step">
          <p>Recommended next step</p><h3>Shape your private consultation</h3>
          <span>Complete your profile and save the pieces that express the mood, silhouette and craft you are drawn to.</span>
          <Button href="/design-your-outfit">Begin a Couture Request</Button>
        </div>
      </section>

      <section id="account-profile" data-account-panel="profile" tabindex="-1" hidden>
        <div class="panel-heading"><p>My Profile</p><h2>Preferences for a more personal conversation</h2></div>
        <form data-profile-form class="account-form">
          <label>Full name<input name="full_name" maxlength="120" autocomplete="name" /></label>
          <label>Email<input name="email" type="email" autocomplete="email" disabled /><small>Your verified account email cannot be changed here.</small></label>
          <label>Phone<input name="phone" maxlength="30" autocomplete="tel" /></label>
          <label>City<input name="city" maxlength="100" autocomplete="address-level2" /></label>
          <label>Country<input name="country" maxlength="100" autocomplete="country-name" /></label>
          <label>Location or timezone<input name="location" maxlength="140" autocomplete="off" /></label>
          <label>Upcoming event date<input name="upcoming_event_date" type="date" /></label>
          <label>Preferred contact<select name="preferred_contact_method"><option value="">Choose later</option><option value="whatsapp">WhatsApp</option><option value="email">Email</option><option value="phone">Phone</option></select></label>
          <label>Consultation method<select name="preferred_consultation_method"><option value="">Choose later</option><option value="whatsapp">WhatsApp</option><option value="video">Video</option><option value="studio">Studio</option></select></label>
          <fieldset><legend>Couture interests</legend><div class="choice-row">{["Bridal", "Reception", "Engagement", "Festive", "Custom Couture"].map((interest) => <label><input type="checkbox" name="couture_interests" value={interest} />{interest}</label>)}</div></fieldset>
          <p class="form-note">Profile image upload remains unavailable until private-file scanning, resizing and deletion controls are approved.</p>
          <button class="account-action" type="submit">Save Profile</button>
        </form>
      </section>

      <section id="account-saved" data-account-panel="saved" tabindex="-1" hidden>
        <div class="panel-heading"><p>Saved Inspirations</p><h2>A working wardrobe of ideas</h2><span>Guest saves on this device are merged into your account after sign-in. Notes and boards remain private to you.</span></div>
        <form class="board-form" data-board-form><label>New board name<input name="name" maxlength="80" required /></label><button class="account-action" type="submit">Create Board</button></form>
        <div class="board-filter" data-board-filter aria-label="Filter inspiration board"></div>
        <div class="inspiration-grid" data-inspiration-grid></div>
        <p class="empty-state" data-inspiration-empty hidden>No inspirations are saved yet. <a href="/collections">Explore the collection</a> and use the heart on a piece.</p>
      </section>

      <section id="account-requests" data-account-panel="requests" tabindex="-1" hidden>
        <div class="panel-heading"><p>Couture Requests</p><h2>Your atelier conversations</h2><span>Status is read from your submitted requests; no progress is simulated.</span></div>
        <div class="record-list" data-request-list></div><p class="empty-state" data-request-empty hidden>No submitted request is linked to this account yet. <a href="/design-your-outfit">Begin a request</a>.</p>
      </section>

      <section id="account-appointments" data-account-panel="appointments" tabindex="-1" hidden>
        <div class="panel-heading"><p>Appointments</p><h2>Consultation schedule</h2><span>Only availability configured by the Rangbastra team appears here.</span></div>
        <div class="record-list" data-appointment-list></div><p class="empty-state" data-appointment-empty hidden>No appointment is linked to your account.</p>
        <div class="availability"><h3>Available consultation windows</h3><div data-availability-list></div><p>Live booking is intentionally disabled until server-validated capacity and conflict controls are deployed.</p></div>
      </section>

      <section id="account-notifications" data-account-panel="notifications" tabindex="-1" hidden>
        <div class="panel-heading"><p>Notifications</p><h2>Private updates</h2></div><div class="record-list" data-notification-list></div><p class="empty-state" data-notification-empty hidden>You have no account updates.</p>
      </section>

      <section id="account-activity" data-account-panel="activity" tabindex="-1" hidden>
        <div class="panel-heading"><p>Reviews & activity</p><h2>Community features are not active</h2></div>
        <div class="boundary-card"><h3>No fabricated social activity</h3><p>Reviews, comments, stories and public counts will only be introduced with consent, reporting, moderation and abuse controls. This Preview does not create or imply customer activity.</p></div>
      </section>

      <section id="account-preferences" data-account-panel="preferences" tabindex="-1" hidden>
        <div class="panel-heading"><p>Preferences</p><h2>How the client room behaves</h2></div>
        <form data-preferences-form class="preference-list">
          <label><span><strong>Reduce motion</strong><small>Minimise interface movement in your account.</small></span><input type="checkbox" name="reduce_motion" /></label>
          <label><span><strong>Interface sound</strong><small>Reserved for future opt-in sound; no audio plays today.</small></span><input type="checkbox" name="sound_enabled" /></label>
          <label><span><strong>Email notifications</strong><small>Operational account and request updates.</small></span><input type="checkbox" name="email_notifications" /></label>
          <label><span><strong>In-app notifications</strong><small>Show private updates in this client room.</small></span><input type="checkbox" name="in_app_notifications" /></label>
          <label><span><strong>Consultation updates</strong><small>Updates about requests and appointments.</small></span><input type="checkbox" name="consultation_updates" /></label>
          <label><span><strong>Editorial updates</strong><small>Optional Rangbastra editorial news.</small></span><input type="checkbox" name="editorial_updates" /></label>
          <button class="account-action" type="submit">Save Preferences</button>
        </form>
      </section>

      <section id="account-privacy" data-account-panel="privacy" tabindex="-1" hidden>
        <div class="panel-heading"><p>Privacy & security</p><h2>Control of your account</h2></div>
        <div class="privacy-grid">
          <article><h3>Session</h3><p>Your current sign-in is managed by Supabase. Use Sign Out when leaving a shared device.</p><button class="account-action" type="button" data-account-signout>Sign Out</button></article>
          <article><h3>Account data</h3><p>Saved inspirations and preferences are private, owner-scoped records. Request data follows the retention policy under review.</p><a href="/privacy-policy">Read Privacy Policy</a></article>
          <article><h3>Deletion or correction</h3><p>Request account access, correction or deletion through the published contact channel. Automatic deletion is not presented until a verified server workflow exists.</p><a href="/contact">Contact Rangbastra</a></article>
        </div>
      </section>
    </main>
  </div>

  <script is:inline type="application/json" id="account-catalogue" set:html={JSON.stringify(catalogue)} />
</section>

<script>
  import { getSupabaseBrowserClient } from "../../lib/auth/supabaseBrowser";
  const root = document.querySelector<HTMLElement>("[data-account-platform]");
  if (root) {
    const status = root.querySelector<HTMLElement>("[data-account-status]");
    const catalogue = JSON.parse(document.querySelector("#account-catalogue")?.textContent || "[]");
    const productBySlug = new Map(catalogue.map((product: any) => [product.slug, product]));
    const state: any = { user: null, profile: null, preferences: null, boards: [], inspirations: [], requests: [], appointments: [], notifications: [], availability: [] };
    const say = (message: string, error = false) => { if (status) { status.textContent = message; status.dataset.error = String(error); } };
    const escapeHtml = (value: unknown) => String(value ?? "").replace(/[&<>'"]/g, (character) => ({"&":"&amp;","<":"&lt;",">":"&gt;","'":"&#39;",'"':"&quot;"}[character] || character));
    const formatDate = (value: string) => value ? new Intl.DateTimeFormat("en-IN", { dateStyle: "medium", timeStyle: value.includes("T") ? "short" : undefined }).format(new Date(value)) : "Not set";
    const supabase = getSupabaseBrowserClient();

    root.querySelectorAll<HTMLButtonElement>("[data-account-tab]").forEach((button) => button.addEventListener("click", () => {
      const key = button.dataset.accountTab;
      root.querySelectorAll("[data-account-tab]").forEach((item) => item.removeAttribute("aria-current")); button.setAttribute("aria-current", "page");
      root.querySelectorAll<HTMLElement>("[data-account-panel]").forEach((panel) => panel.hidden = panel.dataset.accountPanel !== key);
      root.querySelector<HTMLElement>(`[data-account-panel="${key}"]`)?.focus({ preventScroll: true });
      history.replaceState(null, "", `#${key}`);
    }));

    const setCount = (selector: string, value: number) => { const element = root.querySelector(selector); if (element) element.textContent = String(value); };
    const renderOverview = () => { setCount("[data-overview-saved]", state.inspirations.filter((item: any) => !item.removed_at).length); setCount("[data-overview-requests]", state.requests.length); setCount("[data-overview-appointments]", state.appointments.length); setCount("[data-overview-unread]", state.notifications.filter((item: any) => !item.read_at).length); };
    const renderRecords = () => {
      const requests = root.querySelector<HTMLElement>("[data-request-list]");
      if (requests) requests.innerHTML = state.requests.map((item: any) => `<article><div><span>${escapeHtml(item.reference_number)}</span><h3>${escapeHtml(item.product_name_snapshot)}</h3></div><p>${escapeHtml(item.status.replaceAll("_", " "))}</p><time>${formatDate(item.created_at)}</time></article>`).join("");
      root.querySelector<HTMLElement>("[data-request-empty]")!.hidden = state.requests.length > 0;
      const appointments = root.querySelector<HTMLElement>("[data-appointment-list]");
      if (appointments) appointments.innerHTML = state.appointments.map((item: any) => `<article><div><span>${escapeHtml(item.consultation_method)}</span><h3>${formatDate(item.availability_slots?.starts_at)}</h3></div><p>${escapeHtml(item.status)}</p></article>`).join("");
      root.querySelector<HTMLElement>("[data-appointment-empty]")!.hidden = state.appointments.length > 0;
      const slots = root.querySelector<HTMLElement>("[data-availability-list]");
      if (slots) slots.innerHTML = state.availability.length ? state.availability.map((item: any) => `<span>${formatDate(item.starts_at)} · ${escapeHtml(item.consultation_method)}</span>`).join("") : "<span>No configured windows are currently available.</span>";
      const notifications = root.querySelector<HTMLElement>("[data-notification-list]");
      if (notifications) notifications.innerHTML = state.notifications.map((item: any) => `<article class="${item.read_at ? "" : "is-unread"}"><div><span>${escapeHtml(item.kind)}</span><h3>${escapeHtml(item.title)}</h3><p>${escapeHtml(item.message)}</p></div>${item.read_at ? "" : `<button type="button" data-read-notification="${item.id}">Mark read</button>`}</article>`).join("");
      root.querySelector<HTMLElement>("[data-notification-empty]")!.hidden = state.notifications.length > 0;
    };

    const renderBoards = () => {
      const filter = root.querySelector<HTMLElement>("[data-board-filter]");
      if (filter) filter.innerHTML = `<button type="button" data-board="all" aria-pressed="true">All</button>${state.boards.map((board: any) => `<button type="button" data-board="${board.id}" aria-pressed="false">${escapeHtml(board.name)}</button>`).join("")}`;
      renderInspirations("all");
    };
    const renderInspirations = (boardId: string) => {
      const items = state.inspirations.filter((item: any) => !item.removed_at && (boardId === "all" || item.board_id === boardId));
      const grid = root.querySelector<HTMLElement>("[data-inspiration-grid]");
      if (grid) grid.innerHTML = items.map((item: any) => { const product: any = productBySlug.get(item.product_slug); if (!product) return ""; return `<article><a href="/products/${product.slug}"><img src="${escapeHtml(product.featuredImage)}" alt="${escapeHtml(product.name)}" loading="lazy"><span>${escapeHtml(product.category)}</span><h3>${escapeHtml(product.name)}</h3></a><label>Private note<textarea maxlength="500" data-note="${item.id}">${escapeHtml(item.note)}</textarea></label><label>Board<select data-move="${item.id}"><option value="">Unfiled</option>${state.boards.map((board: any) => `<option value="${board.id}" ${board.id === item.board_id ? "selected" : ""}>${escapeHtml(board.name)}</option>`).join("")}</select></label><button type="button" data-remove-inspiration="${item.id}">Remove</button></article>`; }).join("");
      root.querySelector<HTMLElement>("[data-inspiration-empty]")!.hidden = items.length > 0;
    };

    const mergeGuestWishlist = async () => {
      let slugs: string[] = []; try { slugs = JSON.parse(localStorage.getItem("rangbastraWishlist") || "[]"); } catch { slugs = []; }
      const valid = [...new Set(slugs)].map((slug) => productBySlug.get(slug)).filter(Boolean) as any[];
      if (!valid.length) return;
      const rows = valid.map((product) => ({ user_id: state.user.id, product_id: product.id, product_slug: product.slug, removed_at: null }));
      const { error } = await supabase.from("saved_inspirations").upsert(rows, { onConflict: "user_id,product_id", ignoreDuplicates: false });
      if (error) throw error;
      localStorage.removeItem("rangbastraWishlist"); window.dispatchEvent(new CustomEvent("rangbastra:wishlist-updated"));
    };

    const load = async () => {
      const { data: auth, error: authError } = await supabase.auth.getUser();
      if (authError || !auth.user) { location.assign(`/account/login?next=${encodeURIComponent("/account")}`); return; }
      state.user = auth.user;
      await mergeGuestWishlist();
      const [profile, preferences, boards, inspirations, requests, appointments, notifications, availability] = await Promise.all([
        supabase.from("profiles").select("full_name,email,phone,city,country,location,preferred_contact_method,preferred_consultation_method,couture_interests,upcoming_event_date").eq("id", auth.user.id).single(),
        supabase.from("user_preferences").select("*").eq("user_id", auth.user.id).maybeSingle(),
        supabase.from("inspiration_boards").select("id,name").order("created_at"),
        supabase.from("saved_inspirations").select("id,product_slug,board_id,note,removed_at,created_at").order("created_at", { ascending: false }),
        supabase.from("customization_requests").select("id,reference_number,product_name_snapshot,status,created_at").order("created_at", { ascending: false }),
        supabase.from("appointments").select("id,consultation_method,status,created_at,availability_slots(starts_at,ends_at)").order("created_at", { ascending: false }),
        supabase.from("in_app_notifications").select("id,kind,title,message,href,read_at,created_at").order("created_at", { ascending: false }),
        supabase.from("availability_slots").select("id,starts_at,ends_at,consultation_method,timezone").order("starts_at").limit(8),
      ]);
      const blocking = [profile, boards, inspirations, requests].find((result) => result.error);
      if (blocking?.error) throw blocking.error;
      state.profile = profile.data; state.preferences = preferences.data; state.boards = boards.data || []; state.inspirations = inspirations.data || []; state.requests = requests.data || []; state.appointments = appointments.data || []; state.notifications = notifications.data || []; state.availability = availability.data || [];
      const greeting = root.querySelector("[data-account-greeting]"); if (greeting) greeting.textContent = `Welcome${state.profile?.full_name ? `, ${state.profile.full_name}` : ""}. Your saved details are visible only in your authenticated account.`;
      const profileForm = root.querySelector<HTMLFormElement>("[data-profile-form]"); if (profileForm) { Object.entries(state.profile || {}).forEach(([key, value]) => { const field = profileForm.elements.namedItem(key); if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement) field.value = String(value ?? ""); }); (state.profile?.couture_interests || []).forEach((value: string) => { const input = profileForm.querySelector<HTMLInputElement>(`input[value="${CSS.escape(value)}"]`); if (input) input.checked = true; }); }
      const preferenceForm = root.querySelector<HTMLFormElement>("[data-preferences-form]"); if (preferenceForm) Object.entries(state.preferences || {}).forEach(([key, value]) => { const field = preferenceForm.elements.namedItem(key); if (field instanceof HTMLInputElement && field.type === "checkbox") field.checked = Boolean(value); });
      renderBoards(); renderRecords(); renderOverview(); say("Your account is ready.");
    };

    root.addEventListener("click", async (event) => {
      const target = event.target as HTMLElement;
      if (target.closest("[data-account-signout]")) { await supabase.auth.signOut(); location.assign("/"); return; }
      const board = target.closest<HTMLButtonElement>("[data-board]"); if (board) { root.querySelectorAll("[data-board]").forEach((item) => item.setAttribute("aria-pressed", "false")); board.setAttribute("aria-pressed", "true"); renderInspirations(board.dataset.board || "all"); }
      const remove = target.closest<HTMLButtonElement>("[data-remove-inspiration]"); if (remove) { const { error } = await supabase.from("saved_inspirations").update({ removed_at: new Date().toISOString() }).eq("id", remove.dataset.removeInspiration); if (error) say(error.message, true); else { state.inspirations.find((item: any) => item.id === remove.dataset.removeInspiration).removed_at = new Date().toISOString(); renderBoards(); renderOverview(); say("Inspiration removed. Your private note remains recoverable in the database retention window."); } }
      const read = target.closest<HTMLButtonElement>("[data-read-notification]"); if (read) { const read_at = new Date().toISOString(); const { error } = await supabase.from("in_app_notifications").update({ read_at }).eq("id", read.dataset.readNotification); if (!error) { state.notifications.find((item: any) => item.id === read.dataset.readNotification).read_at = read_at; renderRecords(); renderOverview(); } }
    });
    root.addEventListener("change", async (event) => { const select = (event.target as HTMLElement).closest<HTMLSelectElement>("[data-move]"); if (!select) return; const { error } = await supabase.from("saved_inspirations").update({ board_id: select.value || null }).eq("id", select.dataset.move); if (error) say(error.message, true); else { state.inspirations.find((item: any) => item.id === select.dataset.move).board_id = select.value || null; say("Board updated."); } });
    root.addEventListener("focusout", async (event) => { const note = (event.target as HTMLElement).closest<HTMLTextAreaElement>("[data-note]"); if (!note) return; const { error } = await supabase.from("saved_inspirations").update({ note: note.value.trim() || null }).eq("id", note.dataset.note); say(error ? error.message : "Private note saved.", Boolean(error)); });
    root.querySelector<HTMLFormElement>("[data-board-form]")?.addEventListener("submit", async (event) => { event.preventDefault(); const form = event.currentTarget as HTMLFormElement; const name = String(new FormData(form).get("name") || "").trim(); const { data, error } = await supabase.from("inspiration_boards").insert({ user_id: state.user.id, name }).select("id,name").single(); if (error) say(error.message, true); else { state.boards.push(data); form.reset(); renderBoards(); say("Board created."); } });
    root.querySelector<HTMLFormElement>("[data-profile-form]")?.addEventListener("submit", async (event) => { event.preventDefault(); const form = event.currentTarget as HTMLFormElement; const data = new FormData(form); const payload: any = {}; ["full_name","phone","city","country","location","upcoming_event_date","preferred_contact_method","preferred_consultation_method"].forEach((key) => payload[key] = String(data.get(key) || "").trim() || null); payload.couture_interests = data.getAll("couture_interests"); payload.updated_at = new Date().toISOString(); const { error } = await supabase.from("profiles").update(payload).eq("id", state.user.id); say(error ? error.message : "Profile saved.", Boolean(error)); });
    root.querySelector<HTMLFormElement>("[data-preferences-form]")?.addEventListener("submit", async (event) => { event.preventDefault(); const form = event.currentTarget as HTMLFormElement; const fields = ["reduce_motion","sound_enabled","email_notifications","in_app_notifications","consultation_updates","editorial_updates"]; const payload: any = { user_id: state.user.id, updated_at: new Date().toISOString() }; fields.forEach((key) => { const field = form.elements.namedItem(key) as HTMLInputElement; payload[key] = field.checked; }); const { error } = await supabase.from("user_preferences").upsert(payload); if (!error) document.documentElement.dataset.accountReduceMotion = String(payload.reduce_motion); say(error ? error.message : "Preferences saved.", Boolean(error)); });
    const initial = location.hash.slice(1); if (["overview","profile","saved","requests","appointments","notifications","activity","preferences","privacy"].includes(initial)) root.querySelector<HTMLButtonElement>(`[data-account-tab="${initial}"]`)?.click();
    load().catch((error) => say(error instanceof Error ? error.message : "Account data could not be loaded.", true));
  }
</script>

<style>
  .client-room{padding:clamp(8rem,14vw,12rem) 0 5rem;color:var(--text-secondary)}.client-room__header{max-width:58rem;padding-bottom:clamp(2rem,5vw,5rem)}.client-room__eyebrow,.panel-heading>p,.record-list span{color:var(--text-muted);font-size:var(--caption);font-weight:var(--weight-semibold);letter-spacing:var(--tracking-label);text-transform:uppercase}.client-room h1,.panel-heading h2{color:var(--text-primary);font-family:var(--font-display);font-weight:var(--weight-light);line-height:1}.client-room h1{max-width:12ch;margin:.8rem 0 1.5rem;font-size:clamp(3.4rem,8vw,8.5rem)}.client-room__layout{display:grid;grid-template-columns:minmax(13rem,.28fr) minmax(0,1fr);gap:clamp(2rem,6vw,6rem);align-items:start}.client-room__nav{position:sticky;top:7rem;display:grid;border-block:1px solid var(--border-default)}.client-room__nav button{padding:1rem .2rem;border:0;border-bottom:1px solid var(--border-default);background:transparent;color:var(--text-muted);font:inherit;text-align:left;cursor:pointer}.client-room__nav button[aria-current=page]{color:var(--text-primary);padding-left:1rem;border-left:2px solid var(--color-accent,#c6a972)}.client-room__nav .client-room__signout{margin-top:1rem;color:var(--text-secondary)}.client-room__content{min-width:0}.client-room__notice{margin-bottom:1.5rem;padding:.85rem 1rem;border:1px solid var(--border-default);font-size:var(--body-sm)}.client-room__notice[data-error=true]{border-color:#9d5757;color:#e1aaaa}.panel-heading{display:grid;gap:.8rem;margin-bottom:2rem}.panel-heading h2{font-size:clamp(2.5rem,5vw,5.5rem)}.panel-heading span{max-width:52rem}.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border-default);border:1px solid var(--border-default)}.stat-grid article{display:grid;gap:.4rem;padding:clamp(1.2rem,3vw,2.5rem);background:var(--surface-canvas)}.stat-grid strong{color:var(--text-primary);font:var(--weight-light) clamp(2.5rem,5vw,5rem)/1 var(--font-display)}.stat-grid span{font-size:var(