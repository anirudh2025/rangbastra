<section class="product-activity" data-product-activity aria-labelledby="activity-title">
  <header><p>Reviews &amp; Activity</p><h1 id="activity-title">Your Product Activity</h1><span>Only your own contributions, ratings and likes appear here.</span></header>
  <p class="activity-status" role="status" data-activity-status>Securely loading your activity…</p>
  <section><h2>Comments &amp; private notes</h2><div data-activity-comments></div><p data-empty-comments hidden>No comments or private notes yet.</p></section>
  <section><h2>Your ratings</h2><div data-activity-ratings></div><p data-empty-ratings hidden>No products rated yet.</p></section>
  <section><h2>Liked pieces</h2><div data-activity-likes></div><p data-empty-likes hidden>No liked pieces yet.</p></section>
</section>

<script>
  import { getSupabaseBrowserClient } from "../../lib/auth/supabaseBrowser";
  const root=document.querySelector<HTMLElement>("[data-product-activity]");
  if(root){const supabase=getSupabaseBrowserClient(),status=root.querySelector<HTMLElement>("[data-activity-status]")!;const make=(tag:string,text:string,className="")=>{const node=document.createElement(tag);node.textContent=text;if(className)node.className=className;return node};const card=(href:string,title:string,meta:string,body?:string)=>{const article=document.createElement("article"),link=document.createElement("a");link.href=href;link.append(make("h3",title),make("span",meta));article.append(link);if(body)article.append(make("p",body));return article};(async()=>{const auth=await supabase.auth.getUser();if(!auth.data.user){location.assign(`/account/login?next=${encodeURIComponent("/account/activity")}`);return}const result=await supabase.rpc("get_my_product_activity");if(result.error){status.textContent=result.error.message;return}const data=result.data??{},comments=root.querySelector<HTMLElement>("[data-activity-comments]")!,ratings=root.querySelector<HTMLElement>("[data-activity-ratings]")!,likes=root.querySelector<HTMLElement>("[data-activity-likes]")!;(data.comments??[]).forEach((item:any)=>{const article=card(`/products/${item.productSlug}`,item.productTitle,`${item.type==="private"?"Private note":`Public · ${item.status}`} · ${new Date(item.createdAt).toLocaleDateString("en-IN")}`,item.body);if(item.reason)article.append(make("small",item.reason));(item.replies??[]).forEach((reply:any)=>{const aside=make("aside","", "official-reply");aside.append(make("strong","Rangbastra — Official reply"),make("p",reply.body));article.append(aside)});comments.append(article)});(data.ratings??[]).forEach((item:any)=>ratings.append(card(`/products/${item.productSlug}`,item.productTitle,`${item.rating} / 5`)));(data.likes??[]).forEach((item:any)=>likes.append(card(`/products/${item.productSlug}`,item.productTitle,"Liked piece")));root.querySelector<HTMLElement>("[data-empty-comments]")!.hidden=(data.comments??[]).length>0;root.querySelector<HTMLElement>("[data-empty-ratings]")!.hidden=(data.ratings??[]).length>0;root.querySelector<HTMLElement>("[data-empty-likes]")!.hidden=(data.likes??[]).length>0;status.textContent="Your activity is ready."})()}
</script>

<style>
  .product-activity{display:grid;gap:var(--space-9);padding:clamp(8rem,14vw,12rem) 0 var(--space-10)}header{display:grid;gap:var(--space-3);max-width:60rem}header>p{color:var(--cocoa-300);font-size:var(--caption);letter-spacing:var(--tracking-label);text-transform:uppercase}h1{font-family:var(--font-display);font-size:clamp(3rem,8vw,8rem);font-weight:var(--weight-light);line-height:.95}.product-activity>section{display:grid;gap:var(--space-4)}h2{font-family:var(--font-display);font-size:clamp(2rem,4vw,4rem);font-weight:var(--weight-light)}[data-activity-comments],[data-activity-ratings],[data-activity-likes]{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:var(--space-4)}article{display:grid;align-content:start;gap:var(--space-3);padding:var(--space-5);border:1px solid var(--border-default)}article a{display:grid;gap:var(--space-2)}article h3{font-family:var(--font-display);font-size:1.8rem}article span,article small{color:var(--text-muted);font-size:var(--caption);text-transform:capitalize}.official-reply{display:grid;gap:var(--space-2);padding:var(--space-4);border-left:2px solid var(--cocoa-300);background:rgba(var(--cocoa-rgb),.08)}.official-reply strong{color:var(--cocoa-300)}[hidden]{display:none!important}@media(max-width:900px){[data-activity-comments],[data-activity-ratings],[data-activity-likes]{grid-template-columns:1fr}}
</style>
