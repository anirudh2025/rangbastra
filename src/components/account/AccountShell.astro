---
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";
import Label from "../primitives/Label.astro";
import GoogleG from "../icons/brands/GoogleG.astro";

interface Props {
  mode: "dashboard" | "login" | "signup";
}

const { mode } = Astro.props;
---

<section class="account-room" aria-labelledby="account-heading">
  <header class="portal-header">
    <a href="/" class="portal-wordmark" aria-label="Rangbastra home"
      >Rangbastra</a
    ><span id="account-heading">Private Client Portal</span>
  </header>

  <div class="account-room__panel">
    {
      mode === "dashboard" ? (
        <div class="dashboard-shell" data-account-dashboard>
          <nav class="dashboard-nav" aria-label="Client portal">
            <>
              <a class="is-active" href="#overview">
                Overview
              </a>
              <a href="#profile">My Profile</a>
              <a href="/wishlist">Saved Inspirations</a>
              <a href="#requests">Couture Requests</a>
              <a href="#appointments">Appointments</a>
              <a href="#settings">Account Settings</a>
              <button type="button" data-signout hidden>
                Sign Out
              </button>
            </>
          </nav>
          <div class="dashboard-panel" id="overview">
            <div class="dashboard-heading">
              <>
                <img data-account-avatar alt="" hidden />
                <Icon name="account" size={28} />
                <div>
                  <>
                    <small>Overview</small>
                    <h2>Welcome to your private room.</h2>
                  </>
                </div>
              </>
            </div>
            <p data-account-identity>
              Sign in or create an account to enter your private dashboard.
            </p>
            <div class="portal-metrics">
              <>
                <a href="/wishlist">
                  <>
                    <strong>Saved</strong>
                    <span>Inspirations</span>
                  </>
                </a>
                <span>
                  <>
                    <strong>—</strong>
                    <span>Active requests</span>
                  </>
                </span>
                <span>
                  <>
                    <strong>—</strong>
                    <span>Upcoming consultation</span>
                  </>
                </span>
              </>
            </div>
            <form class="profile-form" data-profile-form hidden>
              <label>
                Full name
                <input name="full_name" autocomplete="name" />
              </label>
              <label>
                Phone / WhatsApp
                <input name="phone" type="tel" autocomplete="tel" />
              </label>
              <label>
                City
                <input name="city" autocomplete="address-level2" />
              </label>
              <label>
                Country
                <input name="country" autocomplete="country-name" />
              </label>
              <label>
                Preferred contact
                <input name="preferred_contact_method" />
              </label>
              <label class="consent">
                <input name="marketing_consent" type="checkbox" /> Optional
                marketing updates
              </label>
              <label>
                Sound volume
                <input
                  type="range"
                  min="20"
                  max="100"
                  value="72"
                  data-sound-volume
                />
              </label>
              <>
                <Button type="submit">Save Profile</Button>
                <p data-profile-note role="status" />
              </>
            </form>
            <div class="dashboard-actions">
              <Button href="/wishlist" variant="cherry" sparkle={false}>
                <Label icon="heart">Open Wishlist</Label>
              </Button>
              <Button href="/design-your-outfit">
                <Label icon="sketch">Design Your Outfit</Label>
              </Button>
              <Button
                href="/account/login"
                class="account-login"
                variant="neutral"
                sparkle={false}
              >
                <Label icon="account">Sign In</Label>
              </Button>
              <Button
                href="/account/signup"
                class="account-login"
                variant="neutral"
                sparkle={false}
              >
                <Label icon="userPlus">Create Account</Label>
              </Button>
            </div>
          </div>
        </div>
      ) : (
        <form class="account-form" data-account-form data-mode={mode}>
          <div class="auth-tabs" aria-label="Account access">
            <>
              <a
                class:list={[mode === "login" && "is-active"]}
                href="/account/login"
              >
                Sign In
              </a>
              <a
                class:list={[mode === "signup" && "is-active"]}
                href="/account/signup"
              >
                Create Account
              </a>
            </>
          </div>
          <div>
            <>
              <small>Secure workspace</small>
              <h2>{mode === "login" ? "Sign in" : "Create your account"}</h2>
            </>
          </div>

          {mode === "signup" && (
            <label>
              Name
              <input name="name" autocomplete="name" required />
            </label>
          )}

          {mode === "signup" && (
            <label>
              Phone / WhatsApp (optional)
              <input name="phone" type="tel" autocomplete="tel" />
            </label>
          )}

          <label>
            Email
            <input name="email" type="email" autocomplete="email" required />
          </label>

          <label>
            Password
            <span class="password-field">
              <>
                <input
                  name="password"
                  type="password"
                  autocomplete={
                    mode === "login" ? "current-password" : "new-password"
                  }
                  required
                  minlength={mode === "signup" ? 8 : undefined}
                />
                <button
                  type="button"
                  data-password-toggle
                  aria-label="Show password"
                >
                  Show
                </button>
              </>
            </span>
          </label>

          {mode === "signup" && (
            <label>
              Confirm password
              <span class="password-field">
                <input
                  name="confirmPassword"
                  type="password"
                  autocomplete="new-password"
                  minlength="8"
                  required
                />
                <button
                  type="button"
                  data-password-toggle
                  aria-label="Show password"
                >
                  Show
                </button>
              </span>
            </label>
          )}
          {mode === "login" && (
            <label class="consent">
              <input name="remember" type="checkbox" /> Remember this session
            </label>
          )}
          {mode === "signup" && (
            <>
              <label class="consent">
                <input name="legalConsent" type="checkbox" required /> I agree
                to the <a href="/terms-and-conditions">Terms</a> and{" "}
                <a href="/privacy-policy">Privacy Policy</a>.
              </label>
              <label class="consent">
                <input name="marketingConsent" type="checkbox" /> Send
                occasional Rangbastra updates. Optional.
              </label>
            </>
          )}

          {mode === "login" && (
            <button class="forgot-link" type="button" data-forgot>
              Forgot password?
            </button>
          )}

          <Button type="submit" variant="neutral" sparkle={false}>
            <Label icon={mode === "login" ? "account" : "userPlus"}>
              {mode === "login" ? "Sign In" : "Create Account"}
            </Label>
          </Button>

          <Button
            type="button"
            variant="google"
            sparkle={false}
            class="google-auth"
          >
            <span class="google-icon">
              <GoogleG />
            </span>
            <span>Continue with Google</span>
          </Button>

          <p class="form-note" data-account-note>
            {mode === "login"
              ? "Use your verified email to continue."
              : "We will email a secure verification link."}
          </p>

          <a
            class="switch-link"
            href={mode === "login" ? "/account/signup" : "/account/login"}
          >
            {mode === "login"
              ? "Create private access"
              : "Already have access?"}
          </a>
        </form>
      )
    }
  </div>
</section>

<script>
  import { initAccountExperience } from "../../lib/auth/accountClient";
  initAccountExperience();
  document.addEventListener("astro:page-load", initAccountExperience);
  /* Legacy client removed from execution after migration to the shared Supabase client.
  // @ts-nocheck -- Supabase REST responses are runtime-validated and intentionally schema-flexible here.
  import { createClient } from "@supabase/supabase-js";
  const config = document.querySelector<HTMLElement>("[data-account-config]"),
    url = config?.dataset.url ?? "",
    key = config?.dataset.key ?? "";
  const sessionKey = "legacySessionStorageDisabled";
  const requestedNext = new URLSearchParams(location.search).get("next");
  const safeNext = requestedNext?.startsWith("/") && !requestedNext.startsWith("//")
    ? requestedNext
    : "/account";
  const supabase =
    url && key
      ? createClient(url, key, {
          auth: {
            flowType: "pkce",
            persistSession: true,
            detectSessionInUrl: true,
          },
        })
      : null;
  const request = async (path: string, options: RequestInit = {}) => {
    if (!url || !key)
      throw new Error(
        "Add Supabase public credentials to activate your client room.",
      );
    const response = await fetch(`${url}${path}`, {
      ...options,
      headers: {
        apikey: key,
        "Content-Type": "application/json",
        ...(options.headers ?? {}),
      },
    });
    const result = await response.json().catch(() => ({}));
    if (!response.ok)
      throw new Error(
        result.msg ??
          result.error_description ??
          result.message ??
          "Unable to complete this request.",
      );
    return result;
  };
  document
    .querySelectorAll<HTMLFormElement>("[data-account-form]")
    .forEach((form) => {
      let submitting = false;
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (submitting) return;
        const note = form.querySelector<HTMLElement>("[data-account-note]")!,
          data = new FormData(form),
          email = String(data.get("email") ?? ""),
          password = String(data.get("password") ?? "");
        if (form.dataset.mode === "signup" && password !== String(data.get("confirmPassword") ?? "")) { note.textContent = "Passwords must match."; form.querySelector<HTMLInputElement>("[name=confirmPassword]")?.focus(); return; }
        if (form.dataset.mode === "signup" && password.length < 8) { note.textContent = "Use at least 8 characters for your password."; return; }
        submitting = true;
        const submit = form.querySelector<HTMLButtonElement>("button[type=submit]");
        if (submit) submit.disabled = true;
        note.textContent = "Preparing secure access…";
        try {
          if (form.dataset.mode === "signup") {
            await request("/auth/v1/signup", {
              method: "POST",
              body: JSON.stringify({
                email,
                password,
                data: {
                  full_name: String(data.get("name") ?? ""),
                  phone: String(data.get("phone") ?? ""),
                  marketing_consent: data.get("marketingConsent") === "on",
                },
              }),
            });
            note.textContent =
              "Check your email to verify and activate your client room.";
          } else {
            const session = await request(
              "/auth/v1/token?grant_type=password",
              { method: "POST", body: JSON.stringify({ email, password }) },
            );
            localStorage.setItem(sessionKey, JSON.stringify(session));
            window.RangbastraAudio?.portal();
            location.href = safeNext;
          }
        } catch (error) {
          note.textContent =
            error instanceof Error ? error.message : "Unable to continue.";
          submitting = false;
          if (submit) submit.disabled = false;
        }
      });
    });
  document.querySelectorAll<HTMLButtonElement>("[data-password-toggle]").forEach((button) => button.addEventListener("click", () => { const input = button.parentElement?.querySelector<HTMLInputElement>("input"); if (!input) return; const show = input.type === "password"; input.type = show ? "text" : "password"; button.textContent = show ? "Hide" : "Show"; button.setAttribute("aria-label", `${show ? "Hide" : "Show"} password`); }));
  document.querySelector<HTMLInputElement>("[data-sound-volume]")?.addEventListener("input",event=>window.RangbastraAudio?.setVolume(Number((event.currentTarget as HTMLInputElement).value)/100));
  document
    .querySelector<HTMLElement>("[data-forgot]")
    ?.addEventListener("click", async () => {
      const form = document.querySelector<HTMLFormElement>(
          "[data-account-form]",
        )!,
        email = String(new FormData(form).get("email") ?? ""),
        note = form.querySelector<HTMLElement>("[data-account-note]")!;
      if (!email) {
        note.textContent = "Enter your email first.";
        return;
      }
      try {
        await request("/auth/v1/recover", {
          method: "POST",
          body: JSON.stringify({
            email,
            redirect_to: `${location.origin}/account/login`,
          }),
        });
        note.textContent = "A password recovery link is on its way.";
      } catch (error) {
        note.textContent =
          error instanceof Error
            ? error.message
            : "Unable to send recovery email.";
      }
    });
  document
    .querySelector<HTMLButtonElement>(".google-auth")
    ?.addEventListener("click", async (event) => {
      const button = event.currentTarget as HTMLButtonElement;
      const note = document.querySelector<HTMLElement>("[data-account-note]")!;
      if (!supabase) {
        note.textContent =
          "Add Supabase public credentials to activate Google sign-in.";
        return;
      }
      button.disabled = true;
      note.textContent = "Opening Google’s secure account chooser…";
      const redirectTo = `${location.origin}/account/oauth-callback`;
      const mobile = matchMedia("(max-width:700px),(pointer:coarse)").matches;
      const { data, error } = await supabase.auth.legacyOAuthDisabled({
        provider: "google",
        options: { redirectTo, skipBrowserRedirect: true },
      });
      if (error || !data.url) {
        button.disabled = false;
        note.textContent = error?.message ?? "Google sign-in could not begin.";
        return;
      }
      if (mobile) {
        location.assign(data.url);
        return;
      }
      const popup = window.open(
        data.url,
        "rangbastra-google-auth",
        "popup=yes,width=520,height=680,resizable=yes,scrollbars=yes",
      );
      if (!popup) {
        location.assign(data.url);
        return;
      }
      const listener = (message: MessageEvent) => {
        if (
          message.origin !== location.origin ||
          message.source !== popup ||
          message.data !== "rangbastra-oauth-complete"
        )
          return;
        window.removeEventListener("message", listener);
        popup.close();
        location.href = safeNext;
      };
      window.addEventListener("message", listener);
      const timer = window.setInterval(() => {
        if (!popup.closed) return;
        clearInterval(timer);
        window.removeEventListener("message", listener);
        button.disabled = false;
        note.textContent = "Google sign-in was closed before completion.";
      }, 500);
    });

  if (supabase && !localStorage.getItem(sessionKey)) {
    supabase.auth.getSession().then(({ data }) => {
      if (!data.session) return;
      localStorage.setItem(sessionKey, JSON.stringify(data.session));
      if (location.pathname === "/account") location.reload();
    });
  }

  const dashboard = document.querySelector<HTMLElement>(
    "[data-account-dashboard]",
  );
  if (dashboard) {
    let session: any = null;
    try {
      session = JSON.parse(localStorage.getItem(sessionKey) ?? "null");
    } catch {}
    const profileForm = dashboard.querySelector<HTMLFormElement>(
        "[data-profile-form]",
      ),
      identity = dashboard.querySelector<HTMLElement>(
        "[data-account-identity]",
      ),
      signout = dashboard.querySelector<HTMLButtonElement>("[data-signout]"),
      login = dashboard.querySelector<HTMLElement>(".account-login");
    if (session?.access_token && profileForm) {
      const auth = { Authorization: `Bearer ${session.access_token}` };
      request("/auth/v1/user", { headers: auth })
        .then(async (user) => {
          identity!.textContent = user.email;
          profileForm.hidden = false;
          signout!.hidden = false;
          login?.setAttribute("hidden", "");
          const profiles = await request(
            `/rest/v1/profiles?id=eq.${user.id}&select=*`,
            { headers: auth },
          );
          const profile = profiles[0] ?? {};
          Object.entries(profile).forEach(([name, value]) => {
            const field = profileForm.elements.namedItem(name);
            if (field instanceof HTMLInputElement) {
              if (field.type === "checkbox") field.checked = Boolean(value);
              else field.value = String(value ?? "");
            }
          });
        })
        .catch(() => {
          localStorage.removeItem(sessionKey);
        });
      profileForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        const data = new FormData(profileForm),
          payload = Object.fromEntries(data.entries());
        payload.marketing_consent = data.get("marketing_consent") === "on";
        const note = profileForm.querySelector<HTMLElement>(
          "[data-profile-note]",
        )!;
        try {
          await request(`/rest/v1/profiles?id=eq.${session.user.id}`, {
            method: "PATCH",
            headers: { ...auth, Prefer: "return=minimal" },
            body: JSON.stringify(payload),
          });
          note.textContent = "Profile updated securely.";
        } catch (error) {
          note.textContent =
            error instanceof Error
              ? error.message
              : "Unable to update profile.";
        }
      });
      signout?.addEventListener("click", async () => {
        window.RangbastraAudio?.signout();
        try {
          await request("/auth/v1/logout", { method: "POST", headers: auth });
        } catch {}
        localStorage.removeItem(sessionKey);
        location.href = "/account/login";
      });
    }
  }
  */
</script>

<style>
  .account-room {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(20rem, 0.48fr);
    gap: clamp(var(--space-6), 7vw, var(--space-11));
    align-items: center;
    min-height: min(52rem, calc(100svh - var(--navbar-height)));
    padding-top: clamp(var(--space-12), 15vw, var(--space-14));
  }

  .account-room__statement {
    display: grid;
    gap: var(--space-5);
    max-width: 48rem;
  }

  h1 {
    max-width: 12ch;
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 8rem);
    font-weight: var(--weight-light);
    letter-spacing: var(--tracking-heading);
    line-height: 0.94;
    text-wrap: balance;
  }

  p {
    max-width: var(--measure-sm);
    color: var(--text-secondary);
    font-size: var(--body-lg);
    line-height: var(--leading-body);
  }

  .account-room__keys {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-top: var(--space-4);
  }

  .account-room__keys span {
    border-bottom: 1px solid var(--cocoa-border-soft);
    color: var(--text-muted);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-caption);
    text-transform: uppercase;
  }

  .account-room__panel {
    min-height: clamp(28rem, 42vw, 38rem);
    padding: clamp(var(--space-5), 5vw, var(--space-8));
    border: 1px solid var(--cocoa-border-soft);
    background:
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.055),
        transparent 24%,
        rgba(106, 78, 66, 0.08)
      ),
      rgba(255, 255, 255, 0.025);
    box-shadow: var(--shadow-premium), var(--shadow-inset);
  }

  .dashboard-panel,
  .account-form {
    display: grid;
    align-content: center;
    gap: var(--space-4);
    height: 100%;
  }

  h2 {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 4rem);
    font-weight: var(--weight-light);
    line-height: var(--leading-title);
  }

  .dashboard-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-top: var(--space-2);
  }
  .profile-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  .profile-form[hidden] {
    display: none;
  }
  .profile-form .button,
  .profile-form [data-profile-note] {
    grid-column: 1/-1;
  }
  .consent {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .consent input {
    min-height: auto;
  }
  .signout {
    min-height: 44px;
    color: var(--cocoa-300);
  }

  label {
    display: grid;
    gap: var(--space-2);
    color: var(--text-muted);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  input {
    min-height: 3.75rem;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    background: rgba(0, 0, 0, 0.32);
    color: var(--text-primary);
    font: inherit;
    padding-inline: var(--space-4);
  }

  input:focus-visible {
    border-color: var(--cocoa-border-strong);
    outline: 1px solid var(--focus-ring);
    outline-offset: var(--space-1);
  }

  .forgot-link,
  .switch-link {
    width: fit-content;
    color: var(--sand-200);
    font-size: var(--body-sm);
    text-decoration: none;
  }

  .form-note {
    font-size: var(--body-sm);
  }

  @media (max-width: 900px) {
    .account-room {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .account-room__panel {
      min-height: auto;
    }
  }
</style>
<style>
  .account-room {
    grid-template-columns: 1fr;
    align-content: center;
    min-height: calc(100svh - var(--navbar-height));
    padding: clamp(6.5rem, 10vw, 9rem) 0 var(--space-8);
  }
  .portal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--cocoa-border-soft);
    color: var(--text-muted);
    font-size: var(--caption);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .portal-wordmark {
    color: var(--ivory-100);
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    text-transform: none;
  }
  .account-room__panel {
    width: min(100%, 64rem);
    min-height: 0;
    margin-inline: auto;
    padding: clamp(var(--space-5), 5vw, var(--space-8));
    border-radius: var(--radius-lg);
    background: #050505;
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.55);
  }
  .account-form {
    width: min(100%, 32rem);
    margin-inline: auto;
  }
  .auth-tabs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--cocoa-border-soft);
  }
  .auth-tabs a {
    min-height: 48px;
    padding: var(--space-3);
    color: var(--text-muted);
    text-align: center;
  }
  .auth-tabs a.is-active {
    border-bottom: 2px solid rgb(var(--cocoa-rgb));
    color: var(--ivory-100);
  }
  .account-form > div > small,
  .dashboard-heading small {
    color: var(--cocoa-300);
    font-size: var(--caption);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .password-field {
    display: flex;
    align-items: center;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    background: #080808;
  }
  .password-field input {
    flex: 1;
    border: 0;
    background: transparent;
  }
  .password-field button {
    min-width: 52px;
    min-height: 44px;
    color: var(--cocoa-300);
    font-size: var(--caption);
  }
  .dashboard-shell {
    display: grid;
    grid-template-columns: 14rem minmax(0, 1fr);
    gap: var(--space-7);
  }
  .dashboard-nav {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--cocoa-border-soft);
    padding-right: var(--space-4);
  }
  .dashboard-nav a,
  .dashboard-nav button {
    display: flex;
    min-height: 46px;
    align-items: center;
    padding: 0 var(--space-3);
