<dialog class="auth-action-dialog" data-auth-action-dialog aria-labelledby="auth-action-title" aria-describedby="auth-action-copy">
  <div><h2 id="auth-action-title">Continue in your private couture account</h2><p id="auth-action-copy" data-auth-action-copy>Sign in is required so this private action can be saved securely and returned to you.</p><div><button type="button" data-auth-action-close>Stay Here</button><a href="/account/login" data-auth-action-login>Sign In</a><a href="/account/signup" data-auth-action-signup>Create Account</a></div></div>
</dialog>

<script>
  import { getSupabaseBrowserClient } from "../../lib/auth/supabaseBrowser";
  const dialog=document.querySelector<HTMLDialogElement>("[data-auth-action-dialog]");
  if(dialog){let intended="/account";let trigger:HTMLElement|null=null;const protectedPath=(href:string)=>/^\/products\/[^/]+\/customize(?:[?#]|$)/.test(href)||/^\/design-your-outfit(?:[?#]|$)/.test(href)||/^\/account(?:[?#]|$)/.test(href);document.addEventListener("click",async event=>{const link=(event.target as HTMLElement).closest<HTMLAnchorElement>("a[href]");if(!link||!protectedPath(link.getAttribute("href")||""))return;if(link.closest("[data-auth-signed-in]"))return;event.preventDefault();intended=new URL(link.href,location.href).pathname+new URL(link.href,location.href).search+new URL(link.href,location.href).hash;trigger=link;try{const session=await getSupabaseBrowserClient().auth.getSession();if(session.data.session){location.assign(intended);return}}catch{}const next=encodeURIComponent(intended);dialog.querySelector<HTMLAnchorElement>("[data-auth-action-login]")!.href=`/account/login?next=${next}`;dialog.querySelector<HTMLAnchorElement>("[data-auth-action-signup]")!.href=`/account/signup?next=${next}`;dialog.showModal()});dialog.querySelector("[data-auth-action-close]")?.addEventListener("click",()=>dialog.close());dialog.addEventListener("close",()=>trigger?.focus())}
</script>

<style>
  .auth-action-dialog{max-width:min(34rem,calc(100% - 2rem));padding:0;border:1px solid var(--cocoa-border);border-radius:var(--radius-lg);background:#050403;color:var(--text-secondary)}.auth-action-dialog::backdrop{background:rgba(0,0,0,.82);backdrop-filter:blur(7px)}.auth-action-dialog>div{display:grid;gap:var(--space-4);padding:clamp(var(--space-5),5vw,var(--space-8))}.auth-action-dialog h2{color:var(--text-primary);font-family:var(--font-display);font-size:clamp(2rem,5vw,3.2rem);font-weight:var(--weight-light);line-height:1}.auth-action-dialog p{line-height:var(--leading-body)}.auth-action-dialog div div{display:flex;flex-wrap:wrap;justify-content:flex-end;gap:var(--space-3)}.auth-action-dialog button,.auth-action-dialog a{display:inline-flex;min-height:44px;align-items:center;padding-inline:var(--space-4);border:1px solid var(--cocoa-border);border-radius:var(--radius-md);background:transparent;color:var(--text-primary)}.auth-action-dialog a:last-child{background:rgba(var(--cocoa-rgb),.18)}.auth-action-dialog :is(button,a):focus-visible{outline:2px solid var(--focus-ring);outline-offset:3px}
</style>
