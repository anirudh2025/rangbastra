---
import Eyebrow from "../primitives/Eyebrow.astro";
---

<header class="bride-stories-header">
  <Eyebrow>Bride Stories</Eyebrow>

  <h2>
    <span class="title-intro">Moments Woven Into</span>
    <span class="title-statement title-highlight">Beautiful Memories</span>
  </h2>

  <p>
    A quiet editorial archive of brides, celebrations and the pieces that
    became part of their most meaningful day.
  </p>
</header>

<style>
  .bride-stories-header {
    display: grid;
    gap:var(--bride-stories-header-gap,var(--editorial-header-gap));
    max-width: var(--bride-stories-header-width, var(--measure-md));
  }

  h2 {
    display: grid;
    gap:var(--bride-stories-title-gap,var(--editorial-title-gap));
    max-width: var(--bride-stories-title-width, min(100%, 54rem));
    color: var(--text-primary);
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    text-wrap: balance;
  }

  .title-intro {
    color: var(--text-primary);
    font-size: var(--section-heading-intro);
    letter-spacing: var(--tracking-heading);
    line-height: 1.18;
  }

  .title-statement {
    background: var(--gradient-primary);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    font-size: var(--section-heading-statement);
    letter-spacing: var(--tracking-heading);
    line-height: 1.12;
    padding-bottom: .08em;
    width:max-content;
    max-width:100%;
    white-space:nowrap;
    font-size:clamp(2.45rem,7.4vw,7.4rem);
    letter-spacing:var(--title-tracking-premium);
  }

  p {
    max-width: var(--bride-stories-copy-width, var(--measure-sm));
    color: var(--text-secondary);
    font-size: var(--body-lg);
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  @media (max-width: 767px) {
    .bride-stories-header {
      gap: var(--space-4);
    }

    .title-intro {
      font-size: var(--section-heading-intro-mobile);
    }

    .title-statement {
      font-size: var(--section-heading-statement-mobile);
    }
  }
</style>
