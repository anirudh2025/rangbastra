---
import { atelierExperience } from "../../data/atelierExperience";
import AtelierCard from "./AtelierCard.astro";
---

<div class="atelier-timeline" data-scroll-timeline>
  {
    atelierExperience.map((item, index) => (
      <div
        class:list={[
          "timeline-item",
          index % 2 === 0 ? "timeline-item--left" : "timeline-item--right",
        ]}
      >
        <span
          class="atelier-milestone"
          data-timeline-milestone
          aria-hidden="true"
        />
        <AtelierCard
          step={item.id}
          title={item.title}
          description={item.description}
        />
      </div>
    ))
  }
</div>

<script>
  import { initTimelineProgress } from "../../lib/animations/timelineProgress";
  initTimelineProgress();
  document.addEventListener("astro:page-load", initTimelineProgress);
</script>

<style>
  .atelier-timeline {
    position: relative;
    display: grid;
    gap: clamp(var(--space-8), 7vw, var(--space-12));
  }

  .atelier-timeline::before {
    content: "";
    position: absolute;
    inset-block: clamp(var(--space-8), 9vw, var(--space-12));
    left: 50%;
    width: 1px;
    background: rgba(var(--cocoa-rgb), 0.26);
    box-shadow: none;
    transform: translateX(-50%);
  }
  .atelier-timeline::after {
    content: "";
    position: absolute;
    inset-block: clamp(var(--space-8), 9vw, var(--space-12));
    left: 50%;
    width: 1.5px;
    background: rgb(var(--cocoa-rgb));
    box-shadow: 0 0 4px var(--cocoa-glow-soft);
    transform: translate3d(-50%, 0, 0) scaleY(var(--timeline-progress, 0));
    transform-origin: top;
    pointer-events: none;
    will-change: transform;
  }
  .atelier-milestone {
    position: absolute;
    top: 50%;
    z-index: 2;
    width: 12px;
    height: 12px;
    border: 1px solid var(--cocoa-border-soft);
    border-radius: 50%;
    background: #030303;
    transform: translateY(-50%);
  }
  .timeline-item--left .atelier-milestone {
    right: -6px;
  }
  .timeline-item--right .atelier-milestone {
    left: -6px;
  }
  .atelier-milestone.is-complete {
    border-color: var(--cocoa-border);
    background: rgb(var(--cocoa-rgb));
    box-shadow: 0 0 4px var(--cocoa-glow-soft);
  }
  .atelier-milestone.is-current {
    border-color: var(--cocoa-border-strong);
    background: rgb(var(--cocoa-rgb));
    box-shadow: 0 0 5px var(--cocoa-glow-soft);
  }

  .timeline-item {
    position: relative;
    width: min(100%, 47rem);
  }

  .timeline-item--left {
    justify-self: start;
    padding-right: clamp(var(--space-8), 8vw, var(--space-13));
  }

  .timeline-item--right {
    justify-self: end;
    padding-left: clamp(var(--space-8), 8vw, var(--space-13));
  }

  .timeline-item--right :global(.atelier-card) {
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .timeline-item--right :global(.number-wrap) {
    order: 2;
  }

  .timeline-item--right :global(.content) {
    margin-left: auto;
    text-align: right;
  }

  .timeline-item--right :global(.divider) {
    margin-left: auto;
    transform-origin: right;
    background: linear-gradient(270deg, var(--cocoa-400), transparent);
  }

  @media (min-width: 1024px) {
    .timeline-item--left,
    .timeline-item--right {
      transform: none;
    }
  }

  @media (max-width: 1023px) {
    .atelier-timeline {
      gap: var(--space-8);
    }

    .atelier-timeline::before {
      left: clamp(2rem, 9vw, 2.75rem);
      transform: none;
    }
    .atelier-timeline::after {
      left: clamp(2rem, 9vw, 2.75rem);
      transform: scaleY(var(--timeline-progress, 0));
    }
    .timeline-item .atelier-milestone {
      left: calc(clamp(2rem, 9vw, 2.75rem) - 6px);
      right: auto;
    }

    .timeline-item,
    .timeline-item--left,
    .timeline-item--right {
      width: 100%;
      justify-self: stretch;
      padding-inline: 0;
      transform: none;
    }

    .timeline-item--right :global(.atelier-card) {
      grid-template-columns: auto minmax(0, 1fr);
    }

    .timeline-item--right :global(.number-wrap) {
      order: 0;
    }

    .timeline-item--right :global(.content) {
      margin-left: 0;
      text-align: left;
    }

    .timeline-item--right :global(.divider) {
      margin-left: 0;
      transform-origin: left;
      background: linear-gradient(90deg, var(--cocoa-400), transparent);
    }
  }

  @media (max-width: 767px) {
    .atelier-timeline {
      gap: var(--space-7);
    }

    .atelier-timeline::before {
      left: clamp(2rem, 9vw, 2.75rem);
      inset-block: var(--space-4);
    }
  }
</style>
