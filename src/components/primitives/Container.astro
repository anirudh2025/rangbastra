---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class:list={["container", className]}>
  <slot />
</div>

<style>
.container {
  width: min(100%, var(--container-default));
  margin-inline: auto;
  padding-inline: var(--container-padding-inline);
}
</style>
