---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<p class:list={["paragraph", className]}>
  <slot />
</p>

<style>
.paragraph {
  max-width: var(--measure);

  color: var(--text-secondary);

  font-size: var(--text-base);

  line-height: var(--leading-relaxed);
}
</style>