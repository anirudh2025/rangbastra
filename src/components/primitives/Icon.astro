---
import {
  luxuryIconAliases,
  luxuryIconPaths,
  type LuxuryIconName,
} from "../icons/luxury/iconPaths";
import Sparkle from "../icons/journey/Sparkle.astro";

interface Props {
  name: string;
  size?: number;
  color?: string;
  class?: string;
  strokeWidth?: number;
}

const {
  name,
  size = 28,
  color = "currentColor",
  class: className = "",
  strokeWidth = 1.72,
} = Astro.props;

const iconName = (luxuryIconAliases[name] ?? name) as LuxuryIconName;
const paths = luxuryIconPaths[iconName] ?? luxuryIconPaths.sparkle;
const useDedicatedSparkle = iconName === "sparkle";
// Brand silhouettes sourced from Simple Icons (CC0): simpleicons.org.
