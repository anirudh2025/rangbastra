---
import {
  luxuryIconAliases,
  luxuryIconPaths,
  type LuxuryIconName,
} from "../icons/luxury/iconPaths";
import Sparkle from "../icons/journey/Sparkle.astro";

interface Props {
  name: string;
  size?: number;
  color?: string;
  class?: string;
  strokeWidth?: number;
}

const {
  name,
  size = 28,
  color = "currentColor",
  class: className = "",
  strokeWidth = 1.72,
} = Astro.props;

const iconName = (luxuryIconAliases[name] ?? name) as LuxuryIconName;
const paths = luxuryIconPaths[iconName] ?? luxuryIconPaths.sparkle;
const useDedicatedSparkle = iconName === "sparkle";
---

{useDedicatedSparkle ? (
  <Sparkle
    size={size}
    color={color}
    class={className}
    strokeWidth={strokeWidth}
  />
) : (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    width={size}
    height={size}
    fill="none"
    stroke={color}
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
    focusable="false"
  >
    {paths.map((path) => <path d={path} />)}
  </svg>
)}
