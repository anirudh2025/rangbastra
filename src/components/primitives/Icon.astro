---
import Sparkles from "../icons/journey/Sparkles.astro";
import Needle from "../icons/journey/Needle.astro";
import Thread from "../icons/journey/Thread.astro";
import Crown from "../icons/journey/Crown.astro";
import Calendar from "../icons/navigation/Calendar.astro";
import Instagram from "../icons/navigation/Instagram.astro";
import Whatsapp from "../icons/navigation/Whatsapp.astro";

interface Props{
    name:string;
    size?:number;
    color?:string;
    class?:string;
    strokeWidth?:number;
}

const{
    name,
    size=28,
    color="currentColor",
    class:className="",
    strokeWidth=1.8
}=Astro.props;

const icons={
    sparkles:Sparkles,
    needle:Needle,
    thread:Thread,
    crown:Crown,
    calendar:Calendar,
    instagram:Instagram,
    whatsapp:Whatsapp
};

const SelectedIcon=icons[name as keyof typeof icons];
---

{
SelectedIcon && (
    <SelectedIcon
        size={size}
        color={color}
        class={className}
        strokeWidth={strokeWidth}
    />
)
}