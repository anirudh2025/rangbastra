  whatsapp:"M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479s1.065 2.875 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.262.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.29.173-1.414-.074-.124-.272-.198-.57-.347M12.045 21.5h-.004a9.45 9.45 0 0 1-4.817-1.319l-.346-.205-3.583.94.956-3.494-.225-.358A9.44 9.44 0 0 1 2.58 12.03C2.582 6.805 6.834 2.55 12.06 2.55a9.4 9.4 0 0 1 6.71 2.78 9.42 9.42 0 0 1 2.772 6.714c-.002 5.226-4.254 9.477-9.497 9.477Z"
};
const brandPath=brandPaths[iconName];
---

{brandPath ? <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width={size} height={size} fill={color} class={className} aria-hidden="true" focusable="false"><path d={brandPath}/></svg> : useDedicatedSparkle ? (
  <Sparkle
    size={size}
    color={color}
    class={className}
    strokeWidth={strokeWidth}
  />
) : (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    width={size}
    height={size}
    fill="none"
    stroke={color}
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
    focusable="false"
  >
    {paths.map((path) => <path d={path} />)}
  </svg>
)}
