---
interface Props {
    href?: string;
    type?: "button" | "submit" | "reset";
    class?: string;
    disabled?: boolean;
}

const {
    href,
    type = "button",
    class: className = "",
    disabled = false
} = Astro.props;
---

{
    href ? (

        <a
            href={disabled ? undefined : href}
            aria-disabled={disabled}
            class:list={[
                "button",
                className,
                disabled && "button--disabled"
            ]}
        >
            <slot />
        </a>

    ) : (

        <button
            type={type}
            disabled={disabled}
            class:list={[
                "button",
                className
            ]}
        >
            <slot />
        </button>

    )
}

<style>

.button{

    position:relative;

    display:inline-flex;

    align-items:center;

    justify-content:center;

    gap:.6rem;

    overflow:hidden;

    padding:
        var(--button-padding-y)
        var(--button-padding-x);

    border:none;

    border-radius:var(--button-radius);

    background:var(--accent);

    color:var(--ivory-50);

    text-decoration:none;

    font-family:inherit;

    font-size:var(--label-md);

    font-weight:var(--weight-semibold);

    line-height:1;

    white-space:nowrap;

    cursor:pointer;

    transition:
        background .35s var(--ease-luxury),
        color .35s var(--ease-luxury),
        transform .35s var(--ease-luxury),
        box-shadow .35s var(--ease-luxury);

}

.button:hover{

    background:var(--accent-hover);

    transform:translateY(-2px);

}

.button:active{

    transform:translateY(0);

}

.button:focus-visible{

    outline:2px solid var(--focus-ring);

    outline-offset:4px;

}

.button:disabled,
.button--disabled{

    opacity:.55;

    cursor:not-allowed;

    pointer-events:none;

}

</style>
