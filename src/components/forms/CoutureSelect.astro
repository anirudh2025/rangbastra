---
interface Option {
  value: string;
  label: string;
}
interface Props {
  name: string;
  label: string;
  options: Option[];
  placeholder?: string;
  required?: boolean;
  errorFor?: string;
}
const {
  name,
  label,
  options,
  placeholder = "Select an option",
  required = false,
  errorFor = name,
} = Astro.props;
const id = `couture-select-${name}`;
---

<div class="couture-select" data-couture-select data-selection-sound>
  <span class="couture-select__label" id={`${id}-label`}>{label}</span>
  <input type="hidden" name={name} required={required} />
  <button
    type="button"
    class="couture-select__trigger"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-labelledby={`${id}-label ${id}-value`}
    aria-controls={`${id}-list`}
  >
    <span id={`${id}-value`} data-select-value>{placeholder}</span>
    <svg viewBox="0 0 16 16" aria-hidden="true"
      ><path d="m4 6 4 4 4-4"></path></svg
    >
  </button>
  <div
    class="couture-select__list"
    id={`${id}-list`}
    role="listbox"
    tabindex="-1"
    aria-labelledby={`${id}-label`}
    hidden
  >
    {
      options.map((option) => (
        <button
          type="button"
          role="option"
          aria-selected="false"
          data-value={option.value}
        >
          {option.label}
          <span aria-hidden="true">✓</span>
        </button>
      ))
    }
  </div>
  <small data-error-for={errorFor}></small>
</div>

<script>
  document
    .querySelectorAll<HTMLElement>("[data-couture-select]")
    .forEach((select) => {
      if (select.dataset.ready) return;
      select.dataset.ready = "true";
      const trigger = select.querySelector<HTMLButtonElement>(
          ".couture-select__trigger",
        )!,
        list = select.querySelector<HTMLElement>("[role=listbox]")!,
        input = select.querySelector<HTMLInputElement>("input[type=hidden]")!,
        value = select.querySelector<HTMLElement>("[data-select-value]")!,
        options = [
          ...select.querySelectorAll<HTMLButtonElement>("[role=option]"),
        ];
      let active = 0,
        typed = "",
        timer = 0;
      const close = (focus = false) => {
        list.hidden = true;
        trigger.setAttribute("aria-expanded", "false");
        if (focus) trigger.focus();
      };
      const positionList = () => {
        if (list.hidden) return;
        const rect=trigger.getBoundingClientRect(),gap=6,spaceBelow=innerHeight-rect.bottom;
        list.style.left=`${Math.max(8,rect.left)}px`;
        list.style.width=`${Math.min(rect.width,innerWidth-16)}px`;
        list.style.top=spaceBelow>=Math.min(280,list.scrollHeight+gap)?`${rect.bottom+gap}px`:`${Math.max(8,rect.top-Math.min(280,list.scrollHeight)-gap)}px`;
      };
      const open = () => {
        document
          .querySelectorAll<HTMLElement>(".couture-select__list")
          .forEach((other) => {
            if (other !== list) other.hidden = true;
          });
        list.hidden = false;
        if(list.parentElement!==document.body)document.body.appendChild(list);
        positionList();
        trigger.setAttribute("aria-expanded", "true");
        active = Math.max(
          0,
          options.findIndex((o) => o.getAttribute("aria-selected") === "true"),
        );
        options[active]?.focus();
      };
      const choose = (option: HTMLButtonElement) => {
        options.forEach((o) =>
          o.setAttribute("aria-selected", String(o === option)),
        );
        input.value = option.dataset.value ?? "";
        value.textContent = option.childNodes[0]?.textContent?.trim() ?? "";
        input.dispatchEvent(new Event("change", { bubbles: true }));
        close(true);
      };
      trigger.addEventListener("click", () => (list.hidden ? open() : close()));
      trigger.addEventListener("keydown", (e) => {
        if (["Enter", " ", "ArrowDown", "ArrowUp"].includes(e.key)) {
          e.preventDefault();
          open();
        }
      });
      list.addEventListener("keydown", (e) => {
        active = options.indexOf(document.activeElement as HTMLButtonElement);
        if (e.key === "Escape") {
          e.preventDefault();
          close(true);
          return;
        }
        if (e.key === "Home") active = 0;
        else if (e.key === "End") active = options.length - 1;
        else if (e.key === "ArrowDown")
          active = Math.min(options.length - 1, active + 1);
        else if (e.key === "ArrowUp") active = Math.max(0, active - 1);
        else if (e.key.length === 1) {
          typed += e.key.toLowerCase();
          clearTimeout(timer);
          timer = window.setTimeout(() => (typed = ""), 500);
          const match = options.findIndex((o) =>
            o.textContent?.trim().toLowerCase().startsWith(typed),
          );
          if (match >= 0) active = match;
        } else return;
        e.preventDefault();
        options[active]?.focus();
      });
      options.forEach((option) =>
        option.addEventListener("click", () => choose(option)),
      );
      document.addEventListener("pointerdown", (event) => {
        if (!select.contains(event.target as Node)&&!list.contains(event.target as Node)) close();
      });
      addEventListener("resize",positionList,{passive:true});
      addEventListener("scroll",positionList,{passive:true,capture:true});
    });
</script>

<style>
  .couture-select {
    position: relative;
    z-index: var(--z-form-control);
    display: grid;
    gap: var(--space-2);
  }
  .couture-select__label {
    color: var(--text-secondary);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  .couture-select__trigger {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    min-height: 3.3rem;
    padding: 0.85rem 3rem 0.85rem 1rem;
    border: 1px solid var(--cocoa-border-soft);
    border-radius: var(--radius-md);
    background: #070707;
    color: var(--text-primary);
    text-align: left;
  }
  .couture-select__trigger svg {
    position: absolute;
    right: 1.15rem;
    width: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    pointer-events: none;
    transition: transform var(--motion-fast);
  }
  .couture-select__trigger[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }
  .couture-select__list {
    position: fixed;
    z-index: var(--z-dropdown);
    overflow: auto;
    max-height: 17rem;
    padding: 0.4rem;
    border: 1px solid var(--cocoa-border);
    border-radius: var(--radius-md);
    background: rgba(5, 5, 5, 0.98);
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.55);
  }
  .couture-select__list button {
    display: flex;
    justify-content: space-between;
    width: 100%;
    min-height: 44px;
    padding: 0.7rem 0.8rem;
    border-radius: calc(var(--radius-md) - 4px);
    color: var(--text-secondary);
    text-align: left;
  }
  .couture-select__list button:hover,
  .couture-select__list button:focus-visible {
    background: rgba(var(--cocoa-rgb), 0.2);
    color: var(--ivory-100);
  }
  .couture-select__list [aria-selected="true"] {
    color: var(--cocoa-300);
  }
  .couture-select__list [aria-selected="false"] span {
    opacity: 0;
  }
  .couture-select__trigger:focus-visible {
    outline: 1px solid var(--cocoa-border-strong);
    outline-offset: 3px;
  }
</style>
