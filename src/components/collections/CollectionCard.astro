---
interface Props {
  title: string;
  subtitle: string;
  image: string;
  href: string;
}

const { title, subtitle, image, href } = Astro.props;
---

<a href={href} class="card">
  <img
    src={image}
    alt={title}
    width="900"
    height="1125"
    loading="lazy"
    decoding="async"
  />

  <span class="shine" aria-hidden="true"></span>

  <span class="overlay">
    <span class="subtitle">{subtitle}/</span>

    <h3>{title}</h3>/

    <span class="cta">View Collection</span>
  </span>
</a>

<style>
  .card {
    --collection-card-overlay: var(--gradient-overlay);
    --collection-card-sheen: var(--gradient-glass);

    position: relative;
    display: block;
    overflow: hidden;
    isolation: isolate;
    aspect-ratio: 4 / 5;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    background: var(--surface-raised);
    box-shadow: var(--shadow-premium), var(--shadow-inset);
    contain: paint;
    transition:
      transform var(--motion-medium) var(--ease-luxury),
      box-shadow var(--motion-medium) var(--ease-luxury),
      border-color var(--motion-medium) var(--ease-luxury);
  }

  .card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      var(--collection-card-overlay),
      var(--collection-card-sheen);
    opacity: .94;
    transition: opacity var(--motion-medium) var(--ease-luxury);
  }

  .card:hover,
  .card:focus-visible {
    transform: translate3d(0, var(--motion-card-lift), 0);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-premium), var(--glow-soft), var(--shadow-inset-strong);
  }

  .card:hover::after,
  .card:focus-visible::after {
    opacity: 1;
  }

  .card:active {
    transform: translate3d(0, 0, 0) scale(var(--scale-button));
  }

  img {
    width: 100%;
    height: auto;
    object-fit: cover;
    transform: scale(1.01);
    will-change: transform;
    backface-visibility: hidden;
    transition: transform var(--motion-slow) var(--ease-luxury);
  }

  .card:hover img,
  .card:focus-visible img {
    transform: scale(var(--motion-image-scale-subtle));
  }

  .shine {
    position: absolute;
    inset: 1px;
    z-index: 2;
    pointer-events: none;
    border-radius: calc(var(--radius-md) - 1px);
    background: var(--gradient-glass);
    opacity: 0;
    transform: translateX(-1%);
    transition:
      opacity var(--motion-medium) var(--ease-luxury),
      transform var(--motion-luxury) var(--ease-luxury);
  }

  .card:hover .shine,
  .card:focus-visible .shine {
    opacity: .26;
    transform: translateX(28%);
  }

  .overlay {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-3);
    padding: clamp(var(--space-4), 2vw, var(--space-7));
  }

  .subtitle,
  .cta {
    color: var(--sand-300);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-caption);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  h3 {
    max-width: 11ch;
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2.05vw, 2.15rem);
    font-weight: var(--weight-light);
    line-height: var(--leading-heading);
    text-wrap: balance;
  }

  .cta {
    display: inline-flex;
    width: fit-content;
    margin-top: var(--space-1);
    color: var(--ivory-100);
    opacity: 0;
    transform: translateY(var(--distance-xs));
    transition:
      opacity var(--motion-base) var(--ease-luxury),
      transform var(--motion-base) var(--ease-luxury);
  }

  .cta::after {
    content: "";
    align-self: center;
    width: var(--space-6);
    height: 1px;
    margin-left: var(--space-3);
    background: currentColor;
    transform-origin: left;
    transform: scaleX(.65);
    transition: transform var(--motion-base) var(--ease-luxury);
  }

  .card:hover .cta,
  .card:focus-visible .cta {
    opacity: .9;
    transform: translate3d(0, 0, 0);
  }

  .card:hover .cta::after,
  .card:focus-visible .cta::after {
    transform: scaleX(1);
  }

  @media (max-width: 767px) {
    .overlay {
      gap: var(--space-2);
      padding: var(--space-4);
    }

    h3 {
      max-width: 11ch;
      font-size: clamp(1.45rem, 8vw, 2.1rem);
    }

    .cta {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .card,
    .card:hover,
    .card:focus-visible,
    .card:active,
    .card:hover img,
    .card:focus-visible img,
    .card:hover .shine,
    .card:focus-visible .shine,
    .card:hover .cta,
    .card:focus-visible .cta {
      transform: none;
    }
  }
</style>
