---
import Eyebrow from "../primitives/Eyebrow.astro";
---

<header class="header">
  <Eyebrow>Featured Collections</Eyebrow>

  <h2>
    <span class="title-intro">Crafted For</span>
    <span class="title-statement">Every Celebration</span>
  </h2>

  <p>
    Discover signature couture collections designed to celebrate every
    unforgettable moment.
  </p>
</header>

<style>
  .header {
    display: grid;
    justify-items: center;
    gap: var(--space-4);
    max-width: var(--measure-md);
    margin: 0 auto clamp(var(--space-8), 6vw, var(--space-11));
    text-align: center;
  }

  h2 {
    display: grid;
    gap: var(--space-1);
    margin: 0;
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    text-align: center;
    justify-self: center;
    text-wrap: balance;
  }

  .title-intro {
    color: var(--text-primary);
    font-size: var(--section-heading-intro);
    letter-spacing: -1.4px;
    line-height: 1.18;
    white-space: nowrap;
  }

  .title-statement {
    background: var(--gradient-primary);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    font-size: var(--section-heading-statement);
    font-weight: 500;
    letter-spacing: -3.8px;
    line-height: 1.12;
    padding-bottom: .08em;
    white-space: nowrap;
  }

  p {
    max-width: var(--measure-md);
    margin-inline: auto;
    color: var(--text-secondary);
    font-size: var(--body-md);
    line-height: var(--leading-body);
    justify-self: center;
    text-align: center;
    text-wrap: pretty;
  }

  @media (max-width: 767px) {
    .header {
      justify-items: start;
      gap: var(--space-3);
      margin-bottom: var(--space-7);
      text-align: left;
    }

    .title-intro {
      font-size: var(--section-heading-intro-mobile);
    }

    .title-statement {
      font-size: var(--section-heading-statement-mobile);
    }
  }
</style>
