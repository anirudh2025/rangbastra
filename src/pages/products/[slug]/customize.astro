---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/primitives/Container.astro";
import Icon from "../../../components/primitives/Icon.astro";
import ProductCustomizationForm from "../../../components/customization/ProductCustomizationForm.astro";
import Footer from "../../../sections/home/Footer.astro";
import {
  getCloudinaryImageUrl,
  getProductImages,
  getPublishedCouturePieces,
  isConfirmedFourByFive,
} from "../../../lib/couture";
import type { CouturePiece } from "../../../data/couture";
interface Props {
  product: CouturePiece;
}
export function getStaticPaths() {
  return getPublishedCouturePieces().map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}
const { product } = Astro.props;
const customizationHero =
  getProductImages(product).find((image) => image.id === "hero") ??
  getProductImages(product)[0];
const customizationImages = ["hero", "detail", "drape", "editorial"]
  .map((id) => getProductImages(product).find((image) => image.id === id) ?? customizationHero);
const endpoint = import.meta.env.PUBLIC_SUPABASE_URL
  ? `${import.meta.env.PUBLIC_SUPABASE_URL}/functions/v1/submit-customization`
  : "";
---

<BaseLayout
  title={`Customize ${product.name} | Rangbastra`}
  description={`Begin a private customization request for ${product.name}.`}
  canonical={`/products/${product.slug}/customize`}
  image={customizationHero.src}
>
  <section class="customize-hero">
    <Container
      ><a class="back-link" href={`/products/${product.slug}`}
        >← Return to {product.name}</a
      ><div class="product-context">
        <div class="context-gallery">
          {customizationImages.map((image,index)=><img data-image-fit={isConfirmedFourByFive(image)?"cover":"contain"} src={getCloudinaryImageUrl(image.src,index===0?1100:520)} alt={image.alt} loading={index===0?"eager":"lazy"} width={image.width??(index===0?900:360)} height={image.height??(index===0?1125:450)}/>) }
        </div><div>
          <p class="eyebrow">{product.collection} · {product.category}</p><h1>
            Shape <span class="title-highlight">{product.name}</span> Around You
          </h1><p>{product.shortDescription}</p><p class="product-facts"><strong>Original shade</strong> {product.color.name} · <strong>Collection</strong> {product.category} · <strong>Starting price</strong> {product.priceLabel}</p><dl>
            <div>
              <Icon name="calendar" size={20} /><dt>
                Estimated making time
              </dt><dd>
                {product.makingTime ?? "Confirmed after consultation"}
              </dd>
            </div><div>
              <Icon name="privateResponses" size={20} /><dt>
                Private response
              </dt><dd>Within 24 hours</dd>
            </div><div>
              <Icon name="dedicatedDesigner" size={20} /><dt>
                Personal guidance
              </dt><dd>Dedicated designer</dd>
            </div>
          </dl>
        </div>
      </div></Container>
  </section>
  <section class="customize-form">
    <Container
      ><ProductCustomizationForm
        product={product}
        endpoint={endpoint}
      /></Container>
  </section><Footer />
</BaseLayout>
<style>
  .customize-hero,
  .customize-form {
    position: relative;
    z-index: var(--z-section);
    padding: clamp(7rem, 12vw, 11rem) 0 clamp(3rem, 6vw, 6rem);
  }
  .customize-form {
    padding-top: 0;
  }
  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--cocoa-300);
    font-size: 0.78rem;
  }
  .product-context {
    display: grid;
    grid-template-columns: minmax(17rem, 0.72fr) minmax(0, 1fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: center;
  }
 .context-gallery{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-2)}
 .context-gallery img {
    width: 100%;
    max-height: 42rem;
    aspect-ratio:4 / 5;
    object-fit: contain;
    object-position:center;
    border: 1px solid var(--cocoa-border);
    border-radius: var(--radius-lg);
  }
 .context-gallery img[data-image-fit="cover"]{object-fit:cover}
 .context-gallery img:first-child{grid-column:1/-1;max-height:36rem}.product-facts{margin-top:var(--space-4);color:var(--text-secondary)}.product-facts strong{color:var(--ivory-100)}
  h1 {
    margin: 0.6rem 0 1rem;
    color: var(--ivory-100);
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 7rem);
    line-height: 0.94;
  }
  .product-context dl {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.8rem;
    margin-top: 2rem;
  }
  .product-context dl > div {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.35rem 0.6rem;
    padding: 1rem;
    border: 1px solid var(--cocoa-border-soft);
    border-radius: var(--radius-md);
    background: #070707;
    color: var(--cocoa-300);
  }
  dt {
    color: var(--text-muted);
    font-size: 0.68rem;
    text-transform: uppercase;
  }
  dd {
    grid-column: 2;
    color: var(--ivory-100);
    font-size: 0.82rem;
  }
  @media (max-width: 780px) {
    .product-context {
      grid-template-columns: 1fr;
    }
    .product-context dl {
      grid-template-columns: 1fr;
    }
  }
</style>
