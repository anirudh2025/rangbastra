---
import BaseLayout from "../layouts/BaseLayout.astro"; import Section from "../components/primitives/Section.astro"; import Container from "../components/primitives/Container.astro"; import ConsultationExperience from "../components/experience/ConsultationExperience.astro"; import SignatureCTA from "../components/experience/SignatureCTA.astro"; import Footer from "../sections/home/Footer.astro";
---
<BaseLayout title="Designer Consultation | Rangbastra" description="Choose a private Rangbastra designer consultation by WhatsApp, video or at the Anand studio, and learn how to prepare." canonical="/designer-consultation"><Section class="experience-section"><Container class="experience-container"><ConsultationExperience/><SignatureCTA variant="account"/></Container></Section><Footer/></BaseLayout>
<style>:global(.experience-section){--section-padding-block:0 clamp(var(--space-10),10vw,var(--space-13));overflow:hidden;background:radial-gradient(circle at 82% 12%,rgba(var(--cocoa-rgb),.14),transparent 34%),var(--surface-canvas)}:global(.experience-container){--container-default:var(--container-wide);display:grid;gap:clamp(var(--space-10),10vw,var(--space-13))}</style>
