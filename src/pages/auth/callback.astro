---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Completing Secure Sign-In | Rangbastra"
  robots="noindex,nofollow"
>
  <section class="auth-callback">
    <p role="status" data-auth-callback-status>
      Completing your secure Google sign-in…
    </p>
  </section>
</BaseLayout>

<script>
  import { createClient } from "@supabase/supabase-js";

  const completeAuth = async () => {
    const status = document.querySelector<HTMLElement>(
      "[data-auth-callback-status]",
    );
    try {
      const url = import.meta.env.PUBLIC_SUPABASE_URL;
      const key =
        import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY ||
        import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
      if (!url || !key) throw new Error("Authentication is not configured");

      const parameters = new URLSearchParams(location.search);
      if (parameters.has("error") || parameters.has("error_code"))
        throw new Error("OAuth provider returned an error");

      const supabase = createClient(url, key, {
        auth: {
          flowType: "pkce",
          persistSession: true,
          autoRefreshToken: true,
          detectSessionInUrl: false,
        },
      });
      const code = parameters.get("code");
      const result = code
        ? await supabase.auth.exchangeCodeForSession(code)
        : await supabase.auth.getSession();
      const { data, error } = result;
      if (error || !data.session)
        throw error ?? new Error("No session returned");
      if (status)
        status.textContent = "Welcome. Opening your private client room…";
      window.RangbastraAudio?.success();
      const requested = parameters.get("next");
      const next =
        requested?.startsWith("/") && !requested.startsWith("//")
          ? requested
          : "/account";
      location.replace(next);
    } catch (error) {
      if (import.meta.env.DEV && error instanceof Error)
        console.error("Rangbastra auth callback:", error.message);
      if (status)
        status.textContent =
          "Google sign-in could not be completed. Please return to Sign In and try again.";
    }
  };
  completeAuth();
</script>

<style>
  .auth-callback {
    display: grid;
    min-height: 100svh;
    place-items: center;
    padding: 2rem;
    background: #050505;
    color: var(--ivory-100);
    text-align: center;
  }
</style>
