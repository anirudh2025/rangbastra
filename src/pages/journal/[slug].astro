---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/primitives/Button.astro";
import Container from "../../components/primitives/Container.astro";
import Eyebrow from "../../components/primitives/Eyebrow.astro";
import Icon from "../../components/primitives/Icon.astro";
import Section from "../../components/primitives/Section.astro";
import Footer from "../../sections/home/Footer.astro";
import { getRelatedArticles, journalArticles } from "../../data/journal";

export const getStaticPaths = () =>
  journalArticles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));

const { article } = Astro.props;
const relatedArticles = getRelatedArticles(article.slug);
---

<BaseLayout
  title={`${article.title} | Rangbastra Journal`}
  description={article.description}
  canonical={`/journal/${article.slug}`}
  image={article.heroImage}
>
  <Section class="article-section">
    <Container class="article-container">
      <article class="article-shell">
        <header class="article-hero">
          <div class="article-meta-panel">
            <Eyebrow>{article.category}</Eyebrow>
            <span>{article.readingTime}</span>
            <span>Rangbastra Atelier</span>
          </div>

          <div class="article-title">
            <a href="/journal" class="back-link">
              <Icon name="journal" size={18} />
              Journal
            </a>
            <h1>{article.title}</h1>
            <p>{article.excerpt}</p>
          </div>

          <figure class="article-image">
            <img src={article.heroImage} alt={article.heroAlt} loading="eager" decoding="async" />
          </figure>
        </header>

        <div class="article-body">
          <aside class="article-note" aria-label="Article note">
            <span>Atelier Reading</span>
            <p>
              Read slowly. Couture decisions become clearer when the eye has
              time to notice proportion, tone and feeling.
            </p>
          </aside>

          <div class="article-content">
            {article.body.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>
      </article>

      <section class="related-articles" aria-labelledby="related-articles-heading">
        <div class="related-heading">
          <Eyebrow>Continue Reading</Eyebrow>
          <h2 id="related-articles-heading">More From The Atelier Desk</h2>
        </div>

        <div class="related-grid">
          {relatedArticles.map((related) => (
            <a href={`/journal/${related.slug}`} class="related-card">
              <span>{related.category}</span>
              <h3>{related.title}</h3>
              <p>{related.excerpt}</p>
            </a>
          ))}
        </div>
      </section>

      <aside class="article-cta" aria-labelledby="article-cta-heading">
        <h2 id="article-cta-heading">Let This Become A Private Design Conversation</h2>
        <Button href="/design-your-outfit">Design Your Dream Outfit</Button>
      </aside>
    </Container>
  </Section>
  <Footer />
</BaseLayout>

<style>
  :global(.article-section) {
    --section-padding-block: 0 clamp(var(--space-10), 10vw, var(--space-13));
    overflow: hidden;
    background:
      radial-gradient(circle at 82% 20%, rgba(106, 78, 66, .2), transparent 34%),
      linear-gradient(90deg, rgba(255, 255, 255, .035) 0 1px, transparent 1px 12rem),
      var(--surface-canvas);
  }

  :global(.article-container) {
    --container-default: var(--container-wide);
    --container-padding-inline: clamp(var(--space-5), 5vw, var(--space-10));
  }

  .article-shell {
    padding-top: clamp(var(--space-12), 14vw, var(--space-14));
  }

  .article-hero {
    display: grid;
    grid-template-columns: minmax(10rem, .16fr) minmax(0, .48fr) minmax(18rem, .36fr);
    gap: clamp(var(--space-5), 6vw, var(--space-10));
    align-items: end;
    min-height: min(52rem, calc(100svh - var(--navbar-height)));
  }

  .article-meta-panel {
    display: grid;
    gap: var(--space-4);
    align-self: center;
    color: var(--text-muted);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
    color: var(--sand-200);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-decoration: none;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    letter-spacing: var(--tracking-heading);
  }

  h1 {
    max-width: 11ch;
    font-size: clamp(3.2rem, 7vw, 7.6rem);
    line-height: .96;
  }

  .article-title p {
    max-width: var(--measure-sm);
    margin-top: var(--space-5);
    color: var(--text-secondary);
    font-size: var(--body-lg);
    line-height: var(--leading-body);
  }

  .article-image {
    min-height: clamp(28rem, 50vw, 42rem);
    overflow: hidden;
    border: 1px solid rgba(198, 169, 114, .22);
  }

  .article-image img {
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    opacity: .84;
  }

  .article-body {
    display: grid;
    grid-template-columns: minmax(12rem, .25fr) minmax(0, .58fr);
    gap: clamp(var(--space-6), 8vw, var(--space-12));
    padding-block: clamp(var(--space-9), 10vw, var(--space-13));
  }

  .article-note {
    position: sticky;
    top: calc(var(--navbar-height) + var(--space-5));
    align-self: start;
    padding: var(--space-5);
    border: 1px solid rgba(198, 169, 114, .18);
    background: rgba(255, 255, 255, .025);
  }

  .article-note span,
  .related-card span {
    color: var(--sand-200);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .article-note p,
  .article-content p,
  .related-card p {
    color: var(--text-secondary);
    font-size: var(--body-md);
    line-height: var(--leading-body);
  }

  .article-content {
    display: grid;
    gap: var(--space-6);
    max-width: 52rem;
  }

  .article-content p:first-child::first-letter {
    float: left;
    padding: .2rem .5rem 0 0;
    color: var(--sand-200);
    font-family: var(--font-display);
    font-size: clamp(5rem, 9vw, 8rem);
    line-height: .72;
  }

  .related-articles {
    display: grid;
    gap: var(--space-7);
    padding-block: clamp(var(--space-8), 9vw, var(--space-12));
    border-block: 1px solid rgba(255, 255, 255, .08);
  }

  .related-heading h2,
  .article-cta h2 {
    max-width: 13ch;
    margin-top: var(--space-4);
    font-size: clamp(2.6rem, 5vw, 5.4rem);
    line-height: 1;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .related-card {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-5);
    min-height: 20rem;
    border: 1px solid rgba(255, 255, 255, .08);
    color: inherit;
    text-decoration: none;
    background: rgba(255, 255, 255, .025);
    transition: border-color 420ms var(--ease-luxury), transform 420ms var(--ease-luxury);
  }

  .related-card:hover {
    border-color: rgba(198, 169, 114, .34);
    transform: translate3d(0, -.3rem, 0);
  }

  .related-card h3 {
    font-size: clamp(1.8rem, 2.6vw, 2.7rem);
    line-height: 1.05;
  }

  .article-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding-block: clamp(var(--space-8), 9vw, var(--space-12));
  }

  @media (max-width: 1024px) {
    .article-hero,
    .article-body {
      grid-template-columns: 1fr;
    }

    .article-note {
      position: static;
      max-width: 28rem;
    }

    .related-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .article-shell {
      padding-top: clamp(var(--space-11), 28vw, var(--space-13));
    }

    .related-grid,
    .article-cta {
      grid-template-columns: 1fr;
      display: grid;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .related-card {
      transition: none;
    }

    .related-card:hover {
      transform: none;
    }
  }
</style>
