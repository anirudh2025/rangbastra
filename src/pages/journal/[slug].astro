---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/primitives/Button.astro";
import Container from "../../components/primitives/Container.astro";
import Eyebrow from "../../components/primitives/Eyebrow.astro";
import Icon from "../../components/primitives/Icon.astro";
import Section from "../../components/primitives/Section.astro";
import Footer from "../../sections/home/Footer.astro";
import { getRelatedArticles, journalArticles } from "../../data/journal";

export const getStaticPaths = () =>
  journalArticles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));

const { article } = Astro.props;
const relatedArticles = getRelatedArticles(article.slug);
const articleUrl = `https://www.rangbastra.luxury/journal/${article.slug}`;
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.title,
  description: article.description,
  image: article.heroImage,
  datePublished: article.publishedDate,
  author: { "@type": "Organization", name: article.author },
  publisher: { "@type": "Organization", name: "Rangbastra" },
  mainEntityOfPage: articleUrl,
  wordCount: article.wordCount,
};
---

<BaseLayout
  title={`${article.title} | Rangbastra Journal`}
  description={article.description}
  canonical={`/journal/${article.slug}`}
  image={article.heroImage}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <div class="reading-progress" aria-hidden="true">
    <i data-reading-progress></i>
  </div>
  <Section class="article-section">
    <Container class="article-container">
      <article class="article-shell">
        <header class="article-hero">
          <div class="article-meta-panel">
            <Eyebrow>{article.category}</Eyebrow>
            <span>{article.readingTime}</span>
            <span>{article.author}</span>
            <time datetime={article.publishedDate}
              >{
                new Intl.DateTimeFormat("en-IN", { dateStyle: "long" }).format(
                  new Date(article.publishedDate),
                )
              }</time
            >
          </div>

          <div class="article-title">
            <a href="/journal" class="back-link">
              <Icon name="journal" size={18} />
              Journal
            </a>
            <h1>{article.title}</h1>
            <p>{article.excerpt}</p>
          </div>

          <figure class="article-image">
            <img
              src={article.heroImage}
              alt={article.heroAlt}
              loading="eager"
              decoding="async"
            />
          </figure>
        </header>

        <div class="article-body">
          <aside class="article-note" aria-label="Article note">
            <span>Atelier Reading</span>
            <p>
              Read slowly. Couture decisions become clearer when the eye has
              time to notice proportion, tone and feeling.
            </p>
          </aside>

          <div class="article-content">
            {article.body.map((paragraph) => <p>{paragraph}</p>)}
            <nav class="share-links" aria-label="Share this article">
              <strong>Share</strong><a
                href={`https://wa.me/?text=${encodeURIComponent(`${article.title} ${articleUrl}`)}`}
                target="_blank"
                rel="noopener noreferrer">WhatsApp</a
              ><a
                href={`mailto:?subject=${encodeURIComponent(article.title)}&body=${encodeURIComponent(articleUrl)}`}
                >Email</a
              ><button type="button" data-copy-link>Copy link</button><output
                data-copy-status
                aria-live="polite"></output>
            </nav>
          </div>
        </div>
      </article>

      <section
        class="related-articles"
        aria-labelledby="related-articles-heading"
      >
        <div class="related-heading">
          <Eyebrow>Continue Reading</Eyebrow>
          <h2 id="related-articles-heading">More From The Atelier Desk</h2>
        </div>

        <div class="related-grid">
          {
            relatedArticles.map((related) => (
              <a href={`/journal/${related.slug}`} class="related-card">
                <span>{related.category}</span>
                <h3>{related.title}</h3>
                <p>{related.excerpt}</p>
              </a>
            ))
          }
        </div>
      </section>

      <section
        class="article-connections"
        aria-labelledby="connections-heading"
      >
        <div>
          <Eyebrow>Connections</Eyebrow><h2 id="connections-heading">
            Continue from reading to discovery
          </h2>
        </div><div>
          {
            article.productSlugs.map((slug) => (
              <Button href={`/products/${slug}`}>Explore Related Piece</Button>
            ))
          }{
            article.storyHref && (
              <Button href={article.storyHref}>Read Bride Stories</Button>
            )
          }
        </div>
      </section>

      <aside class="article-cta" aria-labelledby="article-cta-heading">
        <h2 id="article-cta-heading">
          Let This Become A Private Design Conversation
        </h2>
        <Button href="/design-your-outfit">Design Your Dream Outfit</Button>
      </aside>
    </Container>
  </Section>
  <Footer />
</BaseLayout>

<script>
  const progress = document.querySelector<HTMLElement>(
    "[data-reading-progress]",
  );
  const updateProgress = () => {
    if (!progress) return;
    const max = document.documentElement.scrollHeight - innerHeight;
    progress.style.transform = `scaleX(${max > 0 ? scrollY / max : 0})`;
  };
  addEventListener("scroll", () => requestAnimationFrame(updateProgress), {
    passive: true,
  });
  updateProgress();
  document
    .querySelector<HTMLButtonElement>("[data-copy-link]")
    ?.addEventListener("click", async () => {
      const output =
        document.querySelector<HTMLOutputElement>("[data-copy-status]");
      try {
        await navigator.clipboard.writeText(location.href);
        if (output) output.textContent = "Link copied";
      } catch {
        if (output) output.textContent = "Copy unavailable";
      }
    });
</script>

<style>
  :global(.article-section) {
    --section-padding-block: 0 clamp(var(--space-10), 10vw, var(--space-13));
    overflow: hidden;
    background:
      radial-gradient(
        circle at 82% 20%,
        rgba(106, 78, 66, 0.2),
        transparent 34%
      ),
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.035) 0 1px,
        transparent 1px 12rem
      ),
      var(--surface-canvas);
  }
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    z-index: var(--z-overlay);
    width: 100%;
    height: 2px;
    pointer-events: none;
  }
  .reading-progress i {
    display: block;
    width: 100%;
    height: 100%;
    background: rgb(var(--cocoa-rgb));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--motion-scroll-progress) linear;
  }

  :global(.article-container) {
    --container-default: var(--container-wide);
    --container-padding-inline: clamp(var(--space-5), 5vw, var(--space-10));
  }

  .article-shell {
    padding-top: clamp(var(--space-12), 14vw, var(--space-14));
  }

  .article-hero {
    display: grid;
    grid-template-columns: minmax(10rem, 0.16fr) minmax(0, 0.48fr) minmax(
        18rem,
        0.36fr
      );
    gap: clamp(var(--space-5), 6vw, var(--space-10));
    align-items: end;
    min-height: min(52rem, calc(100svh - var(--navbar-height)));
  }

  .article-meta-panel {
    display: grid;
    gap: var(--space-4);
    align-self: center;
    color: var(--text-muted);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
    color: var(--sand-200);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-decoration: none;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    letter-spacing: var(--tracking-heading);
  }

  h1 {
    max-width: 11ch;
    font-size: clamp(3.2rem, 7vw, 7.6rem);
    line-height: 0.96;
  }

  .article-title p {
    max-width: var(--measure-sm);
    margin-top: var(--space-5);
    color: var(--text-secondary);
    font-size: var(--body-lg);
    line-height: var(--leading-body);
  }

  .article-image {
    min-height: clamp(28rem, 50vw, 42rem);
    overflow: hidden;
    border: 1px solid rgba(198, 169, 114, 0.22);
  }

  .article-image img {
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    opacity: 0.84;
  }

  .article-body {
    display: grid;
    grid-template-columns: minmax(12rem, 0.25fr) minmax(0, 0.58fr);
    gap: clamp(var(--space-6), 8vw, var(--space-12));
    padding-block: clamp(var(--space-9), 10vw, var(--space-13));
  }

  .article-note {
    position: sticky;
    top: calc(var(--navbar-height) + var(--space-5));
    align-self: start;
    padding: var(--space-5);
    border: 1px solid rgba(198, 169, 114, 0.18);
    background: rgba(255, 255, 255, 0.025);
  }

  .article-note span,
  .related-card span {
    color: var(--sand-200);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .article-note p,
  .article-content p,
  .related-card p {
    color: var(--text-secondary);
    font-size: var(--body-md);
    line-height: var(--leading-body);
  }

  .article-content {
    display: grid;
    gap: var(--space-6);
    max-width: 52rem;
  }
  .share-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
    padding-top: var(--space-5);
    border-top: 1px solid var(--border-default);
  }
  .share-links a,
  .share-links button {
    min-height: 44px;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--cocoa-border);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    text-decoration: none;
  }
  .share-links a:focus-visible,
  .share-links button:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 3px;
  }
  .article-connections {
    display: grid;
    grid-template-columns: minmax(0, 0.5fr) minmax(18rem, 0.5fr);
    gap: var(--space-6);
    padding-block: clamp(var(--space-8), 8vw, var(--space-11));
    border-bottom: 1px solid var(--border-default);
  }
  .article-connections > div {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
  }
  .article-connections > div:first-child {
    display: grid;
  }
  .article-connections h2 {
    font-size: clamp(2.5rem, 5vw, 5rem);
  }

  .article-content p:first-child::first-letter {
    float: left;
    padding: 0.2rem 0.5rem 0 0;
    color: var(--sand-200);
    font-family: var(--font-display);
    font-size: clamp(5rem, 9vw, 8rem);
    line-height: 0.72;
  }

  .related-articles {
    display: grid;
    gap: var(--space-7);
    padding-block: clamp(var(--space-8), 9vw, var(--space-12));
    border-block: 1px solid rgba(255, 255, 255, 0.08);
  }

  .related-heading h2,
  .article-cta h2 {
    max-width: 13ch;
    margin-top: var(--space-4);
    font-size: clamp(2.6rem, 5vw, 5.4rem);
    line-height: 1;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .related-card {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-5);
    min-height: 20rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: inherit;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.025);
    transition:
      border-color 420ms var(--ease-luxury),
      transform 420ms var(--ease-luxury);
  }

  .related-card:hover {
    border-color: rgba(198, 169, 114, 0.34);
    transform: translate3d(0, -0.3rem, 0);
  }

  .related-card h3 {
    font-size: clamp(1.8rem, 2.6vw, 2.7rem);
    line-height: 1.05;
  }

  .article-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding-block: clamp(var(--space-8), 9vw, var(--space-12));
  }

  @media (max-width: 1024px) {
    .article-hero,
    .article-body {
      grid-template-columns: 1fr;
    }

    .article-note {
      position: static;
      max-width: 28rem;
    }

    .related-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .article-shell {
      padding-top: clamp(var(--space-11), 28vw, var(--space-13));
    }

    .related-grid,
    .article-cta {
      grid-template-columns: 1fr;
      display: grid;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reading-progress i {
      transition: none;
    }
    .related-card {
      transition: none;
    }

    .related-card:hover {
      transform: none;
    }
  }
</style>
