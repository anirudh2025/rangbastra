---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/primitives/Button.astro";
import Container from "../components/primitives/Container.astro";
import Eyebrow from "../components/primitives/Eyebrow.astro";
import Icon from "../components/primitives/Icon.astro";
import Section from "../components/primitives/Section.astro";
import Footer from "../sections/home/Footer.astro";
import { contact } from "../data/contact";
import { journalArticles, journalCategories } from "../data/journal";

const [featuredArticle, ...articles] = journalArticles;
---

<BaseLayout
  title="Journal | Rangbastra Couture Editorial"
  description="Rangbastra Journal is a couture knowledge room for bridal guidance, craft notes, colour stories and personal design preparation."
  canonical="/journal"
  image={featuredArticle.heroImage}
>
  <Section class="journal-section">
    <Container class="journal-container">
      <section class="journal-hero" aria-labelledby="journal-heading">
        <div class="journal-spine" aria-hidden="true">
          <Icon name="journal" size={34} />
          <span>Issue 01</span>
        </div>

        <div class="journal-copy">
          <Eyebrow>Rangbastra Journal</Eyebrow>
          <p class="journal-kicker">Luxury editorial publishing for the couture bride.</p>
          <h1 id="journal-heading">Knowledge Before The First Sketch</h1>
        </div>

        <a class="journal-cover" href={`/journal/${featuredArticle.slug}`} aria-label={`Read ${featuredArticle.title}`}>
          <img src={featuredArticle.heroImage} alt={featuredArticle.heroAlt} loading="eager" decoding="async" />
          <span>Featured Note</span>
        </a>
      </section>

      <section class="featured-article" aria-labelledby="featured-article-heading">
        <div>
          <span class="article-meta">{featuredArticle.category} / {featuredArticle.readingTime}</span>
          <h2 id="featured-article-heading">{featuredArticle.title}</h2>
        </div>
        <p>{featuredArticle.excerpt}</p>
        <a href={`/journal/${featuredArticle.slug}`} class="text-link">Read the editorial</a>
      </section>

      <section class="journal-filters" aria-label="Journal categories">
        {journalCategories.map((category) => (
          <button type="button" data-category={category} class="filter-button" aria-pressed="false">
            {category}
          </button>
        ))}
      </section>

      <section class="article-grid" aria-label="Journal articles">
        {articles.map((article) => (
          <article class="article-card" data-article-category={article.category}>
            <a href={`/journal/${article.slug}`} aria-label={`Read ${article.title}`}>
              <figure>
                <img src={article.heroImage} alt={article.heroAlt} loading="lazy" decoding="async" />
              </figure>
              <div class="article-card__body">
                <span>{article.category} / {article.readingTime}</span>
                <h2>{article.title}</h2>
                <p>{article.excerpt}</p>
              </div>
            </a>
          </article>
        ))}
      </section>

      <aside class="journal-invitation" aria-labelledby="journal-invitation-heading">
        <div>
          <Eyebrow>Atelier Note</Eyebrow>
          <h2 id="journal-invitation-heading">Bring Your Questions To The Atelier</h2>
        </div>
        <p>
          If a colour, silhouette or embroidery detail has stayed with you,
          begin a private design conversation before the idea fades.
        </p>
        <div class="journal-actions">
          <Button href="/design-your-outfit">Design Your Dream Outfit</Button>
          <a href={contact.whatsappUrl} class="whatsapp-link">
            <Icon name="whatsapp" size={18} />
            Message The Atelier
          </a>
        </div>
      </aside>
    </Container>
  </Section>
  <Footer />
</BaseLayout>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>(".filter-button");
  const cards = document.querySelectorAll<HTMLElement>("[data-article-category]");

  filters[0]?.classList.add("filter-button--active");
  filters[0]?.setAttribute("aria-pressed", "true");

  filters.forEach((filter) => {
    filter.addEventListener("click", () => {
      const category = filter.dataset.category ?? "All";

      filters.forEach((item) => {
        item.classList.remove("filter-button--active");
        item.setAttribute("aria-pressed", "false");
      });
      filter.classList.add("filter-button--active");
      filter.setAttribute("aria-pressed", "true");

      cards.forEach((card) => {
        const matches = category === "All" || card.dataset.articleCategory === category;
        card.hidden = !matches;
      });
    });
  });
</script>

<style>
  :global(.journal-section) {
    --section-padding-block: 0 clamp(var(--space-10), 10vw, var(--space-13));
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(198, 169, 114, .08) 0 1px, transparent 1px 10rem),
      radial-gradient(circle at 78% 18%, rgba(106, 78, 66, .2), transparent 34%),
      var(--surface-canvas);
  }

  :global(.journal-container) {
    --container-default: var(--container-wide);
    --container-padding-inline: clamp(var(--space-5), 5vw, var(--space-10));
  }

  .journal-hero {
    display: grid;
    grid-template-columns: minmax(5rem, .12fr) minmax(0, .52fr) minmax(18rem, .36fr);
    gap: clamp(var(--space-6), 7vw, var(--space-12));
    min-height: min(54rem, calc(100svh - var(--navbar-height)));
    align-items: center;
    padding-top: clamp(var(--space-12), 14vw, var(--space-14));
  }

  .journal-spine {
    display: grid;
    justify-items: center;
    gap: var(--space-4);
    min-height: 32rem;
    padding: var(--space-5);
    border-inline: 1px solid rgba(198, 169, 114, .22);
    color: var(--sand-200);
  }

  .journal-spine span {
    writing-mode: vertical-rl;
    color: var(--text-muted);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .journal-copy {
    display: grid;
    gap: var(--space-5);
  }

  .journal-kicker {
    max-width: 28rem;
    color: var(--text-muted);
    font-size: var(--body-md);
    line-height: var(--leading-body);
  }

  h1,
  h2 {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    letter-spacing: var(--tracking-heading);
  }

  h1 {
    max-width: 10ch;
    font-size: clamp(3.8rem, 8vw, 8.8rem);
    line-height: .92;
  }

  .journal-cover {
    position: relative;
    display: block;
    min-height: clamp(28rem, 52vw, 42rem);
    overflow: hidden;
    border: 1px solid rgba(198, 169, 114, .22);
    color: var(--text-primary);
    text-decoration: none;
  }

  .journal-cover img {
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    opacity: .78;
    transform: scale(1.02);
    transition: transform 900ms var(--ease-luxury), opacity 900ms var(--ease-luxury);
  }

  .journal-cover:hover img {
    opacity: .92;
    transform: scale(1.06);
  }

  .journal-cover span {
    position: absolute;
    inset: auto var(--space-4) var(--space-4) auto;
    color: var(--sand-200);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .featured-article {
    display: grid;
    grid-template-columns: minmax(0, .58fr) minmax(16rem, .3fr) auto;
    gap: clamp(var(--space-5), 5vw, var(--space-9));
    align-items: end;
    padding-block: clamp(var(--space-8), 8vw, var(--space-12));
    border-block: 1px solid rgba(255, 255, 255, .08);
  }

  .article-meta,
  .article-card span {
    color: var(--sand-200);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .featured-article h2 {
    max-width: 14ch;
    margin-top: var(--space-3);
    font-size: clamp(2.6rem, 5vw, 5.4rem);
    line-height: 1;
  }

  .featured-article p,
  .article-card p,
  .journal-invitation p {
    color: var(--text-secondary);
    font-size: var(--body-md);
    line-height: var(--leading-body);
  }

  .text-link,
  .whatsapp-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-primary);
    font-size: var(--label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-decoration: none;
    text-transform: uppercase;
  }

  .journal-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding-block: var(--space-7);
  }

  .filter-button {
    min-height: 2.8rem;
    padding: 0 var(--space-4);
    border: 1px solid rgba(255, 255, 255, .14);
    border-radius: 2px;
    background: rgba(255, 255, 255, .03);
    color: var(--text-muted);
    font: inherit;
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    cursor: pointer;
  }

  .filter-button--active,
  .filter-button:hover,
  .filter-button:focus-visible {
    border-color: rgba(198, 169, 114, .5);
    color: var(--obsidian-1000);
    background: var(--gradient-primary);
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .article-card a {
    display: grid;
    min-height: 100%;
    color: inherit;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, .08);
    background: rgba(255, 255, 255, .025);
    transition: border-color 420ms var(--ease-luxury), transform 420ms var(--ease-luxury);
  }

  .article-card a:hover {
    border-color: rgba(198, 169, 114, .34);
    transform: translate3d(0, -.35rem, 0);
  }

  .article-card figure {
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  .article-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: .76;
    transition: transform 800ms var(--ease-luxury), opacity 800ms var(--ease-luxury);
  }

  .article-card a:hover img {
    opacity: .9;
    transform: scale(1.045);
  }

  .article-card__body {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-5);
  }

  .article-card h2 {
    font-size: clamp(1.8rem, 2.6vw, 2.7rem);
    line-height: 1.05;
  }

  .journal-invitation {
    display: grid;
    grid-template-columns: minmax(0, .5fr) minmax(16rem, .28fr) auto;
    gap: clamp(var(--space-5), 5vw, var(--space-9));
    align-items: center;
    margin-top: clamp(var(--space-9), 10vw, var(--space-13));
    padding: clamp(var(--space-6), 6vw, var(--space-10));
    border: 1px solid rgba(198, 169, 114, .18);
    background:
      radial-gradient(circle at 90% 10%, rgba(198, 169, 114, .13), transparent 32%),
      rgba(255, 255, 255, .03);
  }

  .journal-invitation h2 {
    margin-top: var(--space-4);
    max-width: 13ch;
    font-size: clamp(2.6rem, 5vw, 5.4rem);
    line-height: 1;
  }

  .journal-actions {
    display: grid;
    justify-items: start;
    gap: var(--space-4);
  }

  @media (max-width: 1024px) {
    .journal-hero,
    .featured-article,
    .journal-invitation {
      grid-template-columns: 1fr;
    }

    .journal-spine {
      display: none;
    }

    .article-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .journal-hero {
      min-height: auto;
      padding-top: clamp(var(--space-11), 28vw, var(--space-13));
    }

    .article-grid {
      grid-template-columns: 1fr;
    }

    .journal-filters {
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: var(--space-4);
    }

    .filter-button {
      flex: 0 0 auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .journal-cover img,
    .article-card a,
    .article-card img {
      transition: none;
    }

    .journal-cover:hover img,
    .article-card a:hover,
    .article-card a:hover img {
      transform: none;
    }
  }
</style>
