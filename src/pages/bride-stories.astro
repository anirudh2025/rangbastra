---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/primitives/Button.astro";
import Container from "../components/primitives/Container.astro";
import Eyebrow from "../components/primitives/Eyebrow.astro";
import Icon from "../components/primitives/Icon.astro";
import Section from "../components/primitives/Section.astro";
import Footer from "../sections/home/Footer.astro";
import { brideStories } from "../data/brideStories";

const whatsappUrl = "https://wa.me/918077124409";
const timeline = ["Dream", "Conversation", "Sketch", "Craft", "Wedding Day"];
const gallery = [
  brideStories[0],
  brideStories[1],
  brideStories[2],
  brideStories[0],
  brideStories[2],
];
---

<BaseLayout
  title="Bride Stories | Rangbastra"
  description="Handwritten wedding memories, bride chapters and emotional couture stories from the Rangbastra atelier."
  canonical="/bride-stories"
  image={brideStories[0].image}
>
  <Section class="bride-section">
    <Container class="bride-container">
      <section class="bride-hero" aria-labelledby="bride-heading">
        <figure class="bride-hero__image">
          <img src={brideStories[0].image} alt={brideStories[0].imageAlt} loading="eager" decoding="async" />
        </figure>
        <div class="bride-hero__copy">
          <Eyebrow>Bride Stories</Eyebrow>
          <h1 id="bride-heading">Letters From The Wedding Morning</h1>
          <p>
            Soft memories from brides who began with a feeling and left with a
            couture chapter of their own.
          </p>
          <Button href="/design-your-outfit">Become Our Next Story</Button>
        </div>
      </section>

      <section class="story-intro" aria-labelledby="story-intro-heading">
        <p>Every Bride Has A Story</p>
        <h2 id="story-intro-heading">
          Some are spoken in colour. Some are hidden in thread. Some are kept
          quietly inside the final fitting.
        </h2>
      </section>

      <section class="bride-chapters" aria-label="Featured bride chapters">
        {brideStories.map((story, index) => (
          <article class="bride-chapter">
            <figure>
              <img src={story.image} alt={story.imageAlt} loading="lazy" decoding="async" />
            </figure>
            <div class="bride-chapter__copy">
              <span>Chapter 0{index + 1} / {story.occasion}</span>
              <h2>{story.chapterTitle}</h2>
              <p>{story.memory}</p>
              <blockquote>{story.quote}</blockquote>
              <small>{story.brideName}, {story.city}</small>
            </div>
          </article>
        ))}
      </section>

      <section class="memory-timeline" aria-labelledby="memory-timeline-heading">
        <div class="memory-timeline__heading">
          <Eyebrow>The Journey</Eyebrow>
          <h2 id="memory-timeline-heading">From First Dream To Wedding Day</h2>
        </div>
        <ol>
          {timeline.map((step, index) => (
            <li>
              <span>0{index + 1}</span>
              <strong>{step}</strong>
            </li>
          ))}
        </ol>
      </section>

      <section class="wedding-gallery" aria-labelledby="wedding-gallery-heading">
        <div class="gallery-heading">
          <Eyebrow>Wedding Gallery</Eyebrow>
          <h2 id="wedding-gallery-heading">Fragments Of Celebration</h2>
        </div>
        <div class="gallery-mosaic">
          {gallery.map((story, index) => (
            <figure class:list={["gallery-frame", index === 1 && "gallery-frame--wide", index === 3 && "gallery-frame--tall"]}>
              <img src={story.image} alt={story.imageAlt} loading="lazy" decoding="async" />
            </figure>
          ))}
        </div>
      </section>

      <section class="bride-letters" aria-labelledby="bride-letters-heading">
        <div>
          <Eyebrow>Letters</Eyebrow>
          <h2 id="bride-letters-heading">Written After The Celebration</h2>
        </div>
        <div class="letter-stack">
          {brideStories.map((story) => (
            <article class="letter">
              <Icon name="signature" size={28} />
              <p>{story.letter}</p>
              <span>{story.brideName}</span>
            </article>
          ))}
        </div>
      </section>

      <aside class="next-story" aria-labelledby="next-story-heading">
        <div>
          <Eyebrow>Become Our Next Story</Eyebrow>
          <h2 id="next-story-heading">Let Your Outfit Remember More Than The Day</h2>
        </div>
        <p>
          Begin with your celebration, your family details and the feeling you
          want to carry into the room.
        </p>
        <div class="next-story__actions">
          <Button href="/design-your-outfit">Become Our Next Story</Button>
          <a href={whatsappUrl} class="whatsapp-link">
            <Icon name="whatsapp" size={18} />
            WhatsApp
          </a>
        </div>
      </aside>
    </Container>
  </Section>
  <Footer />
</BaseLayout>

<style>
  :global(.bride-section) {
    --section-padding-block: 0 clamp(var(--space-10), 10vw, var(--space-13));
    overflow: hidden;
    background:
      radial-gradient(circle at 22% 18%, rgba(198, 169, 114, .14), transparent 30%),
      radial-gradient(circle at 88% 38%, rgba(198, 138, 138, .1), transparent 32%),
      var(--surface-canvas);
  }

  :global(.bride-container) {
    --container-default: var(--container-wide);
    --container-padding-inline: clamp(var(--space-5), 5vw, var(--space-10));
  }

  .bride-hero {
    display: grid;
    grid-template-columns: minmax(18rem, .46fr) minmax(0, .54fr);
    gap: clamp(var(--space-6), 7vw, var(--space-11));
    min-height: min(54rem, calc(100svh - var(--navbar-height)));
    align-items: center;
    padding-top: clamp(var(--space-12), 14vw, var(--space-14));
  }

  .bride-hero__image {
    position: relative;
    min-height: clamp(30rem, 58vw, 46rem);
    overflow: hidden;
    border: 1px solid rgba(198, 169, 114, .22);
  }

  .bride-hero__image::after {
    content: "Memory";
    position: absolute;
    right: -1rem;
    bottom: clamp(var(--space-4), 5vw, var(--space-8));
    color: rgba(255, 255, 255, .08);
    font-family: var(--font-display);
    font-size: clamp(5rem, 10vw, 10rem);
    line-height: .8;
  }

  .bride-hero__image img,
  .bride-chapter img,
  .gallery-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bride-hero__image img {
    min-height: inherit;
    opacity: .82;
  }

  .bride-hero__copy {
    display: grid;
    gap: var(--space-5);
    justify-items: start;
  }

  h1,
  h2 {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    letter-spacing: var(--tracking-heading);
  }

  h1 {
    max-width: 10ch;
    font-size: clamp(3.5rem, 8vw, 8.6rem);
    line-height: .92;
  }

  .bride-hero__copy p,
  .bride-chapter__copy p,
  .next-story p {
    max-width: var(--measure-sm);
    color: var(--text-secondary);
    font-size: var(--body-lg);
    line-height: var(--leading-body);
  }

  .story-intro {
    display: grid;
    grid-template-columns: minmax(10rem, .24fr) minmax(0, .76fr);
    gap: clamp(var(--space-5), 8vw, var(--space-12));
    padding-block: clamp(var(--space-9), 10vw, var(--space-13));
    border-block: 1px solid rgba(255, 255, 255, .08);
  }

  .story-intro p,
  .bride-chapter__copy span,
  .memory-timeline li span,
  .letter span {
    color: var(--sand-200);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .story-intro h2 {
    max-width: 18ch;
    font-size: clamp(2.8rem, 5.8vw, 6.6rem);
    line-height: 1;
  }

  .bride-chapters {
    display: grid;
    gap: clamp(var(--space-8), 9vw, var(--space-13));
    padding-block: clamp(var(--space-9), 10vw, var(--space-13));
  }

  .bride-chapter {
    display: grid;
    grid-template-columns: minmax(16rem, .42fr) minmax(0, .48fr);
    gap: clamp(var(--space-5), 7vw, var(--space-11));
    align-items: center;
  }

  .bride-chapter:nth-child(even) {
    grid-template-columns: minmax(0, .48fr) minmax(16rem, .42fr);
  }

  .bride-chapter:nth-child(even) figure {
    order: 2;
  }

  .bride-chapter figure {
    min-height: clamp(26rem, 48vw, 40rem);
    overflow: hidden;
    border: 1px solid rgba(198, 169, 114, .18);
  }

  .bride-chapter__copy {
    display: grid;
    gap: var(--space-4);
  }

  .bride-chapter__copy h2 {
    max-width: 11ch;
    font-size: clamp(2.8rem, 5vw, 5.8rem);
    line-height: .98;
  }

  blockquote {
    max-width: 28rem;
    margin: var(--space-3) 0 0;
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 3vw, 3.2rem);
    font-weight: var(--weight-light);
    line-height: 1.18;
  }

  small {
    color: var(--text-muted);
    font-size: var(--caption);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .memory-timeline {
    display: grid;
    grid-template-columns: minmax(0, .36fr) minmax(0, .64fr);
    gap: clamp(var(--space-6), 8vw, var(--space-12));
    align-items: start;
    padding: clamp(var(--space-7), 8vw, var(--space-11));
    border: 1px solid rgba(198, 169, 114, .18);
    background: rgba(255, 255, 255, .025);
  }

  .memory-timeline h2,
  .gallery-heading h2,
  .bride-letters h2,
  .next-story h2 {
    max-width: 13ch;
    margin-top: var(--space-4);
    font-size: clamp(2.6rem, 5vw, 5.4rem);
    line-height: 1;
  }

  .memory-timeline ol {
    display: grid;
    gap: 0;
    list-style: none;
    counter-reset: none;
  }

  .memory-timeline li {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: var(--space-4);
    align-items: center;
    min-height: 5.6rem;
    border-bottom: 1px solid rgba(255, 255, 255, .08);
  }

  .memory-timeline li:last-child {
    border-bottom: 0;
  }

  .memory-timeline strong {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: var(--weight-light);
  }

  .wedding-gallery,
  .bride-letters,
  .next-story {
    padding-top: clamp(var(--space-9), 10vw, var(--space-13));
  }

  .gallery-heading {
    margin-bottom: var(--space-6);
  }

  .gallery-mosaic {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    grid-auto-rows: clamp(12rem, 18vw, 20rem);
    gap: var(--space-3);
  }

  .gallery-frame {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, .08);
  }

  .gallery-frame--wide {
    grid-column: span 3;
  }

  .gallery-frame--tall {
    grid-row: span 2;
  }

  .gallery-frame:not(.gallery-frame--wide) {
    grid-column: span 2;
  }

  .gallery-frame img {
    opacity: .82;
    transition: transform 900ms var(--ease-luxury), opacity 900ms var(--ease-luxury);
  }

  .gallery-frame:hover img {
    opacity: .94;
    transform: scale(1.045);
  }

  .bride-letters {
    display: grid;
    grid-template-columns: minmax(0, .32fr) minmax(0, .68fr);
    gap: clamp(var(--space-6), 8vw, var(--space-12));
  }

  .letter-stack {
    display: grid;
    gap: var(--space-4);
  }

  .letter {
    display: grid;
    gap: var(--space-4);
    padding: clamp(var(--space-5), 5vw, var(--space-7));
    border: 1px solid rgba(255, 255, 255, .08);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, .04), transparent),
      rgba(255, 255, 255, .02);
  }

  .letter p {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.2vw, 3.4rem);
    font-weight: var(--weight-light);
    line-height: 1.18;
  }

  .next-story {
    display: grid;
    grid-template-columns: minmax(0, .45fr) minmax(16rem, .28fr) auto;
    gap: clamp(var(--space-5), 6vw, var(--space-9));
    align-items: center;
  }

  .next-story__actions {
    display: grid;
    justify-items: start;
    gap: var(--space-4);
  }

  .whatsapp-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-primary);
    font-size: var(--label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    text-decoration: none;
    text-transform: uppercase;
  }

  @media (max-width: 1024px) {
    .bride-hero,
    .story-intro,
    .bride-chapter,
    .bride-chapter:nth-child(even),
    .memory-timeline,
    .bride-letters,
    .next-story {
      grid-template-columns: 1fr;
    }

    .bride-chapter:nth-child(even) figure {
      order: 0;
    }
  }

  @media (max-width: 640px) {
    .bride-hero {
      min-height: auto;
      padding-top: clamp(var(--space-11), 28vw, var(--space-13));
    }

    .gallery-mosaic {
      grid-template-columns: 1fr;
      grid-auto-rows: 18rem;
    }

    .gallery-frame,
    .gallery-frame--wide,
    .gallery-frame--tall,
    .gallery-frame:not(.gallery-frame--wide) {
      grid-column: auto;
      grid-row: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-frame img {
      transition: none;
    }

    .gallery-frame:hover img {
      transform: none;
    }
  }
</style>
