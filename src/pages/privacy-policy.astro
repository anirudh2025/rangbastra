---
import EditorialInfoPage from "../components/support/EditorialInfoPage.astro";

const blocks = [
  {
    title: "Information We Receive",
    body: [
      "When you contact Rangbastra through the website, WhatsApp, email, Instagram or the Design Your Outfit inquiry flow, you may share details such as your name, contact information, event date, outfit references, measurements, budget direction, city and design preferences.",
      "This website currently does not process online payments or run a customer backend account system for completed transactions. Any couture discussion continues through direct atelier communication.",
    ],
  },
  {
    title: "How We Use Information",
    body: [
      "We use inquiry details to understand your couture requirement, respond to your questions, prepare for design discussions, suggest suitable craft directions and coordinate appointments, fittings or delivery conversations.",
      "Reference images and design notes are used only to guide the custom couture process and are not treated as permission to publicly display your personal materials.",
    ],
  },
  {
    title: "WhatsApp, Email And Social Communication",
    body: [
      "Rangbastra may communicate with you through WhatsApp, email, phone or Instagram when you choose those channels. Messages sent through those services are also subject to their own privacy practices.",
      "Please avoid sending sensitive financial information, identity documents or payment credentials through casual messaging channels unless a secure process is specifically confirmed.",
    ],
  },
  {
    title: "Sharing And Retention",
    body: [
      "We do not sell personal information. Details may be shared only with trusted team members, designers, artisans or service partners when needed to support your couture journey.",
      "Inquiry and design communication may be retained for continuity, moderation, record keeping and future reference unless you ask us to delete information we are no longer required to keep.",
    ],
  },
  {
    title: "Your Choices",
    body: [
      "You may ask us to update, correct or delete your contact details by emailing the atelier. You may also request that we stop promotional communication.",
      "For privacy questions, contact Rangbastra through the email listed on the Contact page.",
    ],
  },
];
---

<EditorialInfoPage
  title="Privacy Policy | Rangbastra"
  description="Rangbastra privacy policy for custom couture inquiries, WhatsApp and email communication, design discussions and appointment-led boutique experiences."
  canonical="/privacy-policy"
  eyebrow="Privacy Policy"
  heading="How We Protect Your Couture Notes"
  intro="A clear privacy note for visitors beginning a custom couture conversation with Rangbastra."
  blocks={blocks}
/>
