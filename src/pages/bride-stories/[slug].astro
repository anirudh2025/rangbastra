---
import BaseLayout from "../../layouts/BaseLayout.astro"; import Button from "../../components/primitives/Button.astro"; import Container from "../../components/primitives/Container.astro"; import Eyebrow from "../../components/primitives/Eyebrow.astro"; import Section from "../../components/primitives/Section.astro"; import SignatureCTA from "../../components/experience/SignatureCTA.astro"; import Footer from "../../sections/home/Footer.astro"; import { brideStories, type BrideStory } from "../../data/brideStories";
export const getStaticPaths=()=>brideStories.map(story=>({params:{slug:story.slug},props:{story}}));
const { story }=Astro.props as { story: BrideStory };
---
<BaseLayout title={`${story.chapterTitle} | Bride Stories | Rangbastra`} description={story.weddingContext} canonical={`/bride-stories/${story.slug}`} image={story.image}><Section class="story-detail"><Container class="story-detail__container"><header><Eyebrow>{story.status==="demo"?"Preview Story Format":"Bride Story"}</Eyebrow><h1>{story.chapterTitle}</h1><p>{story.weddingContext}</p></header>{story.status==="demo"&&<aside><strong>Not a testimonial</strong> This Preview-only record demonstrates the page structure. Consent, source and a genuine quote are required before publication.</aside>}<section class="context"><figure><img src={story.image} alt={story.imageAlt} width="900" height="1125" decoding="async"/></figure><div><h2>Wedding and garment context</h2><dl><div><dt>Story</dt><dd>{story.brideName}</dd></div><div><dt>Location</dt><dd>{story.city}</dd></div><div><dt>Garment</dt><dd>{story.garment}</dd></div><div><dt>Source</dt><dd>{story.source??"Pending owner confirmation"}</dd></div><div><dt>Consent</dt><dd>{story.consentConfirmed?"Confirmed":"Not confirmed"}</dd></div></dl><blockquote>{story.quote}</blockquote></div></section><section class="gallery"><Eyebrow>Gallery</Eyebrow><h2>Celebration details</h2><div>{story.gallery.map(image=><figure><img src={image.src} alt={image.alt} width="900" height="1125" loading="lazy" decoding="async"/></figure>)}</div></section><section class="related"><Eyebrow>Related Pieces</Eyebrow><h2>Continue through the collection</h2><div>{story.relatedPieceSlugs.map(slug=><Button href={`/products/${slug}`}>Explore {slug}</Button>)}</div></section><SignatureCTA variant="consultation"/></Container></Section><Footer/></BaseLayout>
<style>:global(.story-detail){--section-padding-block:clamp(var(--space-12),14vw,var(--space-14)) clamp(var(--space-10),10vw,var(--space-13));background:var(--surface-canvas)}:global(.story-detail__container){--container-default:var(--container-wide);display:grid;gap:clamp(var(--space-8),9vw,var(--space-12))}header{display:grid;max-width:60rem;gap:var(--space-5)}h1,h2,blockquote{color:var(--text-primary);font-family:var(--font-display);font-weight:var(--weight-light);line-height:1}h1{font-size:clamp(3.2rem,7vw,7.8rem)}h2{font-size:clamp(2.5rem,5vw,5rem)}p,dd,aside{color:var(--text-secondary);line-height:var(--leading-body)}aside{padding:var(--space-4);border:1px solid var(--cocoa-border);background:rgba(var(--cocoa-rgb),.1)}.context{display:grid;grid-template-columns:minmax(18rem,.45fr) minmax(0,.55fr);gap:clamp(var(--space-6),8vw,var(--space-11));align-items:center}.context figure{min-height:34rem}.context img,.gallery img{width:100%;height:100%;object-fit:cover}.context>div,.gallery,.related{display:grid;gap:var(--space-5)}dl{display:grid;gap:var(--space-3)}dl div{display:grid;grid-template-columns:7rem 1fr;gap:var(--space-3)}dt{color:var(--text-muted);text-transform:uppercase}blockquote{font-size:clamp(2rem,3.5vw,3.6rem)}.gallery>div{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:var(--space-4)}.gallery figure{aspect-ratio:4/5}.related>div{display:flex;flex-wrap:wrap;gap:var(--space-3)}@media(max-width:760px){.context,.gallery>div{grid-template-columns:1fr}.context figure{min-height:28rem}}</style>
