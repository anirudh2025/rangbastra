---
import BaseLayout from "../layouts/BaseLayout.astro"; import Section from "../components/primitives/Section.astro"; import Container from "../components/primitives/Container.astro"; import BrandMilestoneTimeline from "../components/experience/BrandMilestoneTimeline.astro"; import SignatureCTA from "../components/experience/SignatureCTA.astro"; import Footer from "../sections/home/Footer.astro";
---
<BaseLayout title="The Rangbastra Journey | Rangbastra" description="Explore confirmed Rangbastra milestones and the future mission of its digital couture experience." canonical="/rangbastra-journey"><Section class="experience-section"><Container class="experience-container"><BrandMilestoneTimeline/><SignatureCTA variant="editorial"/></Container></Section><Footer/></BaseLayout>
<style>:global(.experience-section){--section-padding-block:0 clamp(var(--space-10),10vw,var(--space-13));background:linear-gradient(90deg,transparent 8%,rgba(var(--cocoa-rgb),.06) 8.1%,transparent 8.2%),var(--surface-canvas)}:global(.experience-container){--container-default:var(--container-wide);display:grid;gap:clamp(var(--space-10),10vw,var(--space-13))}</style>
