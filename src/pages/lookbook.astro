---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/primitives/Container.astro";
import Section from "../components/primitives/Section.astro";
import LookbookReader from "../components/editorial/LookbookReader.astro";
import EditorialMarquee from "../components/editorial/EditorialMarquee.astro";
import SignatureCTA from "../components/experience/SignatureCTA.astro";
import Footer from "../sections/home/Footer.astro";
import { lookbookPages } from "../data/lookbookBook";
---

<BaseLayout
  title="Editorial Lookbook | Rangbastra"
  description="Read the Rangbastra editorial lookbook as an accessible digital book with bridal, festive and evening couture chapters."
  canonical="/lookbook"
  image={lookbookPages[0].image}
  ><Section class="lookbook-book"
    ><Container class="lookbook-book__container"
      ><LookbookReader /><EditorialMarquee
        phrases={[
          "Bridal Couture",
          "Considered Craft",
          "Designed Around Your Story",
          "Occasion Dressing",
        ]}
        label="Lookbook themes"
      /><SignatureCTA variant="collection" /></Container
    ></Section
  ><Footer /></BaseLayout
>
<style>
  :global(.lookbook-book) {
    --section-padding-block: 0 clamp(var(--space-10), 10vw, var(--space-13));
    overflow: hidden;
    background:
      radial-gradient(
        circle at 82% 12%,
        rgba(var(--cocoa-rgb), 0.12),
        transparent 34%
      ),
      #000;
  }
  :global(.lookbook-book__container) {
    --container-default: var(--container-wide);
    display: grid;
    gap: clamp(var(--space-8), 8vw, var(--space-12));
  }
</style>
