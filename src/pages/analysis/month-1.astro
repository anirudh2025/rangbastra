---
import PageLayout from "../../layouts/PageLayout.astro";
import { monthOne, metricLabels, type MetricKey } from "../../data/analytics/month-1";
if (import.meta.env.PROD && import.meta.env.PUBLIC_ENABLE_INTERNAL_ANALYTICS !== "true") {
  return Astro.redirect("/404", 302);
}
const primary:MetricKey[]=["views","likes","profileVisits","shares","saves","followers"];
const allMetrics=Object.keys(metricLabels) as MetricKey[];
const chartMetrics:MetricKey[]=["views","likes","profileVisits","shares","saves","followers"];
const fmt=(n:number)=>new Intl.NumberFormat("en-IN").format(n);
---
<PageLayout title="Instagram Growth — Month 01 | Rangbastra" description="Rangbastra Instagram performance intelligence for 10 May to 9 June." canonical="/analysis/month-1">
<main class="report" data-analytics-report>
  <header class="report-hero">
    <div class="report-hero__copy"><p class="eyebrow">{monthOne.eyebrow}</p><h1>{monthOne.title}</h1><p class="lede">{monthOne.introduction}</p><div class="report-meta"><span>{monthOne.dates}</span><span>Prepared by {monthOne.preparedBy}</span></div></div>
    <div class="growth-orbit" aria-hidden="true">{monthOne.weeks.map((week,i)=><span style={`--i:${i}`}><b>{String(i+1).padStart(2,"0")}</b></span>)}</div>
  </header>

  <nav class="report-tabs" aria-label="Reporting periods"><div role="tablist" aria-label="Select analysis period">
    <button role="tab" aria-selected="true" aria-controls="overview" data-report-tab="overview">Month Overview</button>
    {monthOne.weeks.map(w=><button role="tab" aria-selected="false" aria-controls={w.id} data-report-tab={w.id}>{w.label}</button>)}
  </div><button class="export" type="button" data-print>Export Report</button></nav>

  <section class="report-panel" id="overview" role="tabpanel" tabindex="0" data-report-panel>
    <header class="section-heading"><p class="eyebrow">Executive overview</p><h2>Month 01, in perspective.</h2><p>Cumulative across four reporting periods.</p></header>
    <div class="metrics">{primary.map(key=><button class="metric" type="button" data-metric-card><span>{metricLabels[key]}</span><strong data-counter={monthOne.totals[key]}>0</strong><small>Cumulative across four reporting periods.</small></button>)}</div>
    <blockquote>{monthOne.summary}</blockquote>
    <section class="comparison" aria-labelledby="comparison-title">
      <div class="comparison__head"><div><p class="eyebrow">Weekly comparison</p><h2 id="comparison-title">Four periods. One growth story.</h2></div><div class="metric-select" role="group" aria-label="Chart metric">{chartMetrics.map((key,i)=><button class:list={[i===0&&"active"]} data-chart-metric={key}>{metricLabels[key]}</button>)}</div></div>
      <div class="chart" data-chart data-weeks={JSON.stringify(monthOne.weeks.map(w=>({id:w.id,label:w.label,metrics:w.metrics})))}><svg viewBox="0 0 760 330" role="img" aria-labelledby="chart-title chart-desc"><title id="chart-title">Weekly Views comparison</title><desc id="chart-desc">Four bars compare the selected metric across Weeks 1 to 4.</desc><g class="chart-grid">{[0,1,2,3,4].map(i=><line x1="70" x2="735" y1={45+i*58} y2={45+i*58}/>)}</g><g data-chart-bars></g></svg><div class="chart-tooltip" data-chart-tooltip hidden></div></div>
      <table class="sr-table"><caption>Accessible weekly comparison data</caption><thead><tr><th>Week</th>{chartMetrics.map(k=><th>{metricLabels[k]}</th>)}</tr></thead><tbody>{monthOne.weeks.map(w=><tr><th>{w.label}</th>{chartMetrics.map(k=><td>{fmt(w.metrics[k])}</td>)}</tr>)}</tbody></table>
    </section>
    <section class="benchmarks"><header class="section-heading"><p class="eyebrow">Performance benchmarks</p><h2>Reading quality, not only volume.</h2></header><div class="benchmark-table" role="table"><div class="benchmark-row benchmark-head" role="row"><span>Metric</span><span>Poor</span><span>Average</span><span>Good</span><span>Excellent</span></div>{monthOne.benchmarks.map(b=><div class="benchmark-row" role="row"><strong>{b.metric}</strong>{b.ranges.map(r=><span>{r}</span>)}</div>)}</div></section>
    <section class="findings"><header class="section-heading"><p class="eyebrow">Strategic findings</p><h2>What Month 01 Taught Us</h2></header><div class="insights">{monthOne.findings.map((item,i)=>{const [title,copy]=item.split("|");return <details><summary><span>{String(i+1).padStart(2,"0")}</span>{title}</summary><p>{copy}</p></details>})}</div></section>
    <section class="roadmap"><p class="eyebrow">Next-month roadmap</p><h2>Turn signals into momentum.</h2><ol>{monthOne.recommendations.map((r,i)=><li><span>{String(i+1).padStart(2,"0")}</span>{r}</li>)}</ol></section>
  </section>

  {monthOne.weeks.map(week=><section class="report-panel week" id={week.id} role="tabpanel" tabindex="0" data-report-panel hidden>
    <header class="section-heading"><p class="eyebrow">{week.label} · {week.dates}</p><h2>Performance, content and audience.</h2><button type="button" data-back-overview>← Back to Overview</button></header>
    <div class="metrics week-metrics">{allMetrics.map(key=><button class="metric" type="button" data-metric-card><span>{metricLabels[key]}</span><strong>{fmt(week.metrics[key])}</strong>{week.differences?.[key]!==undefined&&<small class:list={[week.differences[key]!>=0?"positive":"negative"]}>{week.differences[key]!>0?"+":""}{fmt(week.differences[key]!) } vs prior week</small>}</button>)}</div>
    <div class="audience-grid"><article><span>Follower views</span><strong>{week.followerViews}</strong></article><article><span>Non-follower views</span><strong>{week.nonFollowerViews}</strong></article><article><span>Approximate audience</span><strong>{week.audience}</strong></article><article><span>Average daily activity</span><strong>{week.activity}</strong></article></div>
    {week.note&&<aside class="operational-note"><span>Operational context</span><p>{week.note}</p></aside>}
    <div class="week-story"><section><p class="eyebrow">Content performance</p><h3>Top performers</h3><div class="performers">{week.performers.map(p=><article><span>{p.category}</span><strong>{p.name}</strong><small>{p.result}</small></article>)}</div></section><aside class="insight-panel"><p class="eyebrow">Interpretation</p><h3>The signal behind the numbers.</h3><p>{week.insight}</p></aside></div>
  </section>)}
</main>
</PageLayout>

<script>
 import { initAnalyticsReport } from "../../lib/analytics/report";
 document.addEventListener("astro:page-load",initAnalyticsReport); initAnalyticsReport();
</script>

<style>
 .report{--cream:#f2e9df;--wine:#4b1721;--wine-2:#6d2633;min-height:100vh;padding-top:calc(var(--navbar-height) + 3rem);background:radial-gradient(circle at 85% 8%,rgba(157,123,105,.18),transparent 26%),var(--obsidian-1000);color:var(--text-primary)}
 .report-hero{display:grid;grid-template-columns:1.3fr .7fr;align-items:center;min-height:70svh;width:min(92rem,calc(100% - 4rem));margin:auto;padding:5rem 0}.eyebrow{margin:0 0 1rem;color:var(--cocoa-400);font-size:var(--caption);font-weight:600;letter-spacing:.16em;text-transform:uppercase}.report h1,.report h2,.report h3{font-family:var(--font-display);font-weight:300}.report h1{max-width:12ch;margin:0;font-size:clamp(4rem,8vw,8.5rem);line-height:.85}.lede{max-width:46rem;margin:2rem 0;color:var(--text-secondary);font-size:var(--body-lg);line-height:1.7}.report-meta{display:flex;gap:2rem;font-size:.8rem;letter-spacing:.1em;text-transform:uppercase}.growth-orbit{position:relative;aspect-ratio:1;border:1px solid rgba(255,255,255,.09);border-radius:50%}.growth-orbit::before{content:"";position:absolute;inset:18%;border:1px solid rgba(255,203,100,.22);border-radius:50%}.growth-orbit span{position:absolute;left:50%;top:50%;transform:rotate(calc(var(--i)*90deg)) translateY(-44%) translateY(-12vw) rotate(calc(var(--i)*-90deg));display:grid;place-items:center;width:3.5rem;height:3.5rem;border-radius:50%;background:var(--wine);color:var(--cream);box-shadow:0 0 45px rgba(191,142,42,.15)}
 .report-tabs{position:sticky;top:calc(var(--navbar-height) + 1rem);z-index:20;display:flex;justify-content:space-between;align-items:center;width:min(92rem,calc(100% - 2rem));margin:auto;padding:.55rem;border:1px solid var(--glass-border);border-radius:var(--radius-pill);background:rgba(8,6,6,.82);backdrop-filter:blur(18px)}.report-tabs [role=tablist]{display:flex;overflow:auto}.report-tabs button{min-height:44px;padding:.65rem 1.1rem;border:0;border-radius:var(--radius-pill);background:transparent;color:var(--text-secondary);white-space:nowrap;cursor:pointer}.report-tabs [aria-selected=true]{background:var(--wine);color:white}.report-tabs .export{border:1px solid rgba(255,203,100,.25);color:var(--sand-200)}
 .report-panel{width:min(92rem,calc(100% - 4rem));margin:auto;padding:8rem 0}.section-heading{max-width:56rem;margin-bottom:3.5rem}.section-heading h2,.roadmap h2{margin:.2rem 0;font-size:clamp(3rem,6vw,6rem);line-height:.95}.section-heading>p:last-child{color:var(--text-muted)}.section-heading button{margin-top:1rem;border:0;background:none;color:var(--sand-200);cursor:pointer}
 .metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.metric{min-height:13rem;padding:1.5rem;border:1px solid var(--glass-border);border-radius:var(--radius-lg);background:linear-gradient(145deg,rgba(255,255,255,.06),rgba(255,255,255,.015));color:inherit;text-align:left;cursor:pointer;transition:transform .35s var(--ease-luxury),border-color .35s}.metric:hover,.metric:focus-visible{transform:translateY(-4px);border-color:rgba(255,203,100,.28)}.metric span,.metric small{display:block;color:var(--text-muted);font-size:.72rem;letter-spacing:.08em;text-transform:uppercase}.metric strong{display:block;margin:1.2rem 0;font-family:var(--font-display);font-size:clamp(2.7rem,5vw,5rem);font-weight:300}.metric small{line-height:1.5}.positive{color:#9fc7a7!important}.negative{color:#d9a0a0!important}blockquote{margin:5rem 0;padding:3rem clamp(1.5rem,5vw,5rem);border-left:1px solid var(--gold-500);background:linear-gradient(90deg,rgba(75,23,33,.55),transparent);font-family:var(--font-display);font-size:clamp(1.6rem,3vw,3rem);line-height:1.35}
 .comparison,.benchmarks,.findings,.roadmap{padding:6rem 0;border-top:1px solid var(--border-default)}.comparison__head{display:flex;justify-content:space-between;gap:2rem}.comparison h2{margin:.3rem 0;font-size:clamp(2.6rem,5vw,5rem)}.metric-select{display:flex;align-self:end;flex-wrap:wrap;gap:.4rem}.metric-select button{min-height:44px;border:1px solid var(--border-default);border-radius:var(--radius-pill);background:transparent;color:var(--text-secondary);cursor:pointer}.metric-select .active{border-color:var(--gold-500);color:var(--sand-100)}.chart{position:relative;margin-top:3rem;padding:2rem;border:1px solid var(--border-default);border-radius:var(--radius-lg);background:rgba(255,255,255,.02)}.chart svg{display:block;width:100%;min-height:20rem}.chart-grid line{stroke:rgba(255,255,255,.08)}.chart-tooltip{position:absolute;padding:.65rem .8rem;border:1px solid var(--glass-border);border-radius:.6rem;background:#160d0f;pointer-events:none}.sr-table{position:absolute;width:1px;height:1px;overflow:hidden;clip-path:inset(50%)}
 .benchmark-table{border:1px solid var(--border-default);border-radius:var(--radius-lg);overflow:hidden}.benchmark-row{display:grid;grid-template-columns:1.3fr repeat(4,1fr)}.benchmark-row>*{padding:1.25rem;border-bottom:1px solid var(--border-default)}.benchmark-head{background:var(--wine);font-size:.75rem;text-transform:uppercase}.insights{display:grid;grid-template-columns:1fr 1fr;gap:1rem}.insights details{padding:1.5rem;border:1px solid var(--border-default);border-radius:var(--radius-lg);background:rgba(255,255,255,.025)}.insights summary{display:flex;gap:1rem;align-items:center;min-height:44px;font-family:var(--font-display);font-size:1.6rem;cursor:pointer}.insights summary span{color:var(--gold-500);font-family:var(--font-body);font-size:.7rem}.insights details p{color:var(--text-secondary);line-height:1.7}.roadmap ol{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;padding:1px;background:var(--border-default);list-style:none}.roadmap li{display:flex;gap:1rem;padding:1.5rem;background:var(--obsidian-1000);line-height:1.6}.roadmap li span{color:var(--gold-500);font-size:.7rem}
 .week-metrics{grid-template-columns:repeat(4,1fr)}.week-metrics .metric{min-height:10rem}.week-metrics .metric strong{font-size:3rem}.audience-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin:2rem 0}.audience-grid article{padding:1.5rem;border-bottom:1px solid var(--gold-600)}.audience-grid span,.performers span{display:block;color:var(--text-muted);font-size:.72rem;text-transform:uppercase}.audience-grid strong{display:block;margin-top:.8rem}.operational-note{margin:3rem 0;padding:2rem;border:1px solid rgba(255,203,100,.25);border-radius:var(--radius-lg);background:rgba(75,23,33,.45)}.operational-note span{color:var(--gold-400);font-size:.75rem;text-transform:uppercase}.operational-note p{max-width:70rem;line-height:1.7}.week-story{display:grid;grid-template-columns:1.35fr .65fr;gap:2rem;margin-top:5rem}.week-story h3{font-size:3rem}.performers{display:grid;grid-template-columns:1fr 1fr;gap:1rem}.performers article{padding:1.5rem;border:1px solid var(--border-default);border-radius:var(--radius-md)}.performers strong,.performers small{display:block;margin-top:.6rem}.performers small{color:var(--sand-200)}.insight-panel{align-self:start;position:sticky;top:calc(var(--navbar-height) + 7rem);padding:2rem;border-radius:var(--radius-lg);background:var(--cream);color:#25191a}.insight-panel p:last-child{line-height:1.8}
 @media(max-width:1024px){.report-hero{grid-template-columns:1fr}.growth-orbit{display:none}.metrics,.week-metrics{grid-template-columns:repeat(2,1fr)}.week-story{grid-template-columns:1fr}.insight-panel{position:static}.roadmap ol{grid-template-columns:1fr 1fr}}
 @media(max-width:700px){.report{padding-top:calc(var(--navbar-height) + 1rem)}.report-hero,.report-panel{width:calc(100% - 2rem)}.report-hero{min-height:65svh;padding:4rem 0}.report h1{font-size:clamp(3.4rem,17vw,5.3rem)}.report-meta{flex-direction:column;gap:.5rem}.report-tabs{top:calc(var(--navbar-height) + .5rem);border-radius:var(--radius-md)}.report-tabs .export{display:none}.report-panel{padding:5rem 0}.metrics,.week-metrics{grid-template-columns:1fr 1fr}.metric{min-height:9rem;padding:1rem}.metric strong,.week-metrics .metric strong{font-size:clamp(2rem,10vw,3rem)}.metric small{display:none}.comparison__head{display:block}.metric-select{margin-top:1.5rem;flex-wrap:nowrap;overflow:auto}.chart{padding:.5rem;overflow:hidden}.benchmark-table{overflow:auto}.benchmark-row{min-width:42rem}.insights,.audience-grid,.performers,.roadmap ol{grid-template-columns:1fr}.section-heading h2,.roadmap h2{font-size:clamp(2.7rem,14vw,4rem)}}
 @media(max-width:360px){.metrics,.week-metrics{grid-template-columns:1fr}.report-tabs{width:calc(100% - 1rem)}}
 @media(prefers-reduced-motion:reduce){*,*::before,*::after{scroll-behavior:auto!important}.metric{transition:none}}
 @media print{.report{padding:0;background:white;color:#1c1516}.report-tabs,.export{display:none!important}.report-panel{display:block!important;width:100%;padding:2rem 0;break-before:page}.report-hero{min-height:auto;width:100%;padding:2rem 0}.metric,.chart,.insights details{break-inside:avoid;border-color:#aaa;background:none}.eyebrow,.metric span,.metric small{color:#633}.sr-table{position:static;width:100%;height:auto;clip-path:none}.chart{display:none}}
</style>
