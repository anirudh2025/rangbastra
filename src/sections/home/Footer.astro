---
import Container from "../../components/primitives/Container.astro";
import Button from "../../components/primitives/Button.astro";
import Label from "../../components/primitives/Label.astro";
import Eyebrow from "../../components/primitives/Eyebrow.astro";
import { footerNavigation } from "../../data/footerNavigation";
import { contact, getWhatsAppHref } from "../../data/contact";
import rangbastraLogo from "../../assets/branding/Rangbastra Web Logo.svg";

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <Container class="footer-container">
    <section class="footer-invitation" aria-labelledby="footer-heading">
      <Eyebrow>Rangbastra Signature</Eyebrow>

      <h2 id="footer-heading">
        <span class="title-intro">Every Celebration Deserves</span>
        <span class="title-statement">A Signature</span>
      </h2>

      <p>
        A final note from the maison: may every thread, silhouette and memory
        you carry forward feel considered, intimate and beautifully your own.
      </p>

      <div class="footer-actions" aria-label="Connect with Rangbastra">
        <Button href="/design-your-outfit" class="footer-primary">
          <Label icon="designer" iconSize={14}>Design Your Outfit</Label>
        </Button>

        <Button href={contact.instagramUrl} target="_blank" class="footer-secondary" variant="instagram">
          <Label icon="instagram" iconSize={14}>Visit Instagram</Label>
        </Button>

        <Button href={getWhatsAppHref("homepage")} target="_blank" class="footer-secondary" variant="whatsapp">
          <Label icon="whatsapp" iconSize={14}>Message WhatsApp</Label>
        </Button>
      </div>
    </section>

    <div class="footer-divider" aria-hidden="true"></div>

    <nav class="footer-navigation" aria-label="Footer navigation">
      {
        footerNavigation.map((group) => (
          <section class="footer-nav-group" aria-labelledby={`footer-${group.title.toLowerCase()}`}>
            <h3 id={`footer-${group.title.toLowerCase()}`}>{group.title}</h3>

            <ul>
              {
                group.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      target={link.external ? "_blank" : undefined}
                      rel={link.external ? "noopener noreferrer" : undefined}
                    >
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </section>
        ))
      }
    </nav>

    <div class="brand-signature">
      <img
        class="brand-logo"
        src={rangbastraLogo.src}
        alt="Rangbastra"
        width="360"
        height="80"
        loading="eager"
        decoding="async"
      />

      <div class="brand-copy">
        <p>Crafted in India. Made to be remembered.</p>
        <p>Handcrafted for timeless celebrations.</p>
      </div>

      <p class="copyright">&copy; {currentYear} Rangbastra</p>
    </div>

    <p class="footer-credit">Digital Experience by Cloutora</p>
  </Container>
</footer>

<style>
  .site-footer {
    --footer-padding-block: clamp(var(--space-7), 7vw, var(--space-10));
    --footer-background: var(--surface-canvas);
    --footer-glow-opacity: .16;
    --footer-satin-opacity: .28;
    --footer-content-gap: clamp(var(--space-6), 5vw, var(--space-8));
    --footer-invitation-width: min(100%, 64rem);
    --footer-copy-width: var(--measure-sm);
    --footer-action-gap: var(--space-3);
    --footer-nav-gap: clamp(var(--space-5), 5vw, var(--space-8));
    --footer-link-gap: var(--space-3);
    --footer-signature-gap: var(--space-5);

    position: relative;
    overflow: hidden;
    padding-block: var(--footer-padding-block) var(--space-5);
    background:
      radial-gradient(
        circle at 50% 16%,
        rgba(106, 78, 66, var(--footer-glow-opacity)),
        transparent 34%
      ),
      radial-gradient(circle at 10% 82%, rgba(181, 147, 130, .07), transparent 30%),
      radial-gradient(circle at 92% 72%, rgba(106, 78, 66, .08), transparent 32%),
      rgba(0,0,0,.28);
  }

  .site-footer::before,
  .site-footer::after {
    content: "";
    position: absolute;
    z-index: 0;
    pointer-events: none;
  }

  .site-footer::before {
    top: 6%;
    right: -12%;
    width: min(58rem, 70vw);
    height: min(28rem, 38vw);
    background: var(--gradient-satin-fold);
    opacity: var(--footer-satin-opacity);
    transform: rotate(-10deg);
  }

  .site-footer::after {
    bottom: -14%;
    left: -16%;
    width: min(48rem, 64vw);
    height: min(34rem, 44vw);
    background:
      linear-gradient(140deg, transparent, rgba(181, 147, 130, .045), transparent),
      var(--gradient-satin-fold);
    opacity: calc(var(--footer-satin-opacity) * .78);
    transform: rotate(14deg);
  }

  :global(.footer-container) {
    --container-default: var(--container-wide);
    --container-padding-inline: clamp(var(--space-5), 5vw, var(--space-10));

    position: relative;
    z-index: var(--z-content);
    display: grid;
    gap: var(--footer-content-gap);
  }

  .footer-invitation {
    display: grid;
    justify-items: center;
    gap: clamp(var(--space-4), 3vw, var(--space-6));
    max-width: var(--footer-invitation-width);
    margin-inline: auto;
    text-align: center;
  }

  h2 {
    display: grid;
    gap: var(--space-2);
    max-width: min(100%, 58rem);
    color: var(--text-primary);
    font-family: var(--font-display);
    font-weight: var(--weight-editorial);
    font-synthesis: none;
    text-align: center;
    text-wrap: balance;
  }

  .title-intro {
    color: var(--text-primary);
    font-size: var(--section-heading-intro);
    letter-spacing: var(--tracking-heading);
    line-height: 1.18;
  }

  .title-statement {
    background: var(--gradient-primary);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    font-size: var(--section-heading-statement);
    letter-spacing: var(--tracking-heading);
    line-height: 1.12;
    padding-bottom: .08em;
  }

  .footer-invitation p {
    max-width: var(--footer-copy-width);
    color: var(--text-secondary);
    font-size: var(--body-lg);
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  .footer-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--footer-action-gap);
    padding-top: var(--space-2);
  }

  :global(.footer-primary),
  :global(.footer-secondary) {
    min-height: var(--button-height);
    box-shadow: var(--glow-soft), var(--shadow-inset);
  }

  :global(.footer-primary) {
    min-width: 14.75rem;
    background: var(--gradient-primary);
    isolation: isolate;
  }

  :global(.footer-secondary.button--instagram){background:linear-gradient(135deg,#515BD4 0%,#8134AF 28%,#DD2A7B 58%,#F58529 100%);background-clip:padding-box;color:#fff;border-color:transparent;box-shadow:none;}
  :global(.footer-secondary.button--whatsapp){background:linear-gradient(135deg,#128C7E 0%,#1dad68 58%,#25D366 100%);background-clip:padding-box;color:#fff;border-color:rgba(37,211,102,.48);box-shadow:none;}
  :global(.footer-secondary.button--instagram:hover),:global(.footer-secondary.button--whatsapp:hover){color:#fff;box-shadow:none;}

  :global(.footer-primary:hover),
  :global(.footer-primary:focus-visible) {
    background: var(--button-primary-gradient-hover);
    box-shadow: var(--glow-medium), var(--button-shadow-hover), var(--shadow-inset-strong);
  }

  :global(.footer-secondary) {
    min-width: 9.75rem;
    border: 1px solid var(--border-default);
    background: rgba(255, 255, 255, .025);
    color: var(--text-secondary);
  }

  :global(.footer-secondary:hover),
  :global(.footer-secondary:focus-visible) {
    border-color: var(--border-strong);
    background: rgba(255, 255, 255, .045);
    color: var(--text-primary);
    box-shadow: var(--shadow-inset-strong);
  }

  .footer-divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(181, 147, 130, .26),
      rgba(255, 255, 255, .08),
      rgba(181, 147, 130, .26),
      transparent
    );
    box-shadow: var(--glow-soft);
  }

  .footer-navigation {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--footer-nav-gap);
    align-items: start;
  }

  .footer-nav-group {
    display: grid;
    gap: var(--space-5);
  }

  .footer-nav-group h3 {
    color: var(--cocoa-400);
    font-size: var(--caption);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-caption);
    text-transform: uppercase;
  }

  .footer-nav-group ul {
    display: grid;
    gap: var(--footer-link-gap);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .footer-nav-group a {
    position: relative;
    display: inline-flex;
    width: fit-content;
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-size: clamp(.82rem, .86vw, .98rem);
    font-weight: var(--weight-medium);
    letter-spacing:.02em;
    line-height: var(--leading-caption);
    text-decoration: none;
    text-wrap: balance;
    transition:
      color var(--motion-medium) var(--ease-luxury),
      text-shadow var(--motion-medium) var(--ease-luxury),
      transform var(--motion-medium) var(--ease-luxury);
  }

  .footer-nav-group a::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: -.2em;
    left: 0;
    height: 1px;
    background: linear-gradient(90deg, var(--cocoa-400), transparent);
    opacity: .8;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--motion-medium) var(--ease-luxury);
  }

  .footer-nav-group a:hover,
  .footer-nav-group a:focus-visible {
    color: var(--text-primary);
    text-shadow: var(--glow-soft);
    transform: translate3d(0, var(--motion-card-lift), 0);
  }

  .footer-nav-group a:hover::after,
  .footer-nav-group a:focus-visible::after {
    transform: scaleX(1);
  }

  .footer-nav-group a:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: var(--space-2);
  }

  .brand-signature {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    gap: var(--footer-signature-gap);
    align-items: end;
    color: var(--text-muted);
  }

  .brand-logo {
    display: block;
    width: min(100%, clamp(16rem, 32vw, 29rem));
    height: auto;
    opacity: .92;
    filter: drop-shadow(0 0 18px rgba(181, 147, 130, .16));
  }

  .brand-copy {
    display: grid;
    gap: var(--space-2);
    max-width: 28rem;
  }

  .brand-copy p,
  .copyright {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--caption);
    line-height: var(--leading-caption);
    text-wrap: pretty;
  }

  .brand-copy p:first-child {
    color: var(--text-secondary);
  }

  .copyright {
    justify-self: end;
    white-space: nowrap;
  }

  .footer-credit {
    justify-self: end;
    margin: calc(var(--footer-signature-gap) * -0.5) 0 0;
    color: var(--text-muted);
    font-size: clamp(.65rem, .55vw, .78rem);
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-caption);
    opacity: .56;
    text-transform: uppercase;
  }

  @media (max-width: 1023px) {
    .footer-navigation {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-7);
    }

    .brand-signature {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .copyright {
      justify-self: start;
    }
  }

  @media (max-width: 767px) {
    .site-footer {
      --footer-padding-block: clamp(var(--space-8), 18vw, var(--space-11));
      --footer-glow-opacity: .13;
      --footer-satin-opacity: .2;
      --footer-content-gap: var(--space-7);
      --footer-nav-gap: var(--space-7);
      --footer-link-gap: var(--space-3);
    }

    .site-footer::before {
      top: 8%;
      right: -48%;
      width: 36rem;
      height: 20rem;
    }

    .site-footer::after {
      bottom: -8%;
      left: -48%;
      width: 32rem;
      height: 24rem;
    }

    :global(.footer-container) {
      --container-padding-inline: clamp(var(--space-4), 6vw, var(--space-6));
    }

    .footer-invitation {
      justify-items: start;
      gap: var(--space-5);
      text-align: left;
    }

    h2 {
      text-align: left;
    }

    .title-intro {
      font-size: var(--section-heading-intro-mobile);
    }

    .title-statement {
      font-size: var(--section-heading-statement-mobile);
    }

    .footer-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      justify-content: stretch;
      width: 100%;
      max-width: 34rem;
    }

    :global(.footer-primary),
    :global(.footer-secondary) {
      width: 100%;
      min-width: 0;
      min-height: 44px;
      --button-padding-x: clamp(.75rem, 3vw, 1rem);
      --button-padding-y: .75rem;
      font-size: clamp(.68rem, 2.8vw, .78rem);
    }

    :global(.footer-secondary:last-child) {
      grid-column: 1 / -1;
      justify-self: center;
      width: min(100%, 16rem);
    }

    .footer-navigation {
      grid-template-columns: 1fr;
    }

    .brand-signature {
      gap: var(--space-4);
    }

    .footer-credit {
      justify-self: start;
      margin-top: calc(var(--space-2) * -1);
    }

    .brand-logo {
      width: min(100%, 18rem);
    }
  }

  @media (max-width: 350px) {
    .footer-actions {
      grid-template-columns: 1fr;
    }

    :global(.footer-secondary:last-child) {
      grid-column: auto;
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-nav-group a:hover,
    .footer-nav-group a:focus-visible,
    .footer-nav-group a:hover::after,
    .footer-nav-group a:focus-visible::after {
      transform: none;
    }
  }
</style>
