---
import Container from "../../components/primitives/Container.astro";
import Eyebrow from "../../components/primitives/Eyebrow.astro";
import Section from "../../components/primitives/Section.astro";
---

<Section class="purpose-section" aria-labelledby="rangbastra-purpose-heading">
  <Container class="purpose-container">
    <div class="purpose-introduction">
      <Eyebrow>About Rangbastra</Eyebrow>
      <h2 id="rangbastra-purpose-heading">What Rangbastra does</h2>
    </div>
    <div class="purpose-copy">
      <p>
        Rangbastra is an online luxury bridal and occasion-wear couture platform
        based in Anand, Gujarat. Customers can explore couture collections,
        create a private account, save favourite pieces, request a personalised
        design consultation, and share measurements, preferences and design
        requirements with the Rangbastra team.
      </p>
      <p class="purpose-authentication">
        Google Sign-In is used to authenticate customers and provide secure
        access to their Rangbastra account, saved inspirations and submitted
        couture enquiries.
      </p>
      <nav class="purpose-links" aria-label="Rangbastra account and policies">
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/terms-and-conditions">Terms &amp; Conditions</a>
        <a href="/account">Create Account or Sign In</a>
      </nav>
    </div>
  </Container>
</Section>

<style>
  :global(.purpose-section) {
    --section-padding-block: clamp(var(--space-8), 8vw, var(--space-11));
    position: relative;
    border-block: 1px solid var(--cocoa-border-soft);
    background: radial-gradient(circle at 16% 28%, rgba(var(--cocoa-rgb), .12), transparent 34%), var(--surface-canvas);
  }
  :global(.purpose-container) {
    display: grid;
    grid-template-columns: minmax(16rem, .8fr) minmax(18rem, 1.2fr);
    gap: clamp(var(--space-6), 8vw, var(--space-11));
    align-items: start;
  }
  .purpose-introduction { display: grid; gap: var(--space-4); }
  h2 {
    max-width: 11ch;
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 5.4rem);
    font-weight: var(--weight-light);
    letter-spacing: var(--tracking-heading);
    line-height: 1;
  }
  .purpose-copy { display: grid; gap: var(--space-5); max-width: 52rem; }
  .purpose-copy p {
    margin: 0;
    color: var(--text-secondary);
    font-size: var(--body-lg);
    line-height: var(--leading-body);
  }
  .purpose-authentication {
    padding-top: var(--space-5);
    border-top: 1px solid var(--cocoa-border-soft);
    color: var(--sand-200) !important;
    font-size: var(--body-md) !important;
  }
  .purpose-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-6);
    padding-top: var(--space-2);
  }
  .purpose-links a {
    color: var(--ivory-100);
    font-size: var(--body-sm);
    text-decoration-color: rgb(var(--cocoa-rgb));
    text-underline-offset: .35em;
  }
  .purpose-links a:hover,
  .purpose-links a:focus-visible { color: var(--sand-200); }
  @media (max-width: 760px) {
    :global(.purpose-container) { grid-template-columns: 1fr; gap: var(--space-7); }
  }
</style>
